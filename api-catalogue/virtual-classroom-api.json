{
  "openapi": "3.0.0",
  "info": {
    "title": "Virtual Classroom API",
    "version": "1.0.0",
    "x-api-id": "virtual-classroom-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Education",
    "x-domain": "Education",
    "description": "Classes virtuelles. Salles de cours en ligne, partage écran et enregistrement."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/classrooms": {
      "get": {
        "summary": "Classes planifiées",
        "operationId": "listClassrooms",
        "tags": [
          "Classrooms"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Créer classe",
        "operationId": "createClassroom",
        "tags": [
          "Classrooms"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/classrooms/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Detail",
        "operationId": "getClassroom",
        "tags": [
          "Classrooms"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Démarrer cours",
        "operationId": "startClass",
        "tags": [
          "Classrooms"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "delete": {
        "summary": "Terminer cours",
        "operationId": "endClass",
        "tags": [
          "Classrooms"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/classrooms/{id}/participants": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Participants",
        "operationId": "getParticipants",
        "tags": [
          "Participants"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Inviter",
        "operationId": "inviteParticipant",
        "tags": [
          "Participants"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/classrooms/{id}/recording": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Enregistrement",
        "operationId": "getRecording",
        "tags": [
          "Recording"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}