          }
        }
      ],
      "get": {
        "summary": "Notes étudiant",
        "operationId": "getGradesV2",
        "tags": [
          "Grades"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Ajouter note",
        "operationId": "addGradeV2",
        "tags": [
          "Grades"
