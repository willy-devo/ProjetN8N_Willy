{
  "openapi": "3.0.0",
  "info": {
    "title": "Key Rotation API",
    "version": "1.0.0",
    "x-api-id": "key-rotation-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Cybersécurité",
    "x-domain": "Cybersecurity",
    "description": "Rotation clés cryptographiques. HSM, KMS et politiques rotation. DIFFERENCE vs certificate-management-api : Key Rotation = clés symétriques/asymétriques KMS, Certificate Management = certificats X.509 publics.",
    "x-false-positive-warning": "Certificats X.509 -> certificate-management-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/keys": {
      "get": {
        "summary": "Clés cryptographiques",
        "operationId": "listCryptoKeys",
        "tags": [
          "Keys"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Créer clé",
        "operationId": "createKey",
        "tags": [
          "Keys"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/keys/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Info clé",
        "operationId": "getKeyInfo",
        "tags": [
          "Keys"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Rotation manuelle",
        "operationId": "rotateKey",
        "tags": [
          "Keys"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "delete": {
        "summary": "Désactiver",
        "operationId": "disableKey",
        "tags": [
          "Keys"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/keys/rotation-policy": {
      "get": {
        "summary": "Politique rotation",
        "operationId": "getRotationPolicy",
        "tags": [
          "Policy"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Mettre a jour",
        "operationId": "updateRotationPolicy",
        "tags": [
          "Policy"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}