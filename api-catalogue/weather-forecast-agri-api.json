{
  "openapi": "3.0.0",
  "info": {
    "title": "Weather Forecast Agri API",
    "version": "1.0.0",
    "x-api-id": "weather-forecast-agri-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Agriculture",
    "x-domain": "Agriculture",
    "description": "Météo agricole hyperlocale. Prévisions, gelées et risques. DIFFERENCE vs energy-forecast-api : Weather Forecast Agri = météo parcelle agricole, Energy Forecast = prévisions consommation énergie.",
    "x-false-positive-warning": "Prévisions énergie -> energy-forecast-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/weather/{fieldId}": {
      "parameters": [
        {
          "name": "fieldId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Prévisions 10j",
        "operationId": "getWeatherForecast",
        "tags": [
          "Weather"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/weather/{fieldId}/frost-alerts": {
      "parameters": [
        {
          "name": "fieldId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Alertes gelée",
        "operationId": "getFrostAlerts",
        "tags": [
          "Frost"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/weather/{fieldId}/agro-indices": {
      "parameters": [
        {
          "name": "fieldId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Indices agrométéo",
        "operationId": "getAgroIndices",
        "tags": [
          "Indices"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}