{
  "openapi": "3.0.0",
  "info": {
    "title": "Config API",
    "version": "1.0.0",
    "x-api-id": "config-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Platform",
    "x-domain": "Infrastructure",
    "description": "Configuration applicative et feature flags."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v1/config/{key}": {
      "parameters": [
        {
          "name": "key",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Récupérer une configuration",
        "operationId": "getConfig",
        "tags": [
          "Config"
        ],
        "responses": {
          "200": {
            "description": "Valeur"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Définir une configuration",
        "operationId": "setConfig",
        "tags": [
          "Config"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "value"
                ],
                "properties": {
                  "value": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Défini"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/config/features": {
      "get": {
        "summary": "Lister les feature flags",
        "operationId": "listFeatureFlags",
        "tags": [
          "Features"
        ],
        "responses": {
          "200": {
            "description": "Feature flags"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/config/features/{flag}/toggle": {
      "parameters": [
        {
          "name": "flag",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "put": {
        "summary": "Activer/désactiver un feature flag",
        "operationId": "toggleFeatureFlag",
        "tags": [
          "Features"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "enabled"
                ],
                "properties": {
                  "enabled": {
                    "type": "boolean"
                  },
                  "rollout_percent": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 100,
                    "description": "Déploiement progressif"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Togglé"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "NOT_FOUND"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Clé API manquante ou invalide",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Ressource non trouvée",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit — ressource déjà existante ou état incompatible",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Clé API Kong Gateway"
      }
    }
  }
}