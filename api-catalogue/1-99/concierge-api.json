{
  "openapi": "3.0.0",
  "info": {
    "title": "Concierge API",
    "version": "1.0.0",
    "x-api-id": "concierge-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Tourisme",
    "x-domain": "Tourism",
    "description": "Services conciergerie hôtelière. Réservations, recommandations et assistance."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
