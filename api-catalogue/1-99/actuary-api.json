{
  "openapi": "3.0.0",
  "info": {
    "title": "Actuary API",
    "version": "1.0.0",
    "x-api-id": "actuary-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Assurance",
    "x-domain": "Insurance",
    "description": "Calculs actuariels. Provisions, réserves et solvabilité."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
