          "Provisions"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/actuary/solvency": {
      "get": {
        "summary": "Ratio solvabilite",
        "operationId": "getSolvencyRatio",
        "tags": [
          "Solvency"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Tester solvabilite",
        "operationId": "runSolvencyTest",
