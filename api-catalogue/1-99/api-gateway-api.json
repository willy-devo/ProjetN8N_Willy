{
  "openapi": "3.0.0",
  "info": {
    "title": "API Gateway API",
    "version": "1.0.0",
    "x-api-id": "api-gateway-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Divers",
    "x-domain": "Cross",
    "description": "Gestion passerelle API. Routes, auth et monitoring."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/gateway/routes": {
      "get": {
        "summary": "Routes",
        "operationId": "listRoutes",
        "tags": [
          "Routes"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Ajouter route",
        "operationId": "addRoute",
        "tags": [
          "Routes"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/gateway/routes/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Detail",
        "operationId": "getRoute",
        "tags": [
          "Routes"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Modifier",
        "operationId": "updateRoute",
        "tags": [
          "Routes"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "delete": {
        "summary": "Supprimer",
        "operationId": "removeRoute",
        "tags": [
          "Routes"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/gateway/consumers": {
      "get": {
        "summary": "Consommateurs",
        "operationId": "listConsumers",
        "tags": [
          "Consumers"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Ajouter",
        "operationId": "addConsumer",
        "tags": [
          "Consumers"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/gateway/analytics": {
      "get": {
        "summary": "Trafic API",
        "operationId": "getGatewayAnalytics",
        "tags": [
          "Analytics"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}