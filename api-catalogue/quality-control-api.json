{
  "openapi": "3.0.0",
  "info": {
    "title": "Quality Control API",
    "version": "1.0.0",
    "x-api-id": "quality-control-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Industrie",
    "x-domain": "Industry",
    "description": "Controle qualite production. Plans de controle, mesures et non-conformites. DIFFERENCE vs data-quality-api : Quality Control = qualite produit physique, Data Quality = qualite donnees informatiques.",
    "x-false-positive-warning": "Qualite donnees -> data-quality-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/quality/plans": {
      "get": {
        "summary": "Plans de controle",
        "operationId": "listQualityPlans",
        "tags": [
          "Plans"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Creer",
        "operationId": "createQualityPlan",
        "tags": [
          "Plans"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/quality/checks/{orderId}": {
      "parameters": [
        {
          "name": "orderId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Controles",
        "operationId": "getQualityChecks",
        "tags": [
          "Checks"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Realiser controle",
        "operationId": "performCheck",
        "tags": [
          "Checks"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/quality/nonconformities": {
      "get": {
        "summary": "Non-conformites",
        "operationId": "listNonConformities",
        "tags": [
          "NC"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Declarer NC",
        "operationId": "createNC",
        "tags": [
          "NC"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/quality/nonconformities/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Detail NC",
        "operationId": "getNC",
        "tags": [
          "NC"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Resoudre NC",
        "operationId": "resolveNC",
        "tags": [
          "NC"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}