{
  "openapi": "3.0.0",
  "info": {
    "title": "Analytics API",
    "version": "2.0.0",
    "x-api-id": "analytics-api-v2",
    "x-api-version": "v2",
    "x-status": "active",
    "x-team": "Equipe Data",
    "x-domain": "Analytics & BI",
    "description": "Version 2 Analytics. Entonnoirs configurables, segments en temps réel, export streaming et dashboards partagés. DIFFÉRENCE vs v1 : ajout du streaming, des entonnoirs custom et du partage de dashboards.",
    "x-breaking-changes-from-previous": [
      "Entonnoirs custom (nouveau)",
      "Streaming export via SSE",
      "Dashboards partagés avec tokens",
      "Segments temps réel"
    ]
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v2/analytics/sales": {
      "get": {
        "summary": "Métriques ventes v2",
        "operationId": "getSalesV2",
        "tags": [
          "Analytics"
        ],
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "to",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "granularity",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "hour",
                "day",
                "week",
                "month"
              ],
              "default": "day"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Métriques"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v2/analytics/funnels": {
      "post": {
        "summary": "Créer et analyser un entonnoir custom",
        "operationId": "analyzeFunnel",
        "tags": [
          "Funnels"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "steps"
                ],
                "properties": {
                  "steps": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "date_range": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Analyse entonnoir"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v2/analytics/dashboard/share": {
      "post": {
        "summary": "Partager un dashboard avec un token d'accès public",
        "operationId": "shareDashboard",
        "tags": [
          "Dashboard"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "dashboard_id"
                ],
                "properties": {
                  "dashboard_id": {
                    "type": "string"
                  },
                  "expires_in_days": {
                    "type": "integer",
                    "default": 7
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Lien partageable généré"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v2/analytics/stream": {
      "get": {
        "summary": "Métriques temps réel en streaming (Server-Sent Events)",
        "operationId": "streamAnalytics",
        "tags": [
          "Stream"
        ],
        "parameters": [
          {
            "name": "metrics",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Stream SSE"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Non autorisé",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Non trouvé",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}