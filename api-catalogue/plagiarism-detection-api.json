{
  "openapi": "3.0.0",
  "info": {
    "title": "Plagiarism Detection API",
    "version": "1.0.0",
    "x-api-id": "plagiarism-detection-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Education",
    "x-domain": "Education",
    "description": "Détection de plagiat. Analyse similarité et rapport détaillé."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/plagiarism/check": {
      "post": {
        "summary": "Analyser document",
        "operationId": "checkPlagiarism",
        "tags": [
          "Check"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/plagiarism/reports/{documentId}": {
      "parameters": [
        {
          "name": "documentId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Documents similaires",
        "operationId": "getSimilarDocuments",
        "tags": [
          "Reports"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}