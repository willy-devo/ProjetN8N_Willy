{
  "openapi": "3.0.0",
  "info": {
    "title": "Alert API",
    "version": "1.0.0",
    "x-api-id": "alert-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Platform",
    "x-domain": "Communication",
    "description": "Alertes système et gestion des incidents. Pannes, seuils dépassés, escalades vers équipes OPS. DIFFÉRENCE vs notification-api : Alert cible les équipes techniques internes (PagerDuty, Slack ops), Notification cible les clients finaux. DIFFÉRENCE vs messaging-api : Alert est automatisé par des règles, Messaging est initié par un humain. DIFFÉRENCE vs email-api : Alert peut notifier par email mais son rôle est l'incident management.",
    "x-false-positive-warning": "Notifier un client → notification-api. Chat humain → messaging-api. Email marketing → email-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v1/alerts": {
      "post": {
        "summary": "Créer une alerte manuelle",
        "operationId": "createAlert",
        "tags": [
          "Alerts"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AlertCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Créée"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "get": {
        "summary": "Lister les alertes actives",
        "operationId": "listAlerts",
        "tags": [
          "Alerts"
        ],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "active",
                "acknowledged",
                "resolved"
              ]
            }
          },
          {
            "name": "severity",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "critical",
                "high",
                "medium",
                "low"
              ]
            }
          },
          {
            "name": "service",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Alertes"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/alerts/{id}/acknowledge": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "put": {
        "summary": "Acquitter une alerte",
        "operationId": "ackAlert",
        "tags": [
          "Alerts"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "acknowledged_by": {
                    "type": "string"
                  },
                  "comment": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Acquittée"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/alerts/{id}/resolve": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "put": {
        "summary": "Résoudre une alerte",
        "operationId": "resolveAlert",
        "tags": [
          "Alerts"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "resolved_by": {
                    "type": "string"
                  },
                  "root_cause": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Résolue"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/alerts/rules": {
      "get": {
        "summary": "Lister les règles d'alerte",
        "operationId": "getRules",
        "tags": [
          "Rules"
        ],
        "responses": {
          "200": {
            "description": "Règles"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Créer une règle d'alerte automatique",
        "operationId": "createRule",
        "tags": [
          "Rules"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AlertRule"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Créée"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "AlertCreate": {
        "type": "object",
        "required": [
          "title",
          "severity",
          "service"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "service": {
            "type": "string",
            "example": "payment-api"
          },
          "description": {
            "type": "string"
          },
          "notify_channels": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "slack",
                "pagerduty",
                "email"
              ]
            }
          }
        }
      },
      "AlertRule": {
        "type": "object",
        "required": [
          "name",
          "condition",
          "severity"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "condition": {
            "type": "string",
            "example": "error_rate > 5%"
          },
          "severity": {
            "type": "string"
          },
          "cooldown_minutes": {
            "type": "integer",
            "default": 15
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "NOT_FOUND"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Clé API manquante ou invalide",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Ressource non trouvée",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit — ressource déjà existante ou état incompatible",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Clé API Kong Gateway"
      }
    }
  }
}