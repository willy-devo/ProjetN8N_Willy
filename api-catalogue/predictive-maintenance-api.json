{
  "openapi": "3.0.0",
  "info": {
    "title": "Predictive Maintenance API",
    "version": "1.0.0",
    "x-api-id": "predictive-maintenance-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe IoT",
    "x-domain": "IoT",
    "description": "Maintenance prédictive ML sur équipements industriels. Détection pannes anticipées et recommandations."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/maintenance/predictions/{deviceId}": {
      "parameters": [
        {
          "name": "deviceId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Prédictions pannes",
        "operationId": "getMaintenancePredictions",
        "tags": [
          "Predictions"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Lancer analyse",
        "operationId": "runPrediction",
        "tags": [
          "Predictions"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/maintenance/alerts": {
      "get": {
        "summary": "Alertes maintenance",
        "operationId": "getMaintenanceAlerts",
        "tags": [
          "Alerts"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Acquitter",
        "operationId": "acknowledgeAlert",
        "tags": [
          "Alerts"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/maintenance/history/{deviceId}": {
      "parameters": [
        {
          "name": "deviceId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Historique interventions",
        "operationId": "getMaintenanceHistory",
        "tags": [
          "History"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}