        "summary": "Schemas",
        "operationId": "listSchemas",
        "tags": [
          "Schemas"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Creer",
        "operationId": "createSchema",
        "tags": [
          "Schemas"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/warehouse/tables/{schema}": {
      "parameters": [
        {
          "name": "schema",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Tables",
        "operationId": "listTables",
        "tags": [
          "Tables"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
