{
  "openapi": "3.0.0",
  "info": {
    "title": "Data Warehouse API",
    "version": "1.0.0",
    "x-api-id": "data-warehouse-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Data",
    "x-domain": "Data",
    "description": "Entrepot donnees structure. Tables, vues et requetes BI. DIFFERENCE vs data-lake-api : Data Warehouse = donnees structurees pour BI, Data Lake = donnees brutes.",
