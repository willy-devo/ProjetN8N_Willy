{
  "openapi": "3.0.0",
  "info": {
    "title": "Waste-Management API",
    "version": "1.0.0",
    "x-api-id": "waste-management-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Industrie",
    "x-domain": "Industry",
    "description": "Gestion dechets industriels. Tri, traceabilite et reporting reglementaire."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/waste/streams": {
      "get": {
        "summary": "Flux dechets",
        "operationId": "listWasteStreams",
        "tags": [
          "Streams"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Ajouter flux",
        "operationId": "addWasteStream",
        "tags": [
          "Streams"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/waste/records": {
      "get": {
        "summary": "Enregistrements",
        "operationId": "listWasteRecords",
        "tags": [
          "Records"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Declarer dechet",
        "operationId": "recordWasteProduction",
        "tags": [
          "Records"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/waste/reports": {
      "get": {
        "summary": "Rapport dechets",
        "operationId": "getWasteReport",
        "tags": [
          "Reports"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Rapport reglementaire",
        "operationId": "submitRegulatoryReport",
        "tags": [
          "Reports"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}