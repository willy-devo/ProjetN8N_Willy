{
  "openapi": "3.0.0",
  "info": {
    "title": "Sanctions Screening API",
    "version": "1.0.0",
    "x-api-id": "sanctions-screening-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Legal",
    "x-domain": "Legal",
    "description": "Criblage listes sanctions internationales. UE, OFAC, ONU et gel avoirs."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/sanctions/screen": {
      "post": {
        "summary": "Criblage en masse",
        "operationId": "screenBatch",
        "tags": [
          "Screen"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/sanctions/lists": {
      "get": {
        "summary": "Dernière mise a jour",
        "operationId": "getLastUpdate",
        "tags": [
          "Lists"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/sanctions/alerts": {
      "get": {
        "summary": "Alertes criblage",
        "operationId": "getSanctionAlerts",
        "tags": [
          "Alerts"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Résoudre alerte",
        "operationId": "resolveSanctionAlert",
        "tags": [
          "Alerts"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}