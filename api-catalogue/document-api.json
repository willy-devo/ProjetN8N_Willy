{
  "openapi": "3.0.0",
  "info": {
    "title": "Document API",
    "version": "1.0.0",
    "x-api-id": "document-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Platform",
    "x-domain": "Infrastructure",
    "description": "Génération de documents (contrats, CGV, devis). Templates Word/PDF et signature électronique. DIFFÉRENCE vs file-storage-api : Document API génère des documents à partir de templates, File Storage stocke des fichiers existants.",
    "x-false-positive-warning": "Stockage de fichiers → file-storage-api. Factures → invoice-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/documents/generate": {
      "post": {
        "summary": "Générer un document depuis un template",
        "operationId": "generateDocument",
        "tags": [
          "Documents"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "template_id",
                  "data"
                ],
                "properties": {
                  "template_id": {
                    "type": "string"
                  },
                  "data": {
                    "type": "object",
                    "description": "Variables injectées dans le template"
                  },
                  "format": {
                    "type": "string",
                    "enum": [
                      "pdf",
                      "docx"
                    ],
                    "default": "pdf"
                  },
                  "sign": {
                    "type": "boolean",
                    "default": false
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Document généré"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/documents/templates": {
      "get": {
        "summary": "Lister les templates disponibles",
        "operationId": "listDocTemplates",
        "tags": [
          "Templates"
        ],
        "responses": {
          "200": {
            "description": "Templates"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Créer un template document",
        "operationId": "createDocTemplate",
        "tags": [
          "Templates"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "content"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "format": {
                    "type": "string",
                    "enum": [
                      "docx",
                      "pdf"
                    ]
                  },
                  "content": {
                    "type": "string",
                    "description": "Template Handlebars ou base64 .docx"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Template créé"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/documents/{id}/sign": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "post": {
        "summary": "Demander une signature électronique",
        "operationId": "requestSignature",
        "tags": [
          "Signatures"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "signatories"
                ],
                "properties": {
                  "signatories": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "email": {
                          "type": "string",
                          "format": "email"
                        },
                        "name": {
                          "type": "string"
                        },
                        "order": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Demande de signature envoyée"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Non autorisé",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Non trouvé",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}