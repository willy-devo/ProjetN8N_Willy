{
  "openapi": "3.0.0",
  "info": {
    "title": "Customs Clearance API",
    "version": "1.0.0",
    "x-api-id": "customs-clearance-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Transport",
    "x-domain": "Transport",
    "description": "Dédouanement marchandises. Déclarations douanières, droits et suivi."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/customs/declarations": {
      "get": {
        "summary": "Déclarations en cours",
        "operationId": "listDeclarations",
        "tags": [
          "Declarations"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Créer déclaration",
        "operationId": "createDeclaration",
        "tags": [
          "Declarations"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/customs/declarations/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Detail",
        "operationId": "getDeclaration",
        "tags": [
          "Declarations"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Modifier",
        "operationId": "updateDeclaration",
        "tags": [
          "Declarations"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Soumettre",
        "operationId": "submitDeclaration",
        "tags": [
          "Declarations"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/customs/tariffs": {
      "post": {
        "summary": "Calculer droits et taxes",
        "operationId": "calculateTariffs",
        "tags": [
          "Tariffs"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}