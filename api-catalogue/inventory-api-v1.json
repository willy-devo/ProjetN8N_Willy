{
  "openapi": "3.0.0",
  "info": {
    "title": "Inventory API",
    "version": "1.0.0",
    "x-api-id": "inventory-api-v1",
    "x-api-version": "v1",
    "x-status": "deprecated",
    "x-team": "Equipe Logistique",
    "x-domain": "Supply Chain",
    "description": "Version 1 inventaire. DEPRECATED 2021. Pas d'alertes de seuil, pas de réapprovisionnement automatique, pas d'historique mouvements. Migrer vers v3.",
    "x-breaking-changes-from-previous": "N/A — version initiale",
    "x-breaking-changes-in-next": [
      "Alertes de seuil de stock",
      "Réapprovisionnement automatique",
      "Historique des mouvements par produit",
      "Support multi-entrepôts"
    ],
    "x-successor": "inventory-api"
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/inventory": {
      "get": {
        "summary": "Inventaire global",
        "operationId": "listInventoryV1",
        "tags": [
          "Inventory"
        ],
        "responses": {
          "200": {
            "description": "Inventaire"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/inventory/{productId}": {
      "parameters": [
        {
          "name": "productId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Stock d'un produit",
        "operationId": "getInventoryV1",
        "tags": [
          "Inventory"
        ],
        "responses": {
          "200": {
            "description": "Stock"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Mettre à jour le stock",
        "operationId": "updateInventoryV1",
        "tags": [
          "Inventory"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "quantity"
                ],
                "properties": {
                  "quantity": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Mis à jour"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Non autorisé",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Non trouvé",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}