{
  "openapi": "3.0.0",
  "info": {
    "title": "POS API",
    "version": "1.0.0",
    "x-api-id": "pos-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Retail",
    "x-domain": "Retail",
    "description": "Point of Sale en magasin. Transactions, tiroir-caisse et reçus."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/pos/transactions": {
      "get": {
        "summary": "Transactions",
        "operationId": "listPOSTransactions",
        "tags": [
          "Transactions"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Créer vente",
        "operationId": "createPOSTransaction",
        "tags": [
          "Transactions"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/pos/transactions/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Detail",
        "operationId": "getPOSTransaction",
        "tags": [
          "Transactions"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Annuler vente",
        "operationId": "voidTransaction",
        "tags": [
          "Transactions"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/pos/sessions": {
      "get": {
        "summary": "Session ouverte",
        "operationId": "getCurrentSession",
        "tags": [
          "Sessions"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Fermer caisse",
        "operationId": "closeSession",
        "tags": [
          "Sessions"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}