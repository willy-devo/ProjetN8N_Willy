{
  "openapi": "3.0.0",
  "info": {
    "title": "Metrics API",
    "version": "1.0.0",
    "x-api-id": "metrics-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Data",
    "x-domain": "Analytics & BI",
    "description": "Métriques techniques et business. KPIs d'ingénierie (latence, taux d'erreur) et business. DIFFÉRENCE vs analytics-api : Metrics = orienté ingénierie et monitoring, Analytics = orienté business et ventes.",
    "x-false-positive-warning": "Métriques business → analytics-api. Rapports → reporting-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v1/metrics": {
      "post": {
        "summary": "Publier une métrique custom",
        "operationId": "publishMetric",
        "tags": [
          "Metrics"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "value",
                  "tags"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "example": "api.response_time"
                  },
                  "value": {
                    "type": "number"
                  },
                  "unit": {
                    "type": "string",
                    "enum": [
                      "ms",
                      "count",
                      "percent",
                      "bytes"
                    ]
                  },
                  "tags": {
                    "type": "object",
                    "example": {
                      "service": "order-api",
                      "env": "prod"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Publiée"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/metrics/{name}": {
      "parameters": [
        {
          "name": "name",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Récupérer une métrique sur une période",
        "operationId": "getMetric",
        "tags": [
          "Metrics"
        ],
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "to",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "aggregation",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "avg",
                "min",
                "max",
                "sum",
                "p95",
                "p99"
              ],
              "default": "avg"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Métrique"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/metrics/kpis": {
      "get": {
        "summary": "KPIs techniques globaux",
        "operationId": "getKPIs",
        "tags": [
          "Metrics"
        ],
        "responses": {
          "200": {
            "description": "KPIs"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/metrics/query": {
      "post": {
        "summary": "Requête avancée multi-métriques",
        "operationId": "queryMetrics",
        "tags": [
          "Metrics"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "metrics": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "from": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "to": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "group_by": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Résultats"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "NOT_FOUND"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Clé API manquante ou invalide",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Ressource non trouvée",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit — ressource déjà existante ou état incompatible",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Clé API Kong Gateway"
      }
    }
  }
}