{
  "openapi": "3.0.0",
  "info": {
    "title": "Harvest API",
    "version": "1.0.0",
    "x-api-id": "harvest-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Agriculture",
    "x-domain": "Agriculture",
    "description": "Planification et suivi des récoltes. Dates optimales, équipements et tonnages."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/harvests": {
      "get": {
        "summary": "Récoltes planifiées",
        "operationId": "listHarvests",
        "tags": [
          "Harvests"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Planifier récolte",
        "operationId": "createHarvest",
        "tags": [
          "Harvests"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/harvests/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Detail",
        "operationId": "getHarvest",
        "tags": [
          "Harvests"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Modifier",
        "operationId": "updateHarvest",
        "tags": [
          "Harvests"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Terminer récolte",
        "operationId": "completeHarvest",
        "tags": [
          "Harvests"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/harvests/{id}/tonnage": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Tonnage récolté",
        "operationId": "getTonnage",
        "tags": [
          "Tonnage"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Enregistrer",
        "operationId": "recordTonnage",
        "tags": [
          "Tonnage"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}