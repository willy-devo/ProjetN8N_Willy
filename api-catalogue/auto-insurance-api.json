{
  "openapi": "3.0.0",
  "info": {
    "title": "Auto Insurance API",
    "version": "1.0.0",
    "x-api-id": "auto-insurance-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Assurance",
    "x-domain": "Insurance",
    "description": "Assurance automobile. Contrats, bonus-malus et constat amiable."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/auto-insurance/{vehicleId}": {
      "parameters": [
        {
          "name": "vehicleId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Assurance véhicule",
        "operationId": "getAutoInsurance",
        "tags": [
          "AutoInsurance"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Souscrire",
        "operationId": "subscribeAutoInsurance",
        "tags": [
          "AutoInsurance"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/auto-insurance/{contractId}/bonus-malus": {
      "parameters": [
        {
          "name": "contractId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Coefficient B/M",
        "operationId": "getBonusMalus",
        "tags": [
          "BonusMalus"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/auto-insurance/accident-report": {
      "post": {
        "summary": "Créer constat amiable",
        "operationId": "createAccidentReport",
        "tags": [
          "Accident"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}