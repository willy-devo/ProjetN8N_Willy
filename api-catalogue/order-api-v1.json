{
  "openapi": "3.0.0",
  "info": {
    "title": "Order API",
    "version": "1.0.0",
    "x-api-id": "order-api",
    "x-api-version": "v1",
    "x-status": "deprecated",
    "x-team": "Equipe Commerce",
    "x-domain": "E-Commerce",
    "description": "Version initiale de l'API commandes. DEPRECATED depuis 2021. Ne supporte qu'un seul produit par commande, IDs entiers, pas de remises ni de pagination. Migrer vers v2.",
    "x-breaking-changes-in-next": [
      "ID commande integer→string ORD-XXXX",
      "customer_id integer→string CUST-XXX",
      "product_id unique→tableau items",
      "Suppression directe interdite→utiliser /cancel"
    ],
    "x-successor": "order-api-v2"
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v1/orders": {
      "post": {
        "summary": "Créer une commande (mono-produit)",
        "operationId": "createOrderV1",
        "tags": [
          "Orders"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OrderV1Create"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Commande créée",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderV1"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "get": {
        "summary": "Lister les commandes",
        "operationId": "listOrdersV1",
        "tags": [
          "Orders"
        ],
        "parameters": [
          {
            "name": "customer_id",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "pending",
                "shipped",
                "delivered"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Liste",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/OrderV1"
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/orders/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "integer"
          },
          "description": "ID entier — BREAKING CHANGE en v2 où l'ID devient string ORD-XXXX"
        }
      ],
      "get": {
        "summary": "Récupérer une commande",
        "operationId": "getOrderV1",
        "tags": [
          "Orders"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderV1"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "delete": {
        "summary": "Supprimer une commande — BREAKING: remplacé par /cancel en v2",
        "operationId": "deleteOrderV1",
        "tags": [
          "Orders"
        ],
        "responses": {
          "204": {
            "description": "Supprimée"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "OrderV1Create": {
        "type": "object",
        "required": [
          "customer_id",
          "product_id",
          "quantity"
        ],
        "properties": {
          "customer_id": {
            "type": "integer",
            "example": 42,
            "description": "BREAKING v2: devient string CUST-XXX"
          },
          "product_id": {
            "type": "integer",
            "example": 101,
            "description": "BREAKING v2: remplacé par tableau items"
          },
          "quantity": {
            "type": "integer",
            "minimum": 1
          },
          "shipping_address": {
            "type": "string"
          }
        }
      },
      "OrderV1": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1001,
            "description": "BREAKING v2: devient string ORD-XXXX"
          },
          "customer_id": {
            "type": "integer"
          },
          "product_id": {
            "type": "integer"
          },
          "quantity": {
            "type": "integer"
          },
          "total_price": {
            "type": "number"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "shipped",
              "delivered"
            ]
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "NOT_FOUND"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Clé API manquante ou invalide",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Ressource non trouvée",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit — ressource déjà existante ou état incompatible",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Clé API Kong Gateway"
      }
    }
  }
}