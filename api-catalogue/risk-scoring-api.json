{
  "openapi": "3.0.0",
  "info": {
    "title": "Risk Scoring API",
    "version": "1.0.0",
    "x-api-id": "risk-scoring-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Assurance",
    "x-domain": "Insurance",
    "description": "Scoring risque assurance. Modèles actuariels et ML. DIFFERENCE vs credit-scoring-api : Risk Scoring = risque assurable (santé, auto, habitation), Credit Scoring = risque crédit bancaire.",
    "x-false-positive-warning": "Risque credit -> credit-scoring-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/risk/score": {
      "post": {
        "summary": "Calculer score risque",
        "operationId": "scoreRisk",
        "tags": [
          "Risk"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/risk/{clientId}": {
      "parameters": [
        {
          "name": "clientId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Score risque client",
        "operationId": "getClientRisk",
        "tags": [
          "Risk"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/risk/models": {
      "get": {
        "summary": "Modèles disponibles",
        "operationId": "listRiskModels",
        "tags": [
          "Models"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}