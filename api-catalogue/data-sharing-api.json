{
  "openapi": "3.0.0",
  "info": {
    "title": "Data Sharing API",
    "version": "1.0.0",
    "x-api-id": "data-sharing-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Data",
    "x-domain": "Data",
    "description": "Partage securise de donnees. Accords, acces controles et expiration."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
