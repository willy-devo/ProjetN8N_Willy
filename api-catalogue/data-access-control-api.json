{
  "openapi": "3.0.0",
  "info": {
    "title": "Data Access Control API",
    "version": "1.0.0",
    "x-api-id": "data-access-control-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Data",
    "x-domain": "Data",
    "description": "Controle acces donnees. RBAC, policies et audits acces. DIFFERENCE vs permission-api : Data Access Control = droits sur datasets, Permission = droits applicatifs generiques.",
    "x-false-positive-warning": "Droits applicatifs -> permission-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/data-access/policies": {
      "get": {
        "summary": "Politiques acces",
        "operationId": "listDataAccessPolicies",
        "tags": [
          "Policies"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Creer",
        "operationId": "createDataAccessPolicy",
        "tags": [
          "Policies"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/data-access/{datasetId}/grants": {
      "parameters": [
        {
          "name": "datasetId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Droits accordes",
        "operationId": "getDataGrants",
        "tags": [
          "Grants"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Accorder acces",
        "operationId": "grantAccess",
        "tags": [
          "Grants"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "delete": {
        "summary": "Revoquer acces",
        "operationId": "revokeAccess",
        "tags": [
          "Grants"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}