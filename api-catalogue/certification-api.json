{
  "openapi": "3.0.0",
  "info": {
    "title": "Certification API",
    "version": "1.0.0",
    "x-api-id": "certification-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Education",
    "x-domain": "Education",
    "description": "Certifications et diplômes numériques. Émission, vérification et badges. DIFFERENCE vs grade-api : Certification = diplôme officiel émis, Grade = note de contrôle continu.",
    "x-false-positive-warning": "Note contrôle continu -> grade-api-v2."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/certifications": {
      "get": {
        "summary": "Certifications émises",
        "operationId": "listCertifications",
        "tags": [
          "Certifications"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Émettre certification",
        "operationId": "issueCertification",
        "tags": [
          "Certifications"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/certifications/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Vérifier authenticité",
        "operationId": "verifyCertification",
        "tags": [
          "Certifications"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/certifications/{studentId}/all": {
      "parameters": [
        {
          "name": "studentId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Toutes certifications",
        "operationId": "getAllCertifications",
        "tags": [
          "All"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}