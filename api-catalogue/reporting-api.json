{
  "openapi": "3.0.0",
  "info": {
    "title": "Reporting API",
    "version": "1.0.0",
    "x-api-id": "reporting-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Data",
    "x-domain": "Analytics & BI",
    "description": "Génération de rapports planifiés. Export PDF, Excel, tableaux de bord programmés. DIFFÉRENCE vs analytics-api : Reporting = documents générés et envoyés par email, Analytics = métriques consultables en temps réel.",
    "x-false-positive-warning": "Métriques temps réel → analytics-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v1/reports/generate": {
      "post": {
        "summary": "Générer un rapport",
        "operationId": "generateReportDoc",
        "tags": [
          "Reports"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "type",
                  "format"
                ],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": [
                      "sales",
                      "inventory",
                      "customers",
                      "orders"
                    ]
                  },
                  "format": {
                    "type": "string",
                    "enum": [
                      "pdf",
                      "excel",
                      "csv"
                    ]
                  },
                  "date_range": {
                    "type": "object",
                    "properties": {
                      "from": {
                        "type": "string",
                        "format": "date"
                      },
                      "to": {
                        "type": "string",
                        "format": "date"
                      }
                    }
                  },
                  "filters": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Génération lancée"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/reports/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Statut de génération",
        "operationId": "getReportStatus",
        "tags": [
          "Reports"
        ],
        "responses": {
          "200": {
            "description": "Statut"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/reports/{id}/download": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Télécharger le rapport",
        "operationId": "downloadReport",
        "tags": [
          "Reports"
        ],
        "responses": {
          "200": {
            "description": "Fichier"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/reports/schedule": {
      "post": {
        "summary": "Planifier un rapport récurrent",
        "operationId": "scheduleReport",
        "tags": [
          "Reports"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string"
                  },
                  "format": {
                    "type": "string"
                  },
                  "cron": {
                    "type": "string",
                    "example": "0 8 * * MON"
                  },
                  "recipients": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "email"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Planifié"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/reports/templates": {
      "get": {
        "summary": "Modèles de rapports disponibles",
        "operationId": "getReportTemplates",
        "tags": [
          "Reports"
        ],
        "responses": {
          "200": {
            "description": "Templates"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "NOT_FOUND"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Clé API manquante ou invalide",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Ressource non trouvée",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit — ressource déjà existante ou état incompatible",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Clé API Kong Gateway"
      }
    }
  }
}