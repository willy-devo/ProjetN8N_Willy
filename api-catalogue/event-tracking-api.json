{
  "openapi": "3.0.0",
  "info": {
    "title": "Event Tracking API",
    "version": "1.0.0",
    "x-api-id": "event-tracking-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Data",
    "x-domain": "Analytics & BI",
    "description": "Collecte d'événements comportementaux utilisateurs. Clics, pages vues, funnels de conversion."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v1/events/track": {
      "post": {
        "summary": "Enregistrer un événement utilisateur",
        "operationId": "trackEvent",
        "tags": [
          "Events"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "event",
                  "user_id"
                ],
                "properties": {
                  "event": {
                    "type": "string",
                    "example": "product.viewed"
                  },
                  "user_id": {
                    "type": "string"
                  },
                  "properties": {
                    "type": "object"
                  },
                  "timestamp": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "session_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Enregistré"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/events/batch": {
      "post": {
        "summary": "Envoi groupé d'événements",
        "operationId": "trackBatchEvents",
        "tags": [
          "Events"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "events": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    },
                    "maxItems": 100
                  }
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Traitement asynchrone"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/events/funnels/{funnelId}": {
      "parameters": [
        {
          "name": "funnelId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Analyse d'un funnel de conversion",
        "operationId": "getFunnel",
        "tags": [
          "Funnels"
        ],
        "responses": {
          "200": {
            "description": "Funnel"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/events/sessions/{userId}": {
      "parameters": [
        {
          "name": "userId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Sessions d'un utilisateur",
        "operationId": "getUserSessions",
        "tags": [
          "Sessions"
        ],
        "responses": {
          "200": {
            "description": "Sessions"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "NOT_FOUND"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Clé API manquante ou invalide",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Ressource non trouvée",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit — ressource déjà existante ou état incompatible",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Clé API Kong Gateway"
      }
    }
  }
}