{
  "openapi": "3.0.0",
  "info": {
    "title": "Warehouse API",
    "version": "1.0.0",
    "x-api-id": "warehouse-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Logistique",
    "x-domain": "Supply Chain",
    "description": "Entrepôts et emplacements physiques. Mouvements de stock inter-entrepôts. DIFFÉRENCE vs inventory-api : Warehouse = où sont les produits (entrepôt, allée, étagère), Inventory = combien en stock.",
    "x-false-positive-warning": "Quantités de stock → inventory-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v1/warehouses": {
      "get": {
        "summary": "Lister les entrepôts",
        "operationId": "listWarehouses",
        "tags": [
          "Warehouses"
        ],
        "responses": {
          "200": {
            "description": "Entrepôts"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/warehouses/{id}/stock": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Stock d'un entrepôt",
        "operationId": "getWarehouseStock",
        "tags": [
          "Warehouses"
        ],
        "responses": {
          "200": {
            "description": "Stock"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/warehouses/transfer": {
      "post": {
        "summary": "Transférer du stock entre entrepôts",
        "operationId": "transferStock",
        "tags": [
          "Warehouses"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "product_id",
                  "from_warehouse",
                  "to_warehouse",
                  "quantity"
                ],
                "properties": {
                  "product_id": {
                    "type": "string"
                  },
                  "from_warehouse": {
                    "type": "string"
                  },
                  "to_warehouse": {
                    "type": "string"
                  },
                  "quantity": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Transfert initié"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/warehouses/{id}/locations": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Emplacements dans un entrepôt (allées, étagères)",
        "operationId": "getLocations",
        "tags": [
          "Warehouses"
        ],
        "responses": {
          "200": {
            "description": "Emplacements"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "NOT_FOUND"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Clé API manquante ou invalide",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Ressource non trouvée",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit — ressource déjà existante ou état incompatible",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Clé API Kong Gateway"
      }
    }
  }
}