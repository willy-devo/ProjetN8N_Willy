{
  "openapi": "3.0.0",
  "info": {
    "title": "Food Safety API",
    "version": "1.0.0",
    "x-api-id": "food-safety-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Agriculture",
    "x-domain": "Agriculture",
    "description": "Securite alimentaire. Conformite HACCP, alertes et retraits produits."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/food-safety/checks": {
      "get": {
        "summary": "Controles",
        "operationId": "listFoodSafetyChecks",
        "tags": [
          "Checks"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Creer controle",
        "operationId": "createFoodSafetyCheck",
        "tags": [
          "Checks"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/food-safety/recalls": {
      "get": {
        "summary": "Retraits actifs",
        "operationId": "listRecalls",
        "tags": [
          "Recalls"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Initier retrait",
        "operationId": "initiateRecall",
        "tags": [
          "Recalls"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/food-safety/alerts": {
      "get": {
        "summary": "Alertes",
        "operationId": "getFoodSafetyAlerts",
        "tags": [
          "Alerts"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}