{
  "openapi": "3.0.0",
  "info": {
    "title": "Experiment Tracking API",
    "version": "1.0.0",
    "x-api-id": "experiment-tracking-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Data",
    "x-domain": "Data",
    "description": "Suivi experiences ML. Runs, metriques et comparaison."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
