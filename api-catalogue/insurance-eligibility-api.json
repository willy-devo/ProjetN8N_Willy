{
  "openapi": "3.0.0",
  "info": {
    "title": "Insurance Eligibility API",
    "version": "1.0.0",
    "x-api-id": "insurance-eligibility-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Santé",
    "x-domain": "Healthcare",
    "description": "Vérification droits assurance maladie AMO/AMC et calcul reste à charge. DIFFÉRENCE vs health-insurance-api : Insurance Eligibility = vérification droits côté soin, Health Insurance = gestion contrats côté assureur.",
    "x-false-positive-warning": "Contrats assurance santé → health-insurance-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v1/eligibility/check": {
      "post": {
        "summary": "Vérifier droits ouverts",
        "operationId": "checkEligibility",
        "tags": [
          "Eligibility"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/eligibility/{patientId}": {
      "parameters": [
        {
          "name": "patientId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Droits du patient",
        "operationId": "getEligibility",
        "tags": [
          "Eligibility"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/eligibility/{patientId}/coverage": {
      "parameters": [
        {
          "name": "patientId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Détail couverture",
        "operationId": "getCoverage",
        "tags": [
          "Coverage"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "NotFound": {
        "description": "Ressource non trouvée"
      },
      "BadRequest": {
        "description": "Données invalides"
      },
      "Unauthorized": {
        "description": "Clé API invalide"
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}