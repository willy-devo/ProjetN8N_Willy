{
  "openapi": "3.0.0",
  "info": {
    "title": "Flight Booking API",
    "version": "1.0.0",
    "x-api-id": "flight-booking-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Tourisme",
    "x-domain": "Tourism",
    "description": "Réservation vols. Recherche, sièges et check-in en ligne."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/flights/search": {
      "post": {
        "summary": "Rechercher vols",
        "operationId": "searchFlights",
        "tags": [
          "Search"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/flights/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Detail vol",
        "operationId": "getFlightDetails",
        "tags": [
          "Flights"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Réserver vol",
        "operationId": "bookFlight",
        "tags": [
          "Flights"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/flights/{bookingId}/seat": {
      "parameters": [
        {
          "name": "bookingId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Plan cabine",
        "operationId": "getSeatMap",
        "tags": [
          "Seats"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Choisir siège",
        "operationId": "selectSeat",
        "tags": [
          "Seats"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/flights/{bookingId}/checkin": {
      "parameters": [
        {
          "name": "bookingId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "post": {
        "summary": "Check-in en ligne",
        "operationId": "onlineCheckin",
        "tags": [
          "Checkin"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/flights/{bookingId}/cancel": {
      "parameters": [
        {
          "name": "bookingId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "post": {
        "summary": "Annuler vol",
        "operationId": "cancelFlight",
        "tags": [
          "Cancel"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}