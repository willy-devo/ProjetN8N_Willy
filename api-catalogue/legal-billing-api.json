{
  "openapi": "3.0.0",
  "info": {
    "title": "Legal Billing API",
    "version": "1.0.0",
    "x-api-id": "legal-billing-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Legal",
    "x-domain": "Legal",
    "description": "Facturation cabinet d'avocats. Honoraires, temps passe et notes de frais. DIFFERENCE vs billing-api : Legal Billing = honoraires avocats/notaires (temps passe, forfait), Billing = facturation services generiques.",
    "x-false-positive-warning": "Facturation generique -> billing-api-v3."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/legal-billing/matters/{matterId}": {
      "parameters": [
        {
          "name": "matterId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Facturation dossier",
        "operationId": "getMatterBilling",
        "tags": [
          "Matters"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Saisir temps",
        "operationId": "addTimeEntry",
        "tags": [
          "Matters"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/legal-billing/invoices": {
      "get": {
        "summary": "Factures",
        "operationId": "listLegalInvoices",
        "tags": [
          "Invoices"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Générer facture",
        "operationId": "generateLegalInvoice",
        "tags": [
          "Invoices"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/legal-billing/invoices/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Detail",
        "operationId": "getLegalInvoice",
        "tags": [
          "Invoices"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Envoyer",
        "operationId": "sendInvoice",
        "tags": [
          "Invoices"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}