{
  "openapi": "3.0.0",
  "info": {
    "title": "Claims Notification API",
    "version": "1.0.0",
    "x-api-id": "claims-notification-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Assurance",
    "x-domain": "Insurance",
    "description": "Notifications sinistres. Alertes clients et partenaires. DIFFERENCE vs notification-api : Claims Notification = alertes specifiques assurance sinistre, Notification = multi-canaux generique.",
    "x-false-positive-warning": "Notifications generiques -> notification-api-v2."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/claims-notifications/{claimId}": {
      "parameters": [
        {
          "name": "claimId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Notifications envoyees",
        "operationId": "getClaimNotifications",
        "tags": [
          "Notifications"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Envoyer notification",
        "operationId": "sendClaimNotification",
        "tags": [
          "Notifications"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}