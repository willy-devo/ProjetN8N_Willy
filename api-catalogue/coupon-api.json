{
  "openapi": "3.0.0",
  "info": {
    "title": "Coupon API",
    "version": "1.0.0",
    "x-api-id": "coupon-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Retail",
    "x-domain": "Retail",
    "description": "Coupons et codes promo. Generation, validation et tracking."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/coupons": {
      "get": {
        "summary": "Coupons actifs",
        "operationId": "listCoupons",
        "tags": [
          "Coupons"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Creer coupon",
        "operationId": "createCoupon",
        "tags": [
          "Coupons"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/coupons/{code}": {
      "parameters": [
        {
          "name": "code",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Detail coupon",
        "operationId": "getCouponDetails",
        "tags": [
          "Coupons"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Utiliser coupon",
        "operationId": "redeemCoupon",
        "tags": [
          "Coupons"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}