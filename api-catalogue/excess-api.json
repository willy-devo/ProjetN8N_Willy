{
  "openapi": "3.0.0",
  "info": {
    "title": "Excess API",
    "version": "1.0.0",
    "x-api-id": "excess-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Assurance",
    "x-domain": "Insurance",
    "description": "Franchises et auto-rétentions. Calcul et application lors des sinistres."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
