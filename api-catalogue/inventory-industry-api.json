{
  "openapi": "3.0.0",
  "info": {
    "title": "Inventory Industry API",
    "version": "1.0.0",
    "x-api-id": "inventory-industry-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Industrie",
    "x-domain": "Industry",
    "description": "Stocks industriels. Matieres premieres, composants et produits finis. DIFFERENCE vs inventory-api : Inventory Industry = stocks de production, Inventory = stock retail.",
    "x-false-positive-warning": "Stock retail -> inventory-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/stock": {
      "get": {
        "summary": "Articles en stock",
        "operationId": "listStockItems",
        "tags": [
          "Stock"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Ajouter",
        "operationId": "addStockItem",
        "tags": [
          "Stock"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/stock/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Niveau stock",
        "operationId": "getStockLevel",
        "tags": [
          "Stock"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Ajuster stock",
        "operationId": "adjustStock",
        "tags": [
          "Stock"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/stock/movements": {
      "get": {
        "summary": "Mouvements",
        "operationId": "listStockMovements",
        "tags": [
          "Movements"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Enregistrer",
        "operationId": "recordMovement",
        "tags": [
          "Movements"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}