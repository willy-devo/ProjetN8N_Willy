{
  "openapi": "3.0.0",
  "info": {
    "title": "Trading API",
    "version": "2.0.0",
    "x-api-id": "trading-api-v2",
    "x-api-version": "v2",
    "x-status": "active",
    "x-team": "Equipe Banque",
    "x-domain": "Banking",
    "description": "Trading actions, obligations, derives. Ordres market/limit/stop. DIFFERENCE vs investment-api : Trading = execution temps reel marches, Investment = gestion epargne retail.",
    "x-false-positive-warning": "Epargne retail -> investment-api.",
    "x-breaking-changes-from-previous": [
      "FIX protocol",
      "Ordres stop-loss"
    ]
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v2/trading/orders": {
      "get": {
        "summary": "Carnet ordres",
        "operationId": "listTradingOrders",
        "tags": [
          "Orders"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Passer ordre",
        "operationId": "placeTradingOrder",
        "tags": [
          "Orders"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v2/trading/orders/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Ordre",
        "operationId": "getTradingOrder",
        "tags": [
          "Orders"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "delete": {
        "summary": "Annuler",
        "operationId": "cancelTradingOrder",
        "tags": [
          "Orders"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v2/trading/market-data": {
      "get": {
        "summary": "Cotations temps reel",
        "operationId": "getMarketData",
        "tags": [
          "Market"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}