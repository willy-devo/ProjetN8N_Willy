{
  "openapi": "3.0.0",
  "info": {
    "title": "Inventory Telecom API",
    "version": "1.0.0",
    "x-api-id": "inventory-telecom-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Telecom",
    "x-domain": "Telecom",
    "description": "Inventaire SIM, equipements et materiel. Stock et affectation. DIFFERENCE vs inventory-api : Inventory Telecom = SIM/equipements reseau, Inventory = produits retail.",
    "x-false-positive-warning": "Produits retail -> inventory-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/inventory-telecom/sim": {
      "get": {
        "summary": "Stock SIM",
        "operationId": "listSIMInventory",
        "tags": [
          "SIM"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Ajouter SIM",
        "operationId": "addSIM",
        "tags": [
          "SIM"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/inventory-telecom/equipment": {
      "get": {
        "summary": "Equipements",
        "operationId": "listEquipment",
        "tags": [
          "Equipment"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Affecter",
        "operationId": "assignEquipment",
        "tags": [
          "Equipment"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}