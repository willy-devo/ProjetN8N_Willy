{
  "openapi": "3.0.0",
  "info": {
    "title": "Anonymization API",
    "version": "1.0.0",
    "x-api-id": "anonymization-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Data",
    "x-domain": "Data",
    "description": "Anonymisation RGPD. k-anonymite et masquage."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/anonymize": {
      "post": {
        "summary": "Pseudonymiser",
        "operationId": "pseudonymizeDataset",
        "tags": [
          "Anonymize"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/anonymize/rules": {
      "get": {
        "summary": "Regles",
        "operationId": "listAnonymizationRules",
        "tags": [
          "Rules"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Creer",
        "operationId": "createAnonymizationRule",
        "tags": [
          "Rules"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/anonymize/verify/{datasetId}": {
      "parameters": [
        {
          "name": "datasetId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "post": {
        "summary": "Verifier",
        "operationId": "verifyAnonymization",
        "tags": [
          "Verify"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}