{
  "openapi": "3.0.0",
  "info": {
    "title": "Synthetic Data API",
    "version": "1.0.0",
    "x-api-id": "synthetic-data-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Data",
    "x-domain": "Data",
    "description": "Generation donnees synthetiques. Modeles, seeds et validation."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/synthetic/generate": {
      "post": {
        "summary": "Generer donnees synthetiques",
        "operationId": "generateSyntheticData",
        "tags": [
          "Generate"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/synthetic/models": {
      "get": {
        "summary": "Modeles",
        "operationId": "listSynthModels",
        "tags": [
          "Models"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Entrainer modele",
        "operationId": "trainSynthModel",
        "tags": [
          "Models"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/synthetic/validate": {
      "post": {
        "summary": "Valider qualite",
        "operationId": "validateSyntheticData",
        "tags": [
          "Validate"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}