{
  "openapi": "3.0.0",
  "info": {
    "title": "Production Planning API",
    "version": "1.0.0",
    "x-api-id": "production-planning-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Industrie",
    "x-domain": "Industry",
    "description": "Planification production. PDP, MPS et gestion capacite."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/planning/pdp": {
      "get": {
        "summary": "Plan directeur",
        "operationId": "getMasterProductionSchedule",
        "tags": [
          "PDP"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Mettre a jour PDP",
        "operationId": "updatePDP",
        "tags": [
          "PDP"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/planning/capacity/{workcenter}": {
      "parameters": [
        {
          "name": "workcenter",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Plan capacite",
        "operationId": "getCapacityPlan",
        "tags": [
          "Capacity"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Ajuster",
        "operationId": "adjustCapacity",
        "tags": [
          "Capacity"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}