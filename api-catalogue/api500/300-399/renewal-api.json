{
  "openapi": "3.0.0",
  "info": {
    "title": "Renewal API",
    "version": "1.0.0",
    "x-api-id": "renewal-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Assurance",
    "x-domain": "Insurance",
    "description": "Renouvellements contrats. Notifications, négociation et confirmation."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/renewals": {
      "get": {
        "summary": "Renouvellements à venir",
        "operationId": "listUpcomingRenewals",
        "tags": [
          "Renewals"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Traiter renouvellement",
        "operationId": "processRenewal",
        "tags": [
          "Renewals"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/renewals/{contractId}": {
      "parameters": [
        {
          "name": "contractId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Statut renouvellement",
        "operationId": "getRenewalStatus",
        "tags": [
          "Renewals"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Négocier conditions",
        "operationId": "negotiateRenewal",
        "tags": [
          "Renewals"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}