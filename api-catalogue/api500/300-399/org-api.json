{
  "openapi": "3.0.0",
  "info": {
    "title": "Organization API",
    "version": "1.0.0",
    "x-api-id": "org-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe RH",
    "x-domain": "Human Resources",
    "description": "Structure organisationnelle. Entités légales, filiales et hiérarchie de l'entreprise. DIFFÉRENCE vs hr-api : Org API gère la structure juridique et les entités légales, HR API gère les employés et leurs dossiers.",
    "x-false-positive-warning": "Dossiers employés → hr-api. Comptes clients → account-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/organizations": {
      "get": {
        "summary": "Lister les entités organisationnelles",
        "operationId": "listOrgs",
        "tags": [
          "Organizations"
        ],
        "responses": {
          "200": {
            "description": "Entités"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Créer une entité légale",
        "operationId": "createOrg",
        "tags": [
          "Organizations"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "type"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "headquarters",
                      "subsidiary",
                      "branch"
                    ]
                  },
                  "country": {
                    "type": "string"
                  },
                  "parent_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Créée"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/organizations/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Détails d'une entité",
        "operationId": "getOrg",
        "tags": [
          "Organizations"
        ],
        "responses": {
          "200": {
            "description": "Entité"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/organizations/{id}/headcount": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Effectif d'une entité",
        "operationId": "getHeadcount",
        "tags": [
          "Organizations"
        ],
        "responses": {
          "200": {
            "description": "Effectif par département"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Non autorisé",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Non trouvé",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}