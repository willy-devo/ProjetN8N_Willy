{
  "openapi": "3.0.0",
  "info": {
    "title": "Litigation API",
    "version": "1.0.0",
    "x-api-id": "litigation-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Legal",
    "x-domain": "Legal",
