{
  "openapi": "3.0.0",
  "info": {
    "title": "Investment API",
    "version": "1.0.0",
    "x-api-id": "investment-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Banque",
    "x-domain": "Banking",
    "description": "Placements financiers OPCVM, ETF, obligations. Catalogue produits et passation ordres. DIFFERENCE vs portfolio-api : Investment = passation ordres et catalogue, Portfolio = analyse portefeuille existant.",
    "x-false-positive-warning": "Analyse portefeuille -> portfolio-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/investments/{clientId}": {
      "parameters": [
        {
          "name": "clientId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Portefeuille client",
        "operationId": "getPortfolio",
        "tags": [
          "Investments"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/investments/products": {
      "get": {
        "summary": "Catalogue produits",
        "operationId": "listInvestmentProducts",
        "tags": [
          "Products"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/investments/orders": {
      "get": {
        "summary": "Ordres en cours",
        "operationId": "listOrders",
        "tags": [
          "Orders"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Passer ordre",
        "operationId": "placeOrder",
        "tags": [
          "Orders"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}