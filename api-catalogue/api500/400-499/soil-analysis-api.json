{
  "openapi": "3.0.0",
  "info": {
    "title": "Soil Analysis API",
    "version": "1.0.0",
    "x-api-id": "soil-analysis-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Agriculture",
    "x-domain": "Agriculture",
    "description": "Analyses de sol. pH, nutriments et recommandations fertilisation. DIFFERENCE vs field-api : Soil Analysis = analyses laboratoire ponctuelles, Field = gestion parcelle complète.",
    "x-false-positive-warning": "Gestion parcelle -> field-api-v2."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/soil/analyses": {
      "get": {
        "summary": "Analyses en cours",
        "operationId": "listSoilAnalyses",
        "tags": [
          "Analyses"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Commander analyse",
        "operationId": "createSoilAnalysis",
        "tags": [
          "Analyses"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/soil/analyses/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Recommandations fertilisation",
        "operationId": "getFertilizationAdvice",
        "tags": [
          "Analyses"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}