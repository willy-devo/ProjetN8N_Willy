{
  "openapi": "3.0.0",
  "info": {
    "title": "Student API",
    "version": "2.0.0",
    "x-api-id": "student-api-v2",
    "x-api-version": "v2",
    "x-status": "active",
    "x-team": "Equipe Education",
    "x-domain": "Education",
    "description": "Gestion étudiants. Profils, inscriptions et parcours. DIFFERENCE vs employee-api : Student = apprenant (inscriptions, notes, parcours), Employee = salarié (RH, paie, contrat).",
    "x-false-positive-warning": "Salarié -> employee-api.",
    "x-breaking-changes-from-previous": [
      "Progression détaillée",
      "Certificats"
    ]
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v2/students": {
      "get": {
        "summary": "Lister étudiants",
        "operationId": "listStudentsV2",
        "tags": [
          "Students"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Inscrire étudiant",
        "operationId": "createStudentV2",
        "tags": [
          "Students"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v2/students/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Profil étudiant",
        "operationId": "getStudentV2",
        "tags": [
          "Students"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Modifier",
        "operationId": "updateStudentV2",
        "tags": [
          "Students"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v2/students/{id}/progress": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Cours complétés",
        "operationId": "getCompletedCourses",
        "tags": [
          "Progress"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v2/students/{id}/certificates": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Certificats",
        "operationId": "getCertificates",
        "tags": [
          "Certs"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}