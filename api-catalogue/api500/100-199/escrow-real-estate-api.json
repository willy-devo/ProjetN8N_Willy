{
  "openapi": "3.0.0",
  "info": {
    "title": "Escrow Real Estate API",
    "version": "1.0.0",
    "x-api-id": "escrow-real-estate-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Immobilier",
    "x-domain": "RealEstate",
    "description": "Séquestre immobilier. Consignation des fonds, conditions et libération. DIFFERENCE vs escrow-api (e-commerce) : Escrow Real Estate = séquestre transactions immobilières, Escrow = séquestre e-commerce.",
    "x-false-positive-warning": "Sequestre e-commerce -> escrow-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/escrow/real-estate": {
      "get": {
        "summary": "Séquestres en cours",
        "operationId": "listRealEstateEscrows",
        "tags": [
          "Escrow"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Créer séquestre",
        "operationId": "createRealEstateEscrow",
        "tags": [
          "Escrow"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/escrow/real-estate/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Detail séquestre",
        "operationId": "getEscrow",
        "tags": [
          "Escrow"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Annuler",
        "operationId": "cancelEscrow",
        "tags": [
          "Escrow"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}