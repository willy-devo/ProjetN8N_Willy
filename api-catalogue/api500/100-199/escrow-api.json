{
  "openapi": "3.0.0",
  "info": {
    "title": "Escrow API",
    "version": "1.0.0",
    "x-api-id": "escrow-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Finance",
    "x-domain": "Finance",
    "description": "Paiements sous séquestre pour marketplaces. Fonds retenus jusqu'à confirmation de livraison, puis libérés."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/escrow": {
      "post": {
        "summary": "Créer un compte séquestre",
        "operationId": "createEscrow",
        "tags": [
          "Escrow"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "order_id",
                  "amount",
                  "seller_id"
                ],
                "properties": {
                  "order_id": {
                    "type": "string"
                  },
                  "amount": {
                    "type": "number"
                  },
                  "seller_id": {
                    "type": "string"
                  },
                  "release_condition": {
                    "type": "string",
                    "enum": [
                      "delivery_confirmed",
                      "buyer_accepts",
                      "auto_7d"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Séquestre créé"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/escrow/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Statut du séquestre",
        "operationId": "getEscrow",
        "tags": [
          "Escrow"
        ],
        "responses": {
          "200": {
            "description": "Séquestre"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/escrow/{id}/release": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "post": {
        "summary": "Libérer les fonds vers le vendeur",
        "operationId": "releaseEscrow",
        "tags": [
          "Escrow"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "reason": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Fonds libérés"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/escrow/{id}/refund": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "post": {
        "summary": "Rembourser l'acheteur (litige)",
        "operationId": "refundEscrow",
        "tags": [
          "Escrow"
        ],
        "responses": {
          "200": {
            "description": "Remboursé"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Non autorisé",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Non trouvé",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}