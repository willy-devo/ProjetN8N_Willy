{
  "openapi": "3.0.0",
  "info": {
    "title": "Exam API",
    "version": "1.0.0",
    "x-api-id": "exam-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Education",
    "x-domain": "Education",
    "description": "Examens officiels. Planification, surveillance et résultats."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
