{
  "openapi": "3.0.0",
  "info": {
    "title": "Destination API",
    "version": "1.0.0",
    "x-api-id": "destination-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Tourisme",
    "x-domain": "Tourism",
