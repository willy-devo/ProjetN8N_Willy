{
  "openapi": "3.0.0",
  "info": {
    "title": "E-Signature API",
    "version": "1.0.0",
    "x-api-id": "esignature-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Legal",
    "x-domain": "Legal",
    "description": "Signature electronique qualifiee eIDAS. Workflows multi-signataires et archivage probatoire.",
    "x-false-positive-warning": "Contrat complet -> contract-api-v3."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
