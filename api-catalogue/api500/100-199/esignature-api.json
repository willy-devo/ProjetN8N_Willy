        "summary": "Documents a signer",
        "operationId": "listESignDocuments",
        "tags": [
          "Documents"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Preparer signature",
        "operationId": "prepareESignDocument",
