{
  "openapi": "3.0.0",
  "info": {
    "title": "Car Rental API",
    "version": "1.0.0",
    "x-api-id": "car-rental-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Tourisme",
    "x-domain": "Tourism",
    "description": "Location de voitures. Disponibilité, tarifs et contrats."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
