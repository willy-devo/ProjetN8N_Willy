{
  "openapi": "3.0.0",
  "info": {
    "title": "Court Filing API",
    "version": "1.0.0",
    "x-api-id": "court-filing-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Legal",
    "x-domain": "Legal",
    "description": "Dépôts et actes au tribunal. RPVA, e-barreau et suivi."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/filings": {
      "get": {
        "summary": "Dépôts en cours",
        "operationId": "listCourtFilings",
        "tags": [
          "Filings"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Créer dépôt",
        "operationId": "createFiling",
        "tags": [
          "Filings"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/filings/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Statut",
        "operationId": "getFilingStatus",
        "tags": [
          "Filings"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Soumettre",
        "operationId": "submitFiling",
        "tags": [
          "Filings"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/filings/{id}/documents": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Documents",
        "operationId": "getFilingDocs",
        "tags": [
          "Docs"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Ajouter",
        "operationId": "addFilingDoc",
        "tags": [
          "Docs"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}