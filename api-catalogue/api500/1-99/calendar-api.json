{
  "openapi": "3.0.0",
  "info": {
    "title": "Calendar API",
    "version": "1.0.0",
    "x-api-id": "calendar-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Platform",
    "x-domain": "Operations",
    "description": "Gestion des calendriers et disponibilités internes. Plannings des conseillers, techniciens et ressources. DIFFÉRENCE vs appointment-api : Calendar = gestion des disponibilités et plannings côté équipes, Appointment = réservation côté client.",
    "x-false-positive-warning": "Réservation côté client → appointment-api. Livraison colis → delivery-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v1/calendars/{resourceId}": {
      "parameters": [
        {
          "name": "resourceId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          },
          "description": "ID d'un employé ou d'une salle"
        }
      ],
      "get": {
        "summary": "Calendrier d'une ressource",
        "operationId": "getCalendar",
        "tags": [
          "Calendar"
        ],
        "responses": {
          "200": {
            "description": "Calendrier"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/calendars/{resourceId}/availability": {
      "parameters": [
        {
          "name": "resourceId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Disponibilités d'une ressource sur une période",
        "operationId": "getAvailability",
        "tags": [
          "Calendar"
        ],
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "to",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Disponibilités"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/calendars/{resourceId}/events": {
      "parameters": [
        {
          "name": "resourceId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "post": {
        "summary": "Ajouter un événement au calendrier",
        "operationId": "createCalendarEvent",
        "tags": [
          "Calendar"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "title",
                  "start",
                  "end"
                ],
                "properties": {
                  "title": {
                    "type": "string"
                  },
                  "start": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "end": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "all_day": {
                    "type": "boolean",
                    "default": false
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "appointment",
                      "meeting",
                      "leave",
                      "blocked"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Événement créé"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Clé API invalide",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Ressource non trouvée",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit d'état",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Clé API Kong Gateway — contacter votre équipe platform"
      }
    }
  }
}