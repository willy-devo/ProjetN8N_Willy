{
  "openapi": "3.0.0",
  "info": {
    "title": "Co-living API",
    "version": "1.0.0",
    "x-api-id": "co-living-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Immobilier",
    "x-domain": "RealEstate",
    "description": "Gestion espaces co-living. Chambres, espaces partagés et services. DIFFERENCE vs hotel-api : Co-living = résidence longue durée avec espaces partagés, Hotel = hébergement touristique court séjour.",
    "x-false-positive-warning": "Hébergement touristique -> hotel-api-v3."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/coliving/spaces": {
      "get": {
        "summary": "Espaces co-living",
        "operationId": "listColivingSpaces",
        "tags": [
          "Spaces"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Créer espace",
        "operationId": "createColivingSpace",
        "tags": [
          "Spaces"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/coliving/spaces/{id}/rooms": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Chambres disponibles",
        "operationId": "getRooms",
        "tags": [
          "Rooms"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Réserver chambre",
        "operationId": "bookRoom",
        "tags": [
          "Rooms"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/coliving/spaces/{id}/amenities": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Services",
        "operationId": "getAmenities",
        "tags": [
          "Amenities"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}