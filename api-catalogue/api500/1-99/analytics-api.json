{
  "openapi": "3.0.0",
  "info": {
    "title": "Analytics API",
    "version": "1.0.0",
    "x-api-id": "analytics-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Data",
    "x-domain": "Analytics & BI",
    "description": "Agrégation et reporting des données métier. KPIs ventes, trafic et comportement utilisateur. DIFFÉRENCE vs reporting-api : Analytics = métriques temps réel et historiques, Reporting = génération de documents PDF/Excel planifiés. DIFFÉRENCE vs metrics-api : Analytics = orienté business (ventes, conversion), Metrics = orienté ingénierie (latence, erreurs).",
    "x-false-positive-warning": "Documents PDF/Excel → reporting-api. Métriques techniques → metrics-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v1/analytics/sales": {
      "get": {
        "summary": "Métriques de ventes",
        "operationId": "getSalesAnalytics",
        "tags": [
          "Analytics"
        ],
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "to",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "granularity",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "hour",
                "day",
                "week",
                "month"
              ],
              "default": "day"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Métriques ventes"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/analytics/traffic": {
      "get": {
        "summary": "Métriques de trafic",
        "operationId": "getTrafficAnalytics",
        "tags": [
          "Analytics"
        ],
        "responses": {
          "200": {
            "description": "Trafic"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/analytics/conversion": {
      "get": {
        "summary": "Taux de conversion",
        "operationId": "getConversionAnalytics",
        "tags": [
          "Analytics"
        ],
        "responses": {
          "200": {
            "description": "Conversion"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/analytics/reports": {
      "post": {
        "summary": "Générer un rapport analytique personnalisé",
        "operationId": "generateReport",
        "tags": [
          "Analytics"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "metrics": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "dimensions": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "filters": {
                    "type": "object"
                  },
                  "date_range": {
                    "type": "object",
                    "properties": {
                      "from": {
                        "type": "string",
                        "format": "date"
                      },
                      "to": {
                        "type": "string",
                        "format": "date"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Rapport"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/analytics/dashboard": {
      "get": {
        "summary": "Tableau de bord temps réel",
        "operationId": "getDashboard",
        "tags": [
          "Analytics"
        ],
        "responses": {
          "200": {
            "description": "Dashboard"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "NOT_FOUND"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Clé API manquante ou invalide",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Ressource non trouvée",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit — ressource déjà existante ou état incompatible",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Clé API Kong Gateway"
      }
    }
  }
}