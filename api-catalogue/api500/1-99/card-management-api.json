{
  "openapi": "3.0.0",
  "info": {
    "title": "Card Management API",
    "version": "1.0.0",
    "x-api-id": "card-management-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Banque",
    "x-domain": "Banking",
    "description": "Cartes bancaires debit/credit. Activation, plafonds, opposition et cartes virtuelles."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
