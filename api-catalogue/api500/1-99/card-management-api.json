      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "post": {
        "summary": "Opposition",
        "operationId": "blockCard",
        "tags": [
          "Block"
