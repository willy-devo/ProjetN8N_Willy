{
  "openapi": "3.0.0",
  "info": {
    "title": "OEE API",
    "version": "1.0.0",
    "x-api-id": "oee-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Industrie",
    "x-domain": "Industry",
    "description": "Calcul TRS/OEE. Disponibilite, performance et qualite machines."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/oee/{machineId}": {
      "parameters": [
        {
          "name": "machineId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Decomposition TRS",
        "operationId": "getOEEBreakdown",
        "tags": [
          "OEE"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/oee/{machineId}/history": {
      "parameters": [
        {
          "name": "machineId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Historique TRS",
        "operationId": "getOEEHistory",
        "tags": [
          "History"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/oee/site": {
      "get": {
        "summary": "TRS par equipe",
        "operationId": "getOEEByShift",
        "tags": [
          "Site"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}