{
  "openapi": "3.0.0",
  "info": {
    "title": "Inference API",
    "version": "1.0.0",
    "x-api-id": "inference-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Data",
    "x-domain": "Data",
    "description": "Serving inference ML. DIFFERENCE vs model-registry-api : Inference = execution predictions, Model Registry = gestion versions.",
    "x-false-positive-warning": "Gestion modeles -> model-registry-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/inference/{modelId}": {
      "parameters": [
        {
          "name": "modelId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "post": {
        "summary": "Prediction",
        "operationId": "predict",
        "tags": [
          "Inference"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "get": {
        "summary": "Info modele",
        "operationId": "getModelInfo",
        "tags": [
          "Inference"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/inference/batch": {
      "post": {
        "summary": "Batch",
        "operationId": "batchPredict",
        "tags": [
          "Batch"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "get": {
        "summary": "Statut",
        "operationId": "getBatchJobStatus",
        "tags": [
          "Batch"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}