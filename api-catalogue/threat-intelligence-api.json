{
  "openapi": "3.0.0",
  "info": {
    "title": "Threat Intelligence API",
    "version": "1.0.0",
    "x-api-id": "threat-intelligence-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Cybersécurité",
    "x-domain": "Cybersecurity",
    "description": "Renseignement sur les menaces. IoC, acteurs malveillants et TTPs."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/threats": {
      "get": {
        "summary": "Menaces actives",
        "operationId": "listActiveThreats",
        "tags": [
          "Threats"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Ajouter menace",
        "operationId": "addThreat",
        "tags": [
          "Threats"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/threats/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Detail menace",
        "operationId": "getThreat",
        "tags": [
          "Threats"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/threats/ioc/check": {
      "post": {
        "summary": "Ingérer IoC",
        "operationId": "ingestIoC",
        "tags": [
          "IoC"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/threats/feeds": {
      "get": {
        "summary": "Flux renseignement",
        "operationId": "listThreatFeeds",
        "tags": [
          "Feeds"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "S'abonner",
        "operationId": "subscribeFeed",
        "tags": [
          "Feeds"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/threats/actors": {
      "get": {
        "summary": "Acteurs malveillants",
        "operationId": "listThreatActors",
        "tags": [
          "Actors"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}