        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v2/stations/{id}/session": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
