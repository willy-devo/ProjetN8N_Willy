{
  "openapi": "3.0.0",
  "info": {
    "title": "EV Charging API",
    "version": "2.0.0",
    "x-api-id": "ev-charging-api-v2",
    "x-api-version": "v2",
    "x-status": "active",
    "x-team": "Equipe IoT",
    "x-domain": "IoT",
