{
  "openapi": "3.0.0",
  "info": {
    "title": "Fertilizer API",
    "version": "1.0.0",
    "x-api-id": "fertilizer-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Agriculture",
    "x-domain": "Agriculture",
    "description": "Gestion fertilisants et intrants. Stocks, applications et bilan azoté."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/fertilizers": {
      "get": {
        "summary": "Fertilisants disponibles",
        "operationId": "listFertilizers",
        "tags": [
          "Fertilizers"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Ajouter produit",
        "operationId": "addFertilizer",
        "tags": [
          "Fertilizers"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/fertilizers/{fieldId}/application": {
      "parameters": [
        {
          "name": "fieldId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Applications",
        "operationId": "getFertilizerApplications",
        "tags": [
          "Application"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Enregistrer application",
        "operationId": "recordApplication",
        "tags": [
          "Application"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/fertilizers/{fieldId}/balance": {
      "parameters": [
        {
          "name": "fieldId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Bilan azoté",
        "operationId": "getNitrogenBalance",
        "tags": [
          "Balance"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}