{
  "openapi": "3.0.0",
  "info": {
    "title": "Energy Consumption API",
    "version": "1.0.0",
    "x-api-id": "energy-consumption-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe IoT",
    "x-domain": "IoT",
    "description": "Consommation énergétique bâtiments et installations. Courbes de charge et optimisation."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
