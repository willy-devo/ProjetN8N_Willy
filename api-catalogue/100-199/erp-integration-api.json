{
  "openapi": "3.0.0",
  "info": {
    "title": "ERP Integration API",
    "version": "1.0.0",
    "x-api-id": "erp-integration-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Industrie",
    "x-domain": "Industry",
    "description": "Integration ERP SAP/Oracle. Synchronisation donnees et transactions."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/erp/sync": {
      "post": {
        "summary": "Synchroniser donnees referentielles",
        "operationId": "syncMasterData",
        "tags": [
          "Sync"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "get": {
        "summary": "Statut synchronisation",
        "operationId": "getSyncStatus",
        "tags": [
          "Sync"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/erp/purchase-orders": {
      "get": {
        "summary": "Commandes achat ERP",
        "operationId": "getERPPurchaseOrders",
        "tags": [
          "PO"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Creer commande achat",
        "operationId": "createERPPO",
        "tags": [
          "PO"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/erp/invoices": {
      "get": {
        "summary": "Factures ERP",
        "operationId": "getERPInvoices",
        "tags": [
          "Invoices"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Comptabiliser facture",
        "operationId": "postERPInvoice",
        "tags": [
          "Invoices"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}