{
  "openapi": "3.0.0",
  "info": {
    "title": "Fraud Detection API",
    "version": "1.0.0",
    "x-api-id": "fraud-detection-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Banque",
    "x-domain": "Banking",
    "description": "Detection fraude temps reel sur transactions. DIFFERENCE vs fraud-claims-api assurance : Fraud Detection = transactions bancaires, Fraud Claims = sinistres assurance.",
    "x-false-positive-warning": "Fraude assurance -> fraud-claims-api. Blanchiment -> aml-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/fraud/score": {
      "post": {
        "summary": "Scorer transaction",
        "operationId": "scoreFraud",
        "tags": [
          "Scoring"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/fraud/rules": {
      "get": {
        "summary": "Regles actives",
        "operationId": "getFraudRules",
        "tags": [
          "Rules"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Ajouter regle",
        "operationId": "addRule",
        "tags": [
          "Rules"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/fraud/alerts": {
      "get": {
        "summary": "Alertes fraude",
        "operationId": "getFraudAlerts",
        "tags": [
          "Alerts"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Resoudre",
        "operationId": "resolveAlert",
        "tags": [
          "Alerts"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}