        "operationId": "getDataQuota",
        "tags": [
          "Usage"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/data-usage/{lineId}/history": {
      "parameters": [
        {
          "name": "lineId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Historique",
        "operationId": "getDataHistory",
        "tags": [
          "History"
