{
  "openapi": "3.0.0",
  "info": {
    "title": "Water Meter API",
    "version": "1.0.0",
    "x-api-id": "water-meter-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe IoT",
    "x-domain": "IoT",
    "description": "Compteurs eau intelligents. Consommation, fuites et facturation. DIFFERENCE vs smart-meter-api : Water Meter = eau uniquement avec detection fuites, Smart Meter = multi-fluides generique.",
    "x-false-positive-warning": "Multi-fluides -> smart-meter-api-v2."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/water-meters": {
      "get": {
        "summary": "Lister",
        "operationId": "listWaterMeters",
        "tags": [
          "Meters"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Enregistrer",
        "operationId": "registerWaterMeter",
        "tags": [
          "Meters"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/water-meters/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Releve eau",
        "operationId": "getWaterReading",
        "tags": [
          "Meters"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/water-meters/{id}/leak-detection": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Detecter fuites",
        "operationId": "detectLeaks",
        "tags": [
          "Leaks"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}