{
  "openapi": "3.0.0",
  "info": {
    "title": "Search API",
    "version": "2.0.0",
    "x-api-id": "search-api-v2",
    "x-api-version": "v2",
    "x-status": "active",
    "x-team": "Equipe Platform",
    "x-domain": "E-Commerce",
    "description": "Version 2 Search. Recherche sémantique vectorielle, personnalisation par profil et A/B sur le ranking. DIFFÉRENCE vs v1 : v2 ajoute embedding vectoriel, personnalisation et expérimentation sur les résultats.",
    "x-breaking-changes-from-previous": [
      "Recherche sémantique vectorielle (embedding)",
      "Personnalisation basée sur l'historique",
      "A/B testing sur le ranking",
      "Résultats enrichis avec facettes dynamiques"
    ]
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v2/search": {
      "get": {
        "summary": "Recherche hybride (lexical + sémantique)",
        "operationId": "searchV2",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "user_id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Pour personnalisation"
          },
          {
            "name": "mode",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "lexical",
                "semantic",
                "hybrid"
              ],
              "default": "hybrid"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Résultats personnalisés"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v2/search/similar": {
      "post": {
        "summary": "Recherche par similarité (more-like-this)",
        "operationId": "searchSimilar",
        "tags": [
          "Search"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "reference_id"
                ],
                "properties": {
                  "reference_id": {
                    "type": "string"
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "product",
                      "article"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Produits similaires"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v2/search/reindex": {
      "post": {
        "summary": "Forcer une réindexation complète ou partielle",
        "operationId": "reindexSearch",
        "tags": [
          "Admin"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "entity": {
                    "type": "string",
                    "enum": [
                      "products",
                      "articles",
                      "all"
                    ],
                    "default": "all"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Réindexation lancée"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Non autorisé",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Non trouvé",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}