        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/segmentation/rules": {
      "get": {
        "summary": "Regles",
        "operationId": "listSegmentationRules",
        "tags": [
