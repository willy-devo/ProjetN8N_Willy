{
  "openapi": "3.0.0",
  "info": {
    "title": "Mini Bar API",
    "version": "1.0.0",
    "x-api-id": "mini-bar-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Tourisme",
    "x-domain": "Tourism",
    "description": "Gestion mini-bars hôteliers. Consommations, réapprovisionnement et facturation.",
    "x-false-positive-warning": "Facturation hôtel complète -> room-booking-api-v3."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
