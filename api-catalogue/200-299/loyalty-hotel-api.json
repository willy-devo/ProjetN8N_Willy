        "summary": "Compte fidelite",
        "operationId": "getHotelLoyaltyAccount",
        "tags": [
          "Loyalty"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Gagner points",
        "operationId": "earnHotelPoints",
