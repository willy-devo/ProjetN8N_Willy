{
  "openapi": "3.0.0",
  "info": {
    "title": "Purchase Order API",
    "version": "1.0.0",
    "x-api-id": "purchase-order-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Supply",
    "x-domain": "Supply Chain",
    "description": "Bons de commande fournisseurs. Gestion des achats, réceptions et rapprochements. DIFFÉRENCE vs order-api : Purchase Order = commandes passées AUX fournisseurs (B2B achats), Order API = commandes passées PAR les clients (B2C ventes).",
    "x-false-positive-warning": "Commandes clients → order-api. Gestion des fournisseurs → supplier-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v1/purchase-orders": {
      "post": {
        "summary": "Créer un bon de commande fournisseur",
        "operationId": "createPurchaseOrder",
        "tags": [
          "PurchaseOrders"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/POCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Bon de commande créé"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "get": {
        "summary": "Lister les bons de commande",
        "operationId": "listPurchaseOrders",
        "tags": [
          "PurchaseOrders"
        ],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "draft",
                "sent",
                "confirmed",
                "received",
                "cancelled"
              ]
            }
          },
          {
            "name": "supplier_id",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Bons de commande"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/purchase-orders/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Détails d'un bon de commande",
        "operationId": "getPurchaseOrder",
        "tags": [
          "PurchaseOrders"
        ],
        "responses": {
          "200": {
            "description": "Bon de commande"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/purchase-orders/{id}/receive": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "post": {
        "summary": "Enregistrer une réception de marchandises",
        "operationId": "receivePurchaseOrder",
        "tags": [
          "PurchaseOrders"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "received_items": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "product_id": {
                          "type": "string"
                        },
                        "quantity_received": {
                          "type": "integer"
                        }
                      }
                    }
                  },
                  "notes": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Réception enregistrée — stock mis à jour"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "POCreate": {
        "type": "object",
        "required": [
          "supplier_id",
          "items"
        ],
        "properties": {
          "supplier_id": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "product_id": {
                  "type": "string"
                },
                "quantity": {
                  "type": "integer"
                },
                "unit_price": {
                  "type": "number"
                }
              }
            }
          },
          "expected_delivery": {
            "type": "string",
            "format": "date"
          },
          "notes": {
            "type": "string"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Clé API invalide",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Ressource non trouvée",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit d'état",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Clé API Kong Gateway — contacter votre équipe platform"
      }
    }
  }
}