{
  "openapi": "3.0.0",
  "info": {
    "title": "Backup Security API",
    "version": "1.0.0",
    "x-api-id": "backup-security-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Cybersécurité",
    "x-domain": "Cybersecurity",
    "description": "Sauvegardes securisees. Chiffrement, immuabilite et tests de restauration."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/backup/policies": {
      "get": {
        "summary": "Politiques backup",
        "operationId": "listBackupPolicies",
        "tags": [
          "Policies"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Creer",
        "operationId": "createBackupPolicy",
        "tags": [
          "Policies"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/backup/jobs": {
      "get": {
        "summary": "Jobs backup",
        "operationId": "listBackupJobs",
        "tags": [
          "Jobs"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Lancer backup",
        "operationId": "triggerBackup",
        "tags": [
          "Jobs"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/backup/restore": {
      "post": {
        "summary": "Test restauration",
        "operationId": "testRestore",
        "tags": [
          "Restore"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}