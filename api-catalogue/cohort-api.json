{
  "openapi": "3.0.0",
  "info": {
    "title": "Cohort API",
    "version": "1.0.0",
    "x-api-id": "cohort-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Data",
    "x-domain": "Analytics & BI",
    "description": "Analyse de cohortes clients. Rétention, LTV et comportement par groupe d'acquisition."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v1/cohorts": {
      "post": {
        "summary": "Créer une analyse de cohorte",
        "operationId": "createCohort",
        "tags": [
          "Cohorts"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "acquisition_period",
                  "metric"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "acquisition_period": {
                    "type": "string",
                    "example": "2026-01"
                  },
                  "metric": {
                    "type": "string",
                    "enum": [
                      "retention",
                      "ltv",
                      "orders_count",
                      "revenue"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Créée"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "get": {
        "summary": "Lister les cohortes",
        "operationId": "listCohorts",
        "tags": [
          "Cohorts"
        ],
        "responses": {
          "200": {
            "description": "Cohortes"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/cohorts/{id}/retention": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Matrice de rétention",
        "operationId": "getCohortRetention",
        "tags": [
          "Cohorts"
        ],
        "responses": {
          "200": {
            "description": "Matrice de rétention"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/cohorts/{id}/ltv": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "LTV de la cohorte par période",
        "operationId": "getCohortLTV",
        "tags": [
          "Cohorts"
        ],
        "responses": {
          "200": {
            "description": "LTV"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Clé API invalide",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Ressource non trouvée",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit d'état",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Clé API Kong Gateway — contacter votre équipe platform"
      }
    }
  }
}