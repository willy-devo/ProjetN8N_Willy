{
  "openapi": "3.0.0",
  "info": {
    "title": "Supplier API",
    "version": "1.0.0",
    "x-api-id": "supplier-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Supply",
    "x-domain": "Supply Chain",
    "description": "Fournisseurs et partenaires B2B. Catalogue, contrats et évaluations."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v1/suppliers": {
      "post": {
        "summary": "Créer un fournisseur",
        "operationId": "createSupplier",
        "tags": [
          "Suppliers"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "contact_email"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "contact_email": {
                    "type": "string",
                    "format": "email"
                  },
                  "country": {
                    "type": "string"
                  },
                  "product_categories": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Créé"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "get": {
        "summary": "Lister les fournisseurs",
        "operationId": "listSuppliers",
        "tags": [
          "Suppliers"
        ],
        "responses": {
          "200": {
            "description": "Fournisseurs"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/suppliers/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Fiche fournisseur",
        "operationId": "getSupplier",
        "tags": [
          "Suppliers"
        ],
        "responses": {
          "200": {
            "description": "Fournisseur"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Mettre à jour",
        "operationId": "updateSupplier",
        "tags": [
          "Suppliers"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Mis à jour"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/suppliers/{id}/products": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Catalogue du fournisseur",
        "operationId": "getSupplierProducts",
        "tags": [
          "Suppliers"
        ],
        "responses": {
          "200": {
            "description": "Produits"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/suppliers/{id}/evaluate": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "post": {
        "summary": "Évaluer un fournisseur",
        "operationId": "evaluateSupplier",
        "tags": [
          "Suppliers"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "score"
                ],
                "properties": {
                  "score": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 5
                  },
                  "criteria": {
                    "type": "object",
                    "properties": {
                      "quality": {
                        "type": "integer"
                      },
                      "delivery": {
                        "type": "integer"
                      },
                      "price": {
                        "type": "integer"
                      }
                    }
                  },
                  "comment": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Évaluation enregistrée"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "NOT_FOUND"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Clé API manquante ou invalide",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Ressource non trouvée",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit — ressource déjà existante ou état incompatible",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Clé API Kong Gateway"
      }
    }
  }
}