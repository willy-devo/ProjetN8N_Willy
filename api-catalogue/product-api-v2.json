{
  "openapi": "3.0.0",
  "info": {
    "title": "Product API",
    "version": "2.0.0",
    "x-api-id": "product-api-v2",
    "x-api-version": "v2",
    "x-status": "deprecated",
    "x-team": "Equipe Catalog",
    "x-domain": "E-Commerce",
    "description": "Version 2 — DEPRECATED jan 2024. Introduit IDs préfixés PROD-, images multiples, variantes produit (taille/couleur) et structure pricing. Migrer vers v3.",
    "x-breaking-changes-from-previous": [
      "id integer→string PROD-XXXX",
      "image string→tableau images[]",
      "price→pricing.base_price",
      "Ajout variants (optionnel)"
    ],
    "x-breaking-changes-in-next": [
      "variants déplacés dans sous-ressource /variants",
      "pricing.base_price→pricing.currency requis",
      "categories remplacée par category_id référençant Catalog API",
      "Ajout SEO metadata obligatoire pour publication"
    ],
    "x-successor": "product-api-v3"
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v2/products": {
      "get": {
        "summary": "Lister avec variantes",
        "operationId": "listProductsV2",
        "tags": [
          "Products"
        ],
        "parameters": [
          {
            "name": "category",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Liste paginée",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductV2List"
                }
              }
            }
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Créer un produit avec variantes",
        "operationId": "createProductV2",
        "tags": [
          "Products"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductV2Create"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Créé",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductV2"
                }
              }
            }
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v2/products/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "pattern": "^PROD-[0-9]{3}$"
          }
        }
      ],
      "get": {
        "summary": "Détails d'un produit",
        "operationId": "getProductV2",
        "tags": [
          "Products"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductV2"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Mettre à jour",
        "operationId": "updateProductV2",
        "tags": [
          "Products"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductV2Create"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Mis à jour"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "delete": {
        "summary": "Archiver (soft delete)",
        "operationId": "archiveProductV2",
        "tags": [
          "Products"
        ],
        "responses": {
          "200": {
            "description": "Archivé"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "ProductV2Create": {
        "type": "object",
        "required": [
          "name",
          "sku",
          "pricing",
          "category"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "sku": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "description": "BREAKING v3: remplacé par category_id"
          },
          "description": {
            "type": "string"
          },
          "pricing": {
            "type": "object",
            "required": [
              "base_price"
            ],
            "properties": {
              "base_price": {
                "type": "number"
              },
              "sale_price": {
                "type": "number"
              },
              "currency": {
                "type": "string",
                "default": "EUR",
                "description": "BREAKING v3: obligatoire"
              }
            }
          },
          "images": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uri"
            }
          },
          "variants": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "sku": {
                  "type": "string"
                },
                "attributes": {
                  "type": "object"
                },
                "stock": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "ProductV2": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "PROD-001"
          },
          "name": {
            "type": "string"
          },
          "sku": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "pricing": {
            "type": "object"
          },
          "images": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "variants": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "draft",
              "archived"
            ]
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ProductV2List": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProductV2"
            }
          },
          "meta": {
            "type": "object",
            "properties": {
              "total": {
                "type": "integer"
              },
              "page": {
                "type": "integer"
              }
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Clé API invalide",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Ressource non trouvée",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit d'état",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Clé API Kong Gateway — contacter votre équipe platform"
      }
    }
  }
}