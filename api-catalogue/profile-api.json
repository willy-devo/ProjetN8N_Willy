{
  "openapi": "3.0.0",
  "info": {
    "title": "Profile API",
    "version": "1.0.0",
    "x-api-id": "profile-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Platform",
    "x-domain": "Identity & Access",
    "description": "Profil public et préférences d'expérience d'un utilisateur connecté. Avatar, bio, paramètres UI et préférences applicatives. DIFFÉRENCE vs user-api : Profile API = données d'affichage et préférences UX visibles par les autres (avatar, bio, timezone), User API = données d'identité et d'accès (email, mot de passe, rôles). DIFFÉRENCE vs customer-profile-api : Profile = préférences d'interface de n'importe quel utilisateur, Customer Profile = données commerciales d'un acheteur (segment, historique d'achat, fidélité).",
    "x-false-positive-warning": "Credentials et rôles → user-api. Données commerciales acheteur → customer-profile-api. Données RH employé → employee-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v1/profile/{userId}": {
      "parameters": [
        {
          "name": "userId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Profil public d'un utilisateur",
        "operationId": "getProfile",
        "tags": [
          "Profile"
        ],
        "responses": {
          "200": {
            "description": "Profil"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Mettre à jour son profil",
        "operationId": "updateProfile",
        "tags": [
          "Profile"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProfileUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Mis à jour"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/profile/{userId}/avatar": {
      "parameters": [
        {
          "name": "userId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "put": {
        "summary": "Changer l'avatar",
        "operationId": "updateAvatar",
        "tags": [
          "Profile"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "avatar": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Avatar mis à jour — URL CDN retournée"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "delete": {
        "summary": "Supprimer l'avatar",
        "operationId": "deleteAvatar",
        "tags": [
          "Profile"
        ],
        "responses": {
          "200": {
            "description": "Avatar supprimé"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/profile/{userId}/preferences": {
      "parameters": [
        {
          "name": "userId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Préférences applicatives",
        "operationId": "getPreferences",
        "tags": [
          "Preferences"
        ],
        "responses": {
          "200": {
            "description": "Préférences"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Mettre à jour les préférences",
        "operationId": "updatePreferences",
        "tags": [
          "Preferences"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "theme": {
                    "type": "string",
                    "enum": [
                      "light",
                      "dark",
                      "auto"
                    ]
                  },
                  "language": {
                    "type": "string"
                  },
                  "timezone": {
                    "type": "string",
                    "example": "Europe/Paris"
                  },
                  "notifications": {
                    "type": "object"
                  },
                  "items_per_page": {
                    "type": "integer",
                    "default": 20
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Préférences mises à jour"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/profile/{userId}/activity": {
      "parameters": [
        {
          "name": "userId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Activité récente de l'utilisateur (connexions, actions)",
        "operationId": "getActivity",
        "tags": [
          "Activity"
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Activité récente"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "ProfileUpdate": {
        "type": "object",
        "properties": {
          "display_name": {
            "type": "string"
          },
          "bio": {
            "type": "string",
            "maxLength": 500
          },
          "website_url": {
            "type": "string",
            "format": "uri"
          },
          "location": {
            "type": "string"
          },
          "timezone": {
            "type": "string",
            "example": "Europe/Paris"
          },
          "social_links": {
            "type": "object",
            "properties": {
              "linkedin": {
                "type": "string"
              },
              "twitter": {
                "type": "string"
              },
              "github": {
                "type": "string"
              }
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "NOT_FOUND"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Clé API invalide",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Ressource non trouvée",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit d'état",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Clé API Kong Gateway — Devoteam nexDigital"
      }
    }
  }
}