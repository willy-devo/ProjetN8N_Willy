{
  "openapi": "3.0.0",
  "info": {
    "title": "Emergency API",
    "version": "1.0.0",
    "x-api-id": "emergency-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Santé",
    "x-domain": "Healthcare",
    "description": "Gestion des urgences médicales. Triage CCMU, passages aux urgences et orientation services."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v1/emergency/triage": {
      "get": {
        "summary": "File de triage",
        "operationId": "getTriageQueue",
        "tags": [
          "Triage"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Enregistrer triage",
        "operationId": "triagePatient",
        "tags": [
          "Triage"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/emergency/cases": {
      "get": {
        "summary": "Cas en cours",
        "operationId": "listCases",
        "tags": [
          "Cases"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Ouvrir cas urgence",
        "operationId": "createCase",
        "tags": [
          "Cases"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/emergency/cases/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Détail cas",
        "operationId": "getCase",
        "tags": [
          "Cases"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Mettre à jour",
        "operationId": "updateCase",
        "tags": [
          "Cases"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Clore",
        "operationId": "closeCase",
        "tags": [
          "Cases"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "NotFound": {
        "description": "Ressource non trouvée"
      },
      "BadRequest": {
        "description": "Données invalides"
      },
      "Unauthorized": {
        "description": "Clé API invalide"
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}