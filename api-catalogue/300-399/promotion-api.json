{
  "openapi": "3.0.0",
  "info": {
    "title": "Promotion API",
    "version": "1.0.0",
    "x-api-id": "promotion-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Marketing",
    "x-domain": "E-Commerce",
    "description": "Promotions commerciales automatiques. Remises sans code (ex: -20% sur toute la catégorie). DIFFÉRENCE vs discount-api : Promotion = remise automatique sans code (s'applique sur critères produits/segments), Discount = code promo saisi par l'utilisateur. DIFFÉRENCE vs pricing-api : Promotion crée les règles de remise, Pricing les applique au calcul final.",
    "x-false-positive-warning": "Code promo saisi → discount-api. Calcul de prix final → pricing-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v1/promotions": {
      "post": {
        "summary": "Créer une promotion automatique",
        "operationId": "createPromotion",
        "tags": [
          "Promotions"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PromotionCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Créée"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "get": {
        "summary": "Lister les promotions actives et planifiées",
        "operationId": "listPromotions",
        "tags": [
          "Promotions"
        ],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "draft",
                "active",
                "expired",
                "paused"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Promotions"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/promotions/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Détails d'une promotion",
        "operationId": "getPromotion",
        "tags": [
          "Promotions"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Modifier une promotion",
        "operationId": "updatePromotion",
        "tags": [
          "Promotions"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Modifiée"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/promotions/{id}/activate": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "put": {
        "summary": "Activer",
        "operationId": "activatePromotion",
        "tags": [
          "Promotions"
        ],
        "responses": {
          "200": {
            "description": "Activée"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/promotions/{id}/deactivate": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "put": {
        "summary": "Désactiver",
        "operationId": "deactivatePromotion",
        "tags": [
          "Promotions"
        ],
        "responses": {
          "200": {
            "description": "Désactivée"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/promotions/eligible": {
      "post": {
        "summary": "Promotions applicables à un panier donné",
        "operationId": "getEligiblePromotions",
        "tags": [
          "Promotions"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "cart_id",
                  "customer_id"
                ],
                "properties": {
                  "cart_id": {
                    "type": "string"
                  },
                  "customer_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Promotions éligibles"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "PromotionCreate": {
        "type": "object",
        "required": [
          "name",
          "type",
          "value"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "percent",
              "fixed",
              "buy_x_get_y",
              "free_shipping"
            ]
          },
          "value": {
            "type": "number"
          },
          "applies_to": {
            "type": "object",
            "properties": {
              "categories": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "products": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "segments": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "min_order_amount": {
            "type": "number"
          },
          "valid_from": {
            "type": "string",
            "format": "date"
          },
          "valid_until": {
            "type": "string",
            "format": "date"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Clé API invalide",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Ressource non trouvée",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit d'état",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Clé API Kong Gateway — contacter votre équipe platform"
      }
    }
  }
}