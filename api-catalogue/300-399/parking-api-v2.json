{
  "openapi": "3.0.0",
  "info": {
    "title": "Parking API",
    "version": "2.0.0",
    "x-api-id": "parking-api-v2",
    "x-api-version": "v2",
    "x-status": "active",
    "x-team": "Equipe Transport",
    "x-domain": "Transport",
    "description": "Gestion parkings et stationnement. Disponibilité, réservation et paiement. DIFFERENCE vs ev-charging-api : Parking = stationnement generique, EV Charging = recharge véhicules électriques spécifiquement.",
    "x-false-positive-warning": "Recharge VE -> ev-charging-api-v2.",
    "x-breaking-changes-from-previous": [
      "Reservation",
      "Paiement integre",
      "Temps reel"
    ]
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v2/parking": {
      "get": {
        "summary": "Parkings disponibles",
        "operationId": "listParkingV2",
        "tags": [
          "Parking"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Réserver place",
        "operationId": "reserveSpot",
        "tags": [
          "Parking"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v2/parking/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Disponibilité",
        "operationId": "getAvailability",
        "tags": [
          "Parking"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v2/parking/{id}/payment": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "post": {
        "summary": "Payer stationnement",
        "operationId": "payParking",
        "tags": [
          "Payment"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}