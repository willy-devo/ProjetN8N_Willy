{
  "openapi": "3.0.0",
  "info": {
    "title": "Travel Insurance API",
    "version": "1.0.0",
    "x-api-id": "travel-insurance-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Tourisme",
    "x-domain": "Tourism",
    "description": "Assurance voyage. Annulation, rapatriement et bagages. DIFFERENCE vs life-insurance-api : Travel Insurance = assurance ponctuelle voyage, Life Insurance = assurance vie long terme.",
    "x-false-positive-warning": "Assurance vie long terme -> life-insurance-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/travel-insurance/quote": {
      "post": {
        "summary": "Obtenir devis",
        "operationId": "getTravelInsuranceQuote",
        "tags": [
          "Quote"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/travel-insurance/policies": {
      "get": {
        "summary": "Contrats voyage",
        "operationId": "listTravelPolicies",
        "tags": [
          "Policies"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Souscrire",
        "operationId": "subscribeTravelInsurance",
        "tags": [
          "Policies"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/travel-insurance/claims": {
      "get": {
        "summary": "Sinistres voyage",
        "operationId": "listTravelClaims",
        "tags": [
          "Claims"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Déclarer sinistre",
        "operationId": "declareTravelClaim",
        "tags": [
          "Claims"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}