{
  "openapi": "3.0.0",
  "info": {
    "title": "Open Banking API",
    "version": "1.0.0",
    "x-api-id": "open-banking-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Banque",
    "x-domain": "Banking",
    "description": "Open banking PSD2. Agregation comptes multi-banques et initiation paiement."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/ob/accounts": {
      "get": {
        "summary": "Comptes agreges",
        "operationId": "listAggregatedAccounts",
        "tags": [
          "Accounts"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/ob/consent": {
      "post": {
        "summary": "Creer consentement TPP",
        "operationId": "createConsent",
        "tags": [
          "Consent"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "delete": {
        "summary": "Revoquer",
        "operationId": "revokeConsent",
        "tags": [
          "Consent"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/ob/payments": {
      "post": {
        "summary": "Initier paiement PSD2",
        "operationId": "initiateOBPayment",
        "tags": [
          "Payments"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}