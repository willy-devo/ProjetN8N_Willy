{
  "openapi": "3.0.0",
  "info": {
    "title": "Property Insurance API",
    "version": "1.0.0",
    "x-api-id": "property-insurance-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Assurance",
    "x-domain": "Insurance",
    "description": "Assurance habitation et biens. MRH, garanties et sinistres. DIFFERENCE vs property-api (immobilier) : Property Insurance = contrat assurance bien, Property = fiche descriptive du bien.",
    "x-false-positive-warning": "Fiche bien immobilier -> property-api-v3."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/property-insurance": {
      "get": {
        "summary": "Contrats habitation",
        "operationId": "listPropertyInsurance",
        "tags": [
          "Insurance"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Souscrire MRH",
        "operationId": "subscribePropertyInsurance",
        "tags": [
          "Insurance"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/property-insurance/{contractId}": {
      "parameters": [
        {
          "name": "contractId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Detail contrat",
        "operationId": "getPropertyInsurance",
        "tags": [
          "Insurance"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Modifier",
        "operationId": "updatePropertyInsurance",
        "tags": [
          "Insurance"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/property-insurance/{contractId}/guarantees": {
      "parameters": [
        {
          "name": "contractId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Garanties incluses",
        "operationId": "getGuarantees",
        "tags": [
          "Guarantees"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}