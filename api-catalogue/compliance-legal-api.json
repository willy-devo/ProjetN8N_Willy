{
  "openapi": "3.0.0",
  "info": {
    "title": "Compliance Legal API",
    "version": "1.0.0",
    "x-api-id": "compliance-legal-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Legal",
    "x-domain": "Legal",
    "description": "Conformite reglementaire juridique. Obligations, veille et reporting. DIFFERENCE vs compliance-check-api : Compliance Legal = conformite droit des affaires, Compliance Check = conformite securite informatique.",
    "x-false-positive-warning": "Conformite securite IT -> compliance-check-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/compliance/legal/obligations": {
      "get": {
        "summary": "Obligations legales",
        "operationId": "listLegalObligations",
        "tags": [
          "Obligations"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Ajouter",
        "operationId": "addObligation",
        "tags": [
          "Obligations"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/compliance/legal/{obligationId}/status": {
      "parameters": [
        {
          "name": "obligationId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Statut conformite",
        "operationId": "getComplianceStatus",
        "tags": [
          "Status"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Mettre a jour",
        "operationId": "updateStatus",
        "tags": [
          "Status"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/compliance/legal/reports": {
      "get": {
        "summary": "Rapports",
        "operationId": "listComplianceReports",
        "tags": [
          "Reports"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Générer rapport",
        "operationId": "generateLegalReport",
        "tags": [
          "Reports"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}