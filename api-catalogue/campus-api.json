{
  "openapi": "3.0.0",
  "info": {
    "title": "Campus API",
    "version": "1.0.0",
    "x-api-id": "campus-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Education",
    "x-domain": "Education",
    "description": "Services campus. Restaurants, salles, events et vie étudiante."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/campus/facilities": {
      "get": {
        "summary": "Équipements campus",
        "operationId": "listFacilities",
        "tags": [
          "Facilities"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/campus/rooms": {
      "get": {
        "summary": "Salles disponibles",
        "operationId": "listCampusRooms",
        "tags": [
          "Rooms"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Réserver salle",
        "operationId": "bookCampusRoom",
        "tags": [
          "Rooms"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/campus/events": {
      "get": {
        "summary": "Événements",
        "operationId": "listCampusEvents",
        "tags": [
          "Events"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Créer événement",
        "operationId": "createCampusEvent",
        "tags": [
          "Events"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/campus/canteen": {
      "get": {
        "summary": "Menu du jour",
        "operationId": "getCanteenMenu",
        "tags": [
          "Canteen"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}