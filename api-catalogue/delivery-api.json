{
  "openapi": "3.0.0",
  "info": {
    "title": "Delivery API",
    "version": "1.0.0",
    "x-api-id": "delivery-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Logistique",
    "x-domain": "Supply Chain",
    "description": "Créneaux de livraison et planning. Réservation de plages horaires et gestion des livreurs. DIFFÉRENCE vs shipping-api : Delivery = planning des créneaux et livreurs, Shipping = colis et transporteurs.",
    "x-false-positive-warning": "Suivi de colis → shipping-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v1/delivery/slots": {
      "get": {
        "summary": "Créneaux de livraison disponibles",
        "operationId": "getSlots",
        "tags": [
          "Delivery"
        ],
        "parameters": [
          {
            "name": "date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "zip",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Créneaux"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/delivery/book": {
      "post": {
        "summary": "Réserver un créneau de livraison",
        "operationId": "bookDelivery",
        "tags": [
          "Delivery"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "order_id",
                  "slot_id"
                ],
                "properties": {
                  "order_id": {
                    "type": "string"
                  },
                  "slot_id": {
                    "type": "string"
                  },
                  "contact_phone": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Créneau réservé"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/delivery/{id}/reschedule": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "put": {
        "summary": "Modifier le créneau de livraison",
        "operationId": "rescheduleDelivery",
        "tags": [
          "Delivery"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "new_slot_id"
                ],
                "properties": {
                  "new_slot_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reprogrammé"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/delivery/tracking/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Suivi en temps réel du livreur",
        "operationId": "trackDelivery",
        "tags": [
          "Delivery"
        ],
        "responses": {
          "200": {
            "description": "Position et ETA"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "NOT_FOUND"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Clé API manquante ou invalide",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Ressource non trouvée",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit — ressource déjà existante ou état incompatible",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Clé API Kong Gateway"
      }
    }
  }
}