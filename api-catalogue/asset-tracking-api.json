{
  "openapi": "3.0.0",
  "info": {
    "title": "Asset Tracking API",
    "version": "1.0.0",
    "x-api-id": "asset-tracking-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe IoT",
    "x-domain": "IoT",
    "description": "Suivi des actifs physiques en temps réel. GPS, géofencing et historique. DIFFERENCE vs logistics-tracking-api : Asset Tracking = actifs stationnaires (machines, équipements), Logistics = colis en transit.",
    "x-false-positive-warning": "Colis en transit -> logistics-tracking-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/assets": {
      "get": {
        "summary": "Lister actifs",
        "operationId": "listAssets",
        "tags": [
          "Assets"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Enregistrer",
        "operationId": "registerAsset",
        "tags": [
          "Assets"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/assets/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Position GPS",
        "operationId": "getAssetLocation",
        "tags": [
          "Assets"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Modifier",
        "operationId": "updateAsset",
        "tags": [
          "Assets"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/assets/{id}/history": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Historique positions",
        "operationId": "getAssetHistory",
        "tags": [
          "History"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/assets/{id}/geofence": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "post": {
        "summary": "Créer zone",
        "operationId": "createGeofence",
        "tags": [
          "Geofence"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "get": {
        "summary": "Vérifier zone",
        "operationId": "checkGeofence",
        "tags": [
          "Geofence"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}