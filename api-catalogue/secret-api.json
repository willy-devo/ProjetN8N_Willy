{
  "openapi": "3.0.0",
  "info": {
    "title": "Secret Manager API",
    "version": "1.0.0",
    "x-api-id": "secret-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Security",
    "x-domain": "Security & Compliance",
    "description": "Gestionnaire de secrets. Credentials, tokens et certificats stockés de manière sécurisée. DIFFÉRENCE vs api-key-api : Secret Manager = stockage générique de tous types de secrets (mots de passe, certificats, tokens tiers), API Key API = gestion spécifique des clés d'accès à nos APIs.",
    "x-false-positive-warning": "Clés API Kong → api-key-api. Chiffrement de données → encryption-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v1/secrets": {
      "post": {
        "summary": "Créer un secret",
        "operationId": "createSecret",
        "tags": [
          "Secrets"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "value"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "value": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "tags": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "rotation_days": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Secret créé (valeur non retournée)"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "get": {
        "summary": "Lister les secrets (métadonnées uniquement)",
        "operationId": "listSecrets",
        "tags": [
          "Secrets"
        ],
        "responses": {
          "200": {
            "description": "Secrets sans valeurs"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/secrets/{name}": {
      "parameters": [
        {
          "name": "name",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Lire la valeur d'un secret",
        "operationId": "getSecret",
        "tags": [
          "Secrets"
        ],
        "responses": {
          "200": {
            "description": "Secret avec valeur"
          },
          "403": {
            "description": "Accès non autorisé"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Mettre à jour la valeur",
        "operationId": "updateSecret",
        "tags": [
          "Secrets"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "value"
                ],
                "properties": {
                  "value": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Mis à jour"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "delete": {
        "summary": "Supprimer un secret",
        "operationId": "deleteSecret",
        "tags": [
          "Secrets"
        ],
        "responses": {
          "204": {
            "description": "Supprimé"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/secrets/{name}/versions": {
      "parameters": [
        {
          "name": "name",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Historique des versions d'un secret",
        "operationId": "getSecretVersions",
        "tags": [
          "Secrets"
        ],
        "responses": {
          "200": {
            "description": "Versions"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Clé API invalide",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Ressource non trouvée",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit d'état",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Clé API Kong Gateway — contacter votre équipe platform"
      }
    }
  }
}