# ─────────────────────────────────────────────
# .env.example — Template à copier en .env
# Commande : cp .env.example .env  puis remplir
# ─────────────────────────────────────────────

# ── Mistral (LLM utilisé par l'agent Discovery) ──
MISTRAL_API_KEY=your_mistral_api_key_here

# ── Kong API Gateway ──
# En Docker : http://kong:8000  (nom de service)
# En local  : http://localhost:8000
KONG_URL=http://kong:8000
KONG_API_KEY=n8n-internal-key-2025

# ── Pinecone (utilisé côté mcp-server) ──
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=apis-catalog
PINECONE_ENVIRONMENT=us-east-1

# ─────────────────────────────────────────────────────────────
# ── LangSmith (observabilité) — OPTIONNEL ────────────────────
# ─────────────────────────────────────────────────────────────
# Active le tracing automatique de chaque step LangGraph :
#   - inputs/outputs LLM
#   - tool calls (search_apis)
#   - latence, tokens, coûts
#
# Crée un compte gratuit sur https://smith.langchain.com
# puis génère une clé API dans Settings → API Keys.
# Laisse les lignes commentées si tu ne veux pas l'activer.
# ─────────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxxxxxxxx
LANGCHAIN_PROJECT=agentic4api-discovery
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Optionnel : n8n si tu réactives le service ──
# N8N_BASIC_AUTH_USER=admin
# N8N_BASIC_AUTH_PASSWORD=changeme
