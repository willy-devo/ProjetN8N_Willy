{
  "openapi": "3.0.0",
  "info": {
    "title": "Geolocation API",
    "version": "1.0.0",
    "x-api-id": "geolocation-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Platform",
    "x-domain": "Localisation",
    "description": "Géolocalisation et cartographie. Geocodage, distances et zones de livraison. DIFFÉRENCE vs localization-api : Geolocation = coordonnées et cartes, Localization = traductions et formats culturels.",
    "x-false-positive-warning": "Traductions/formats → localization-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v1/geo/geocode": {
      "post": {
        "summary": "Convertir une adresse en coordonnées",
        "operationId": "geocode",
        "tags": [
          "Geo"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "address"
                ],
                "properties": {
                  "address": {
                    "type": "string",
                    "example": "12 rue de la Paix, 75001 Paris"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Coordonnées lat/lng"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/geo/reverse-geocode": {
      "post": {
        "summary": "Convertir des coordonnées en adresse",
        "operationId": "reverseGeocode",
        "tags": [
          "Geo"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "lat",
                  "lng"
                ],
                "properties": {
                  "lat": {
                    "type": "number",
                    "example": 48.8698
                  },
                  "lng": {
                    "type": "number",
                    "example": 2.3309
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Adresse"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/geo/distance": {
      "post": {
        "summary": "Calculer la distance entre deux points",
        "operationId": "calcDistance",
        "tags": [
          "Geo"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "origin",
                  "destination"
                ],
                "properties": {
                  "origin": {
                    "type": "object",
                    "properties": {
                      "lat": {
                        "type": "number"
                      },
                      "lng": {
                        "type": "number"
                      }
                    }
                  },
                  "destination": {
                    "type": "object",
                    "properties": {
                      "lat": {
                        "type": "number"
                      },
                      "lng": {
                        "type": "number"
                      }
                    }
                  },
                  "mode": {
                    "type": "string",
                    "enum": [
                      "driving",
                      "walking",
                      "cycling"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Distance et durée"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/geo/delivery-zone": {
      "post": {
        "summary": "Vérifier si une adresse est dans une zone de livraison",
        "operationId": "checkDeliveryZone",
        "tags": [
          "Geo"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "address",
                  "zone_id"
                ],
                "properties": {
                  "address": {
                    "type": "string"
                  },
                  "zone_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Dans la zone ou non"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "NOT_FOUND"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Clé API manquante ou invalide",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Ressource non trouvée",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit — ressource déjà existante ou état incompatible",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Clé API Kong Gateway"
      }
    }
  }
}