{
  "openapi": "3.0.0",
  "info": {
    "title": "Onboarding API",
    "version": "1.0.0",
    "x-api-id": "onboarding-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe RH",
    "x-domain": "Human Resources",
    "description": "Parcours d'intégration des nouveaux employés. Checklist, documents et accès à provisionner."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/onboarding/start": {
      "post": {
        "summary": "Démarrer le parcours d'onboarding",
        "operationId": "startOnboarding",
        "tags": [
          "Onboarding"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "employee_id",
                  "start_date"
                ],
                "properties": {
                  "employee_id": {
                    "type": "string"
                  },
                  "start_date": {
                    "type": "string",
                    "format": "date"
                  },
                  "template_id": {
                    "type": "string",
                    "description": "Template de parcours (ex: dev, commercial, manager)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Parcours démarré"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/onboarding/{employeeId}": {
      "parameters": [
        {
          "name": "employeeId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Statut du parcours d'onboarding",
        "operationId": "getOnboarding",
        "tags": [
          "Onboarding"
        ],
        "responses": {
          "200": {
            "description": "Parcours avec tâches et avancement"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/onboarding/{employeeId}/tasks/{taskId}/complete": {
      "parameters": [
        {
          "name": "employeeId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        },
        {
          "name": "taskId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "put": {
        "summary": "Marquer une tâche d'onboarding comme complétée",
        "operationId": "completeOnboardingTask",
        "tags": [
          "Onboarding"
        ],
        "responses": {
          "200": {
            "description": "Tâche complétée"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/onboarding/{employeeId}/provision-access": {
      "parameters": [
        {
          "name": "employeeId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "post": {
        "summary": "Provisionner automatiquement les accès systèmes",
        "operationId": "provisionAccess",
        "tags": [
          "Onboarding"
        ],
        "responses": {
          "202": {
            "description": "Accès provisionnés"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Non autorisé",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Non trouvé",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}