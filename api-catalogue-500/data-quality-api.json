{
  "openapi": "3.0.0",
  "info": {
    "title": "Data Quality API",
    "version": "1.0.0",
    "x-api-id": "data-quality-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Data",
    "x-domain": "Data",
    "description": "Qualite des donnees. Regles et anomalies. DIFFERENCE vs data-catalog-api : Data Quality = controles qualite, Data Catalog = gouvernance inventaire.",
    "x-false-positive-warning": "Inventaire donnees -> data-catalog-api-v3."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/quality/rules": {
      "get": {
        "summary": "Regles",
        "operationId": "listQualityRules",
        "tags": [
          "Rules"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Creer",
        "operationId": "createQualityRule",
        "tags": [
          "Rules"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/quality/checks/{datasetId}": {
      "parameters": [
        {
          "name": "datasetId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "post": {
        "summary": "Lancer",
        "operationId": "runQualityCheck",
        "tags": [
          "Checks"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "get": {
        "summary": "Resultats",
        "operationId": "getQualityResults",
        "tags": [
          "Checks"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/quality/anomalies": {
      "get": {
        "summary": "Anomalies",
        "operationId": "listDataAnomalies",
        "tags": [
          "Anomalies"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Acquitter",
        "operationId": "acknowledgeAnomaly",
        "tags": [
          "Anomalies"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}