{
  "openapi": "3.0.0",
  "info": {
    "title": "Toll API",
    "version": "1.0.0",
    "x-api-id": "toll-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Transport",
    "x-domain": "Transport",
    "description": "Gestion des péages et taxes de transit. Calcul coûts, télépéage et facturation."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/tolls/calculate": {
      "post": {
        "summary": "Calculer péages itinéraire",
        "operationId": "calculateTolls",
        "tags": [
          "Tolls"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/tolls/accounts/{vehicleId}": {
      "parameters": [
        {
          "name": "vehicleId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Compte télépéage",
        "operationId": "getTollAccount",
        "tags": [
          "Accounts"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Recharger compte",
        "operationId": "topUpAccount",
        "tags": [
          "Accounts"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/tolls/transactions/{vehicleId}": {
      "parameters": [
        {
          "name": "vehicleId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Historique péages",
        "operationId": "getTollTransactions",
        "tags": [
          "Transactions"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}