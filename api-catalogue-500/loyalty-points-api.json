{
  "openapi": "3.0.0",
  "info": {
    "title": "Loyalty Points API",
    "version": "1.0.0",
    "x-api-id": "loyalty-points-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe CRM",
    "x-domain": "CRM & Marketing",
    "description": "Programme de fidélité. Points accumulés, échangés et historique des récompenses."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v1/loyalty/{customerId}": {
      "parameters": [
        {
          "name": "customerId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Solde de points fidélité",
        "operationId": "getLoyaltyBalance",
        "tags": [
          "Loyalty"
        ],
        "responses": {
          "200": {
            "description": "Solde"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/loyalty/earn": {
      "post": {
        "summary": "Attribuer des points (après achat)",
        "operationId": "earnPoints",
        "tags": [
          "Loyalty"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "customer_id",
                  "points",
                  "order_id"
                ],
                "properties": {
                  "customer_id": {
                    "type": "string"
                  },
                  "points": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "order_id": {
                    "type": "string"
                  },
                  "reason": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Points attribués"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/loyalty/redeem": {
      "post": {
        "summary": "Utiliser des points (récompense)",
        "operationId": "redeemPoints",
        "tags": [
          "Loyalty"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "customer_id",
                  "points",
                  "reward_id"
                ],
                "properties": {
                  "customer_id": {
                    "type": "string"
                  },
                  "points": {
                    "type": "integer"
                  },
                  "reward_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Échangés"
          },
          "400": {
            "description": "Solde insuffisant"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/loyalty/{customerId}/history": {
      "parameters": [
        {
          "name": "customerId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Historique des transactions de fidélité",
        "operationId": "getLoyaltyHistory",
        "tags": [
          "Loyalty"
        ],
        "responses": {
          "200": {
            "description": "Historique"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/loyalty/rewards": {
      "get": {
        "summary": "Catalogue des récompenses disponibles",
        "operationId": "getRewards",
        "tags": [
          "Loyalty"
        ],
        "responses": {
          "200": {
            "description": "Récompenses"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "NOT_FOUND"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Clé API manquante ou invalide",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Ressource non trouvée",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit — ressource déjà existante ou état incompatible",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Clé API Kong Gateway"
      }
    }
  }
}