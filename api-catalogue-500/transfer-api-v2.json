{
  "openapi": "3.0.0",
  "info": {
    "title": "Transfer API",
    "version": "2.0.0",
    "x-api-id": "transfer-api-v2",
    "x-api-version": "v2",
    "x-status": "active",
    "x-team": "Equipe Banque",
    "x-domain": "Banking",
    "description": "Virements SEPA, SWIFT et instantane. DIFFERENCE vs payout-api : Transfer = virement entre comptes bancaires, Payout = reversement plateforme vers vendeur.",
    "x-false-positive-warning": "Reversement vendeur -> payout-api.",
    "x-breaking-changes-from-previous": [
      "SEPA instantane",
      "SWIFT",
      "Validation IBAN"
    ]
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v2/transfers": {
      "get": {
        "summary": "Historique",
        "operationId": "listTransfersV2",
        "tags": [
          "Transfers"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Creer virement",
        "operationId": "createTransferV2",
        "tags": [
          "Transfers"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v2/transfers/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Statut",
        "operationId": "getTransferV2",
        "tags": [
          "Transfers"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "delete": {
        "summary": "Annuler",
        "operationId": "cancelTransfer",
        "tags": [
          "Transfers"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v2/transfers/validate-iban": {
      "post": {
        "summary": "Valider IBAN",
        "operationId": "validateIBAN",
        "tags": [
          "Validation"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v2/transfers/fees": {
      "post": {
        "summary": "Calculer frais",
        "operationId": "calculateFees",
        "tags": [
          "Fees"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}