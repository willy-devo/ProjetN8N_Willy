{
  "openapi": "3.0.0",
  "info": {
    "title": "Real Estate Search API",
    "version": "1.0.0",
    "x-api-id": "real-estate-search-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Immobilier",
    "x-domain": "RealEstate",
    "description": "Recherche biens immobiliers. Filtres avancés, carte et alertes. DIFFERENCE vs search-api-v3 : Real Estate Search = recherche biens immobiliers spécifiquement, Search = moteur de recherche générique.",
    "x-false-positive-warning": "Moteur recherche generique -> search-api-v3."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/real-estate/search": {
      "get": {
        "summary": "Rechercher biens",
        "operationId": "searchProperties",
        "tags": [
          "Search"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Sauvegarder recherche",
        "operationId": "saveSearch",
        "tags": [
          "Search"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/real-estate/alerts": {
      "get": {
        "summary": "Alertes actives",
        "operationId": "listSearchAlerts",
        "tags": [
          "Alerts"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Créer alerte",
        "operationId": "createSearchAlert",
        "tags": [
          "Alerts"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/real-estate/map": {
      "get": {
        "summary": "Biens sur carte",
        "operationId": "getPropertiesOnMap",
        "tags": [
          "Map"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}