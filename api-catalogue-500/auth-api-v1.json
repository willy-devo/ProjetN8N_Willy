{
  "openapi": "3.0.0",
  "info": {
    "title": "Auth API",
    "version": "1.0.0",
    "x-api-id": "auth-api-v1",
    "x-api-version": "v1",
    "x-status": "deprecated",
    "x-team": "Equipe Identity",
    "x-domain": "Identity & Access",
    "description": "Version 1 de l'Auth API. DEPRECATED 2022. Sessions serveur sans JWT, pas de refresh token, pas d'OAuth2. Migrer vers v2 (JWT stateless).",
    "x-breaking-changes-in-next": [
      "Sessions serveur→JWT stateless",
      "Nouveau endpoint /refresh",
      "Cookie session→Bearer token header",
      "Ajout OAuth2 client_credentials"
    ],
    "x-successor": "auth-api"
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v1/auth/login": {
      "post": {
        "summary": "Connexion par session serveur (cookies)",
        "operationId": "loginV1",
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password"
                ],
                "properties": {
                  "email": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Cookie de session set-cookie"
          },
          "401": {
            "description": "Identifiants invalides"
          }
        },
        "security": []
      }
    },
    "/v1/auth/logout": {
      "post": {
        "summary": "Déconnexion (invalidation session serveur)",
        "operationId": "logoutV1",
        "tags": [
          "Auth"
        ],
        "responses": {
          "204": {
            "description": "Déconnecté"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/auth/me": {
      "get": {
        "summary": "Profil depuis session",
        "operationId": "getMeV1",
        "tags": [
          "Auth"
        ],
        "responses": {
          "200": {
            "description": "Profil"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Clé API invalide",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Ressource non trouvée",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit d'état",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Clé API Kong Gateway — contacter votre équipe platform"
      }
    }
  }
}