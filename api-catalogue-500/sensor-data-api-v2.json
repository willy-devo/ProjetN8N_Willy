          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Données temps reel",
        "operationId": "getSensorData",
        "tags": [
          "Data"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
