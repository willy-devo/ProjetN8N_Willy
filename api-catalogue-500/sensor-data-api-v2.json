{
  "openapi": "3.0.0",
  "info": {
    "title": "Sensor Data API",
    "version": "2.0.0",
    "x-api-id": "sensor-data-api-v2",
    "x-api-version": "v2",
    "x-status": "active",
    "x-team": "Equipe IoT",
    "x-domain": "IoT",
    "description": "Collecte et analyse données capteurs IoT. Températures, pression, humidité et vibrations. DIFFERENCE vs telemetry-api : Sensor Data = données brutes capteurs physiques, Telemetry = données agrégées équipements.",
    "x-false-positive-warning": "Données agrégées équipements -> telemetry-api.",
    "x-breaking-changes-from-previous": [
      "Stream SSE",
      "Multi-protocoles",
      "Calibration auto"
    ]
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
