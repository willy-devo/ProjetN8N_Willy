{
  "openapi": "3.0.0",
  "info": {
    "title": "Rate Limiting API",
    "version": "1.0.0",
    "x-api-id": "rate-limiting-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Divers",
    "x-domain": "Cross",
    "description": "Gestion quotas et rate limiting. Par client, endpoint et periode."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/rate-limits": {
      "get": {
        "summary": "Quotas configures",
        "operationId": "listRateLimits",
        "tags": [
          "Limits"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Creer quota",
        "operationId": "createRateLimit",
        "tags": [
          "Limits"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/rate-limits/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Detail",
        "operationId": "getRateLimit",
        "tags": [
          "Limits"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Modifier",
        "operationId": "updateRateLimit",
        "tags": [
          "Limits"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/rate-limits/check": {
      "post": {
        "summary": "Consommer quota",
        "operationId": "consumeQuota",
        "tags": [
          "Check"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
