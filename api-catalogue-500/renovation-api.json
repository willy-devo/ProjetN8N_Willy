      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Devis",
        "operationId": "getQuotes",
        "tags": [
          "Quotes"
