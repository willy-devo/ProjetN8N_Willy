        "summary": "Projets en cours",
        "operationId": "listRenovations",
        "tags": [
          "Renovations"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Créer projet",
        "operationId": "createRenovation",
