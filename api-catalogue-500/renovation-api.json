{
  "openapi": "3.0.0",
  "info": {
    "title": "Renovation API",
    "version": "1.0.0",
    "x-api-id": "renovation-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Immobilier",
    "x-domain": "RealEstate",
    "description": "Gestion travaux de rénovation. Devis, planning et suivi chantier."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
