{
  "openapi": "3.0.0",
  "info": {
    "title": "Catalog API",
    "version": "1.0.0",
    "x-api-id": "catalog-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Catalog",
    "x-domain": "E-Commerce",
    "description": "Gestion des catalogues et collections de produits destinés à la publication (site web, app, B2B). Un catalogue regroupe une sélection de produits avec ses propres règles de prix, de disponibilité et d'affichage. DIFFÉRENCE vs product-catalog-api : Catalog API gère les catalogues comme collections publiées (ex: catalogue été 2026, catalogue B2B Allemagne), Product Catalog API gère la taxonomie des catégories et attributs produits. DIFFÉRENCE vs product-api : Catalog = regroupement de produits existants en collections, Product = données d'un produit individuel.",
    "x-false-positive-warning": "Taxonomie et catégories produits → product-catalog-api. Données produit individuel → product-api-v4."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v1/catalogs": {
      "post": {
        "summary": "Créer un catalogue",
        "operationId": "createCatalog",
        "tags": [
          "Catalogs"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CatalogCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Catalogue créé"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "get": {
        "summary": "Lister les catalogues",
        "operationId": "listCatalogs",
        "tags": [
          "Catalogs"
        ],
        "parameters": [
          {
            "name": "channel",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "b2c_web",
                "b2c_app",
                "b2b",
                "marketplace"
              ]
            }
          },
          {
            "name": "locale",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "active",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Catalogues"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/catalogs/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Détails d'un catalogue",
        "operationId": "getCatalog",
        "tags": [
          "Catalogs"
        ],
        "responses": {
          "200": {
            "description": "Catalogue"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Mettre à jour",
        "operationId": "updateCatalog",
        "tags": [
          "Catalogs"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Mis à jour"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "delete": {
        "summary": "Archiver le catalogue",
        "operationId": "archiveCatalog",
        "tags": [
          "Catalogs"
        ],
        "responses": {
          "200": {
            "description": "Archivé"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/catalogs/{id}/products": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Produits d'un catalogue",
        "operationId": "getCatalogProducts",
        "tags": [
          "Products"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Produits"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Ajouter des produits au catalogue",
        "operationId": "addProductsToCatalog",
        "tags": [
          "Products"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "product_ids"
                ],
                "properties": {
                  "product_ids": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "price_override": {
                    "type": "number",
                    "description": "Prix spécifique à ce catalogue"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ajoutés"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/catalogs/{id}/products/{productId}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        },
        {
          "name": "productId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "delete": {
        "summary": "Retirer un produit du catalogue",
        "operationId": "removeProductFromCatalog",
        "tags": [
          "Products"
        ],
        "responses": {
          "204": {
            "description": "Retiré"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/catalogs/{id}/publish": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "post": {
        "summary": "Publier le catalogue (le rend visible sur les canaux)",
        "operationId": "publishCatalog",
        "tags": [
          "Catalogs"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "channels": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "scheduled_at": {
                    "type": "string",
                    "format": "date-time"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Publié"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "CatalogCreate": {
        "type": "object",
        "required": [
          "name",
          "channel",
          "locale"
        ],
        "properties": {
          "name": {
            "type": "string",
            "example": "Catalogue Été 2026"
          },
          "channel": {
            "type": "string",
            "enum": [
              "b2c_web",
              "b2c_app",
              "b2b",
              "marketplace"
            ]
          },
          "locale": {
            "type": "string",
            "example": "fr"
          },
          "currency": {
            "type": "string",
            "default": "EUR"
          },
          "valid_from": {
            "type": "string",
            "format": "date"
          },
          "valid_until": {
            "type": "string",
            "format": "date"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "NOT_FOUND"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Clé API invalide",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Ressource non trouvée",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit d'état",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Clé API Kong Gateway — Devoteam nexDigital"
      }
    }
  }
}