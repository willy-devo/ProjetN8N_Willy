{
  "openapi": "3.0.0",
  "info": {
    "title": "Production Scheduling API",
    "version": "1.0.0",
    "x-api-id": "production-scheduling-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Industrie",
    "x-domain": "Industry",
    "description": "Ordonnancement production. Planning capacitaire, sequencement et optimisation."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/scheduling/plan": {
      "get": {
        "summary": "Planning production",
        "operationId": "getProductionSchedule",
        "tags": [
          "Plan"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Calculer ordonnancement",
        "operationId": "generateSchedule",
        "tags": [
          "Plan"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/scheduling/capacity": {
      "get": {
        "summary": "Charge capacitaire",
        "operationId": "getCapacityLoad",
        "tags": [
          "Capacity"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Verifier capacite",
        "operationId": "runCapacityCheck",
        "tags": [
          "Capacity"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/scheduling/jobs/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Job ordonnance",
        "operationId": "getScheduledJob",
        "tags": [
          "Jobs"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Reprogrammer",
        "operationId": "rescheduleJob",
        "tags": [
          "Jobs"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}