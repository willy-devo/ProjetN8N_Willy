{
  "openapi": "3.0.0",
  "info": {
    "title": "Portfolio API",
    "version": "1.0.0",
    "x-api-id": "portfolio-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Banque",
    "x-domain": "Banking",
    "description": "Gestion portefeuille actifs. Valorisation, performance et rebalancement. DIFFERENCE vs investment-api : Portfolio = analyse existant, Investment = passation ordres.",
    "x-false-positive-warning": "Passer un ordre -> investment-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/portfolios/{clientId}": {
      "parameters": [
        {
          "name": "clientId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Valorisation",
        "operationId": "getPortfolioValue",
        "tags": [
          "Portfolios"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Creer",
        "operationId": "createPortfolio",
        "tags": [
          "Portfolios"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/portfolios/{id}/performance": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Performance TRI",
        "operationId": "getPerformance",
        "tags": [
          "Performance"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/portfolios/{id}/rebalance": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "post": {
        "summary": "Reequilibrer",
        "operationId": "rebalancePortfolio",
        "tags": [
          "Rebalance"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}