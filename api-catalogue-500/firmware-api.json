{
  "openapi": "3.0.0",
  "info": {
    "title": "Firmware API",
    "version": "1.0.0",
    "x-api-id": "firmware-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe IoT",
    "x-domain": "IoT",
    "description": "Gestion des mises a jour firmware OTA. Distribution, déploiement progressif et rollback. DIFFERENCE vs device-registry-api : Firmware = MAJ logicielle, Device Registry = inventaire materiel.",
    "x-false-positive-warning": "Inventaire materiel -> device-registry-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/firmware/releases": {
      "get": {
        "summary": "Releases disponibles",
        "operationId": "listReleases",
        "tags": [
          "Releases"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Publier release",
        "operationId": "publishRelease",
        "tags": [
          "Releases"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/firmware/releases/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Detail release",
        "operationId": "getRelease",
        "tags": [
          "Releases"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/firmware/deployments": {
      "get": {
        "summary": "Déploiements en cours",
        "operationId": "listDeployments",
        "tags": [
          "Deployments"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Lancer déploiement",
        "operationId": "createDeployment",
        "tags": [
          "Deployments"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/firmware/deployments/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Statut",
        "operationId": "getDeploymentStatus",
        "tags": [
          "Deployments"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "delete": {
        "summary": "Rollback",
        "operationId": "rollbackDeployment",
        "tags": [
          "Deployments"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}