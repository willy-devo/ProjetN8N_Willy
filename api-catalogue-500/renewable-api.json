{
  "openapi": "3.0.0",
  "info": {
    "title": "Renewable Energy API",
    "version": "1.0.0",
    "x-api-id": "renewable-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe IoT",
    "x-domain": "IoT",
    "description": "Gestion sources d'énergie renouvelable. Solaire, éolien, hydraulique et mix énergétique."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/renewable/sources": {
      "get": {
        "summary": "Sources renouvelables",
        "operationId": "listRenewableSources",
        "tags": [
          "Sources"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Ajouter source",
        "operationId": "addSource",
        "tags": [
          "Sources"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/renewable/sources/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Statut",
        "operationId": "getSourceStatus",
        "tags": [
          "Sources"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/renewable/mix": {
      "get": {
        "summary": "Prévision mix",
        "operationId": "getMixForecast",
        "tags": [
          "Mix"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}