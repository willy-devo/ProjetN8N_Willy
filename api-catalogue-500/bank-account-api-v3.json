{
  "openapi": "3.0.0",
  "info": {
    "title": "Bank Account API",
    "version": "3.0.0",
    "x-api-id": "bank-account-api-v3",
    "x-api-version": "v3",
    "x-status": "active",
    "x-team": "Equipe Banque",
    "x-domain": "Banking",
    "description": "Comptes courants et epargne avec open banking PSD2. DIFFERENCE vs wallet-api : Bank Account = compte bancaire IBAN/RIB, Wallet = portefeuille electronique interne.",
    "x-false-positive-warning": "Portefeuille electronique -> wallet-api.",
    "x-breaking-changes-from-previous": [
      "PSD2",
      "Solde temps reel"
    ]
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
