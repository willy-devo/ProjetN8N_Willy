{
  "openapi": "3.0.0",
  "info": {
    "title": "Visitor Management API",
    "version": "1.0.0",
    "x-api-id": "visitor-management-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Immobilier",
    "x-domain": "RealEstate",
    "description": "Gestion visiteurs et accès immeubles. Badges, invitations et journal des accès."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/visitors": {
      "get": {
        "summary": "Visiteurs du jour",
        "operationId": "listVisitors",
        "tags": [
          "Visitors"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Pré-enregistrer",
        "operationId": "preRegisterVisitor",
        "tags": [
          "Visitors"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/visitors/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Detail",
        "operationId": "getVisitor",
        "tags": [
          "Visitors"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Enregistrer sortie",
        "operationId": "checkOutVisitor",
        "tags": [
          "Visitors"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/visitors/access-log": {
      "get": {
        "summary": "Journal des accès",
        "operationId": "getAccessLog",
        "tags": [
          "Log"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}