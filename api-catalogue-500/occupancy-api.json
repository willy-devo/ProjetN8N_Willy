{
  "openapi": "3.0.0",
  "info": {
    "title": "Occupancy API",
    "version": "1.0.0",
    "x-api-id": "occupancy-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Immobilier",
    "x-domain": "RealEstate",
    "description": "Taux d'occupation et disponibilités. Baux actifs, vacances et prévisions."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/occupancy/{portfolioId}": {
      "parameters": [
        {
          "name": "portfolioId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Vacances",
        "operationId": "getVacancies",
        "tags": [
          "Occupancy"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/occupancy/{portfolioId}/forecast": {
      "parameters": [
        {
          "name": "portfolioId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Prévisions",
        "operationId": "getOccupancyForecast",
        "tags": [
          "Forecast"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/occupancy/alerts": {
      "get": {
        "summary": "Alertes vacance",
        "operationId": "getOccupancyAlerts",
        "tags": [
          "Alerts"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}