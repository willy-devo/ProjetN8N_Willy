{
  "openapi": "3.0.0",
  "info": {
    "title": "Load Planning API",
    "version": "1.0.0",
    "x-api-id": "load-planning-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Transport",
    "x-domain": "Transport",
    "description": "Planification chargement véhicules. Optimisation espace, poids et contraintes."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/loads": {
      "get": {
        "summary": "Chargements planifiés",
        "operationId": "listLoads",
        "tags": [
          "Loads"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Créer plan chargement",
        "operationId": "createLoadPlan",
        "tags": [
          "Loads"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/loads/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Plan chargement",
        "operationId": "getLoadPlan",
        "tags": [
          "Loads"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Modifier",
        "operationId": "updateLoadPlan",
        "tags": [
          "Loads"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/loads/optimize": {
      "post": {
        "summary": "Optimiser chargement",
        "operationId": "optimizeLoad",
        "tags": [
          "Optimize"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}