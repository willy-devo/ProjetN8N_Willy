{
  "openapi": "3.0.0",
  "info": {
    "title": "Career Guidance API",
    "version": "1.0.0",
    "x-api-id": "career-guidance-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Education",
    "x-domain": "Education",
    "description": "Orientation professionnelle. Metiers, competences et debouches."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/careers/explore": {
      "get": {
        "summary": "Explorer metiers",
        "operationId": "exploreCareerPaths",
        "tags": [
          "Explore"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Matcher profil",
        "operationId": "matchCareersToProfile",
        "tags": [
          "Explore"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/careers/{careerId}": {
      "parameters": [
        {
          "name": "careerId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Competences requises",
        "operationId": "getRequiredSkills",
        "tags": [
          "Careers"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}