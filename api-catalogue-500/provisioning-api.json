{
  "openapi": "3.0.0",
  "info": {
    "title": "Provisioning API",
    "version": "1.0.0",
    "x-api-id": "provisioning-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Telecom",
    "x-domain": "Telecom",
    "description": "Provisioning services telecom. Activation et deactivation lignes."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/provisioning/activate": {
      "post": {
        "summary": "Activer",
        "operationId": "activateService",
        "tags": [
          "Activate"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/provisioning/modify": {
      "post": {
        "summary": "Modifier",
        "operationId": "modifyService",
        "tags": [
          "Modify"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/provisioning/deactivate": {
      "post": {
        "summary": "Desactiver",
        "operationId": "deactivateService",
        "tags": [
          "Deactivate"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/provisioning/status/{requestId}": {
      "parameters": [
        {
          "name": "requestId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Statut",
        "operationId": "getProvisioningStatus",
        "tags": [
          "Status"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}