{
  "openapi": "3.0.0",
  "info": {
    "title": "Solar Panel API",
    "version": "1.0.0",
    "x-api-id": "solar-panel-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe IoT",
    "x-domain": "IoT",
    "description": "Gestion panneaux solaires photovoltaïques. Production, rendement et maintenance."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/solar-panels": {
      "get": {
        "summary": "Lister installations",
        "operationId": "listPanels",
        "tags": [
          "Panels"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Enregistrer",
        "operationId": "registerInstallation",
        "tags": [
          "Panels"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/solar-panels/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Production temps reel",
        "operationId": "getProduction",
        "tags": [
          "Panels"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/solar-panels/{id}/performance": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Rendement",
        "operationId": "getPanelPerformance",
        "tags": [
          "Performance"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}