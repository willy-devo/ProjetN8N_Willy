      "delete": {
        "summary": "Se desabonner",
        "operationId": "unsubscribeDataset",
        "tags": [
          "Subscriptions"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
