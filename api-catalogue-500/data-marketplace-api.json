{
  "openapi": "3.0.0",
  "info": {
    "title": "Data Marketplace API",
    "version": "1.0.0",
    "x-api-id": "data-marketplace-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Data",
    "x-domain": "Data",
    "description": "Marketplace interne donnees. Publication et abonnement."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
