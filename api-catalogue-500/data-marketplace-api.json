          "Datasets"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Publier",
        "operationId": "publishDataset",
        "tags": [
          "Datasets"
