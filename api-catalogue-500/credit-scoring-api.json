{
  "openapi": "3.0.0",
  "info": {
    "title": "Credit Scoring API",
    "version": "1.0.0",
    "x-api-id": "credit-scoring-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Banque",
    "x-domain": "Banking",
    "description": "Scoring credit et risque defaut. Modeles ML et notation Banque de France."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/scoring/{clientId}": {
      "parameters": [
        {
          "name": "clientId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Score credit",
        "operationId": "getScore",
        "tags": [
          "Scoring"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Demander score",
        "operationId": "requestScore",
        "tags": [
          "Scoring"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/scoring/batch": {
      "post": {
        "summary": "Scoring en masse",
        "operationId": "batchScoring",
        "tags": [
          "Batch"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}