{
  "openapi": "3.0.0",
  "info": {
    "title": "Claims Settlement API",
    "version": "1.0.0",
    "x-api-id": "claims-settlement-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Assurance",
    "x-domain": "Insurance",
    "description": "Règlement sinistres et indemnisation. Calcul, paiement et quittance."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/settlements": {
      "get": {
        "summary": "Règlements en cours",
        "operationId": "listSettlements",
        "tags": [
          "Settlements"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Initier règlement",
        "operationId": "createSettlement",
        "tags": [
          "Settlements"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/settlements/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Detail règlement",
        "operationId": "getSettlement",
        "tags": [
          "Settlements"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Payer indemnité",
        "operationId": "paySettlement",
        "tags": [
          "Settlements"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/settlements/{id}/receipt": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Quittance",
        "operationId": "getSettlementReceipt",
        "tags": [
          "Receipt"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}