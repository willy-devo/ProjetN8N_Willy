{
  "openapi": "3.0.0",
  "info": {
    "title": "Forensics API",
    "version": "1.0.0",
    "x-api-id": "forensics-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Cybersécurité",
    "x-domain": "Cybersecurity",
    "description": "Investigation numérique forensique. Analyse artefacts, mémoire et disques."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/forensics/cases": {
      "get": {
        "summary": "Dossiers forensique",
        "operationId": "listForensicCases",
        "tags": [
          "Cases"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Ouvrir dossier",
        "operationId": "createForensicCase",
        "tags": [
          "Cases"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/forensics/cases/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Detail dossier",
        "operationId": "getForensicCase",
        "tags": [
          "Cases"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Mettre a jour",
        "operationId": "updateCase",
        "tags": [
          "Cases"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/forensics/cases/{id}/artifacts": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Artefacts collectés",
        "operationId": "getArtifacts",
        "tags": [
          "Artifacts"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Ajouter artefact",
        "operationId": "addArtifact",
        "tags": [
          "Artifacts"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/forensics/cases/{id}/report": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Rapport forensique",
        "operationId": "getForensicReport",
        "tags": [
          "Report"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}