{
  "openapi": "3.0.0",
  "info": {
    "title": "Health Check API",
    "version": "1.0.0",
    "x-api-id": "health-check-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Divers",
    "x-domain": "Cross",
    "description": "Supervision etat des services. Ping, liveness, readiness et dependances."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/health": {
      "get": {
        "summary": "Etat global",
        "operationId": "getHealthStatus",
        "tags": [
          "Health"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/health/services": {
      "get": {
        "summary": "Etat services",
        "operationId": "listServiceHealth",
        "tags": [
          "Services"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Enregistrer service",
        "operationId": "registerService",
        "tags": [
          "Services"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/health/services/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Detail service",
        "operationId": "getServiceHealth",
        "tags": [
          "Services"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Lancer verification",
        "operationId": "runHealthCheck",
        "tags": [
          "Services"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}