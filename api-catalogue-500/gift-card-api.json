{
  "openapi": "3.0.0",
  "info": {
    "title": "Gift Card API",
    "version": "1.0.0",
    "x-api-id": "gift-card-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Commerce",
    "x-domain": "E-Commerce",
    "description": "Cartes cadeaux et bons d'achat. Émission, activation, utilisation et suivi du solde."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/gift-cards/issue": {
      "post": {
        "summary": "Émettre une carte cadeau",
        "operationId": "issueGiftCard",
        "tags": [
          "GiftCards"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "amount",
                  "currency"
                ],
                "properties": {
                  "amount": {
                    "type": "number"
                  },
                  "currency": {
                    "type": "string",
                    "default": "EUR"
                  },
                  "expiry_date": {
                    "type": "string",
                    "format": "date"
                  },
                  "recipient_email": {
                    "type": "string",
                    "format": "email"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Carte émise avec code unique"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/gift-cards/{code}": {
      "parameters": [
        {
          "name": "code",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Solde et validité d'une carte cadeau",
        "operationId": "getGiftCard",
        "tags": [
          "GiftCards"
        ],
        "responses": {
          "200": {
            "description": "Carte"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/gift-cards/{code}/redeem": {
      "parameters": [
        {
          "name": "code",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "post": {
        "summary": "Utiliser une carte cadeau pour payer",
        "operationId": "redeemGiftCard",
        "tags": [
          "GiftCards"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "amount",
                  "order_id"
                ],
                "properties": {
                  "amount": {
                    "type": "number"
                  },
                  "order_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Montant débité"
          },
          "400": {
            "description": "Solde insuffisant ou carte expirée"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/gift-cards/{code}/balance-history": {
      "parameters": [
        {
          "name": "code",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Historique des utilisations",
        "operationId": "getGiftCardHistory",
        "tags": [
          "GiftCards"
        ],
        "responses": {
          "200": {
            "description": "Historique"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Non autorisé",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Non trouvé",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}