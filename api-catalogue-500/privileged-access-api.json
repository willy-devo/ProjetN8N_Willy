{
  "openapi": "3.0.0",
  "info": {
    "title": "Privileged Access API",
    "version": "1.0.0",
    "x-api-id": "privileged-access-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Cybersécurité",
    "x-domain": "Cybersecurity",
    "description": "Gestion accès privilégiés PAM. Coffre-fort mots de passe, sessions et enregistrement."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/pam/credentials": {
      "get": {
        "summary": "Comptes privilégiés",
        "operationId": "listPrivilegedCredentials",
        "tags": [
          "Credentials"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Ajouter",
        "operationId": "addPrivilegedCredential",
        "tags": [
          "Credentials"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/pam/credentials/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Emprunter credential",
        "operationId": "checkoutCredential",
        "tags": [
          "Credentials"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Remettre",
        "operationId": "checkinCredential",
        "tags": [
          "Credentials"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/pam/sessions": {
      "get": {
        "summary": "Sessions privilégiées",
        "operationId": "listPAMSessions",
        "tags": [
          "Sessions"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Démarrer session",
        "operationId": "startPAMSession",
        "tags": [
          "Sessions"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/pam/recordings": {
      "get": {
        "summary": "Enregistrements",
        "operationId": "listSessionRecordings",
        "tags": [
          "Recordings"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}