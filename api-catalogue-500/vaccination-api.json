{
  "openapi": "3.0.0",
  "info": {
    "title": "Vaccination API",
    "version": "1.0.0",
    "x-api-id": "vaccination-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Santé",
    "x-domain": "Healthcare",
    "description": "Carnet de vaccination électronique. Historique vaccins, rappels et conformité aux schémas vaccinaux."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v1/vaccinations/{patientId}": {
      "parameters": [
        {
          "name": "patientId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Carnet vaccinal",
        "operationId": "getVaccinations",
        "tags": [
          "Vaccinations"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Enregistrer vaccin",
        "operationId": "addVaccination",
        "tags": [
          "Vaccinations"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/vaccinations/{patientId}/due": {
      "parameters": [
        {
          "name": "patientId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Vaccins à faire",
        "operationId": "getDueVaccinations",
        "tags": [
          "Schedule"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/vaccinations/campaigns": {
      "get": {
        "summary": "Campagnes vaccinales",
        "operationId": "listCampaigns",
        "tags": [
          "Campaigns"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Créer campagne",
        "operationId": "createCampaign",
        "tags": [
          "Campaigns"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "NotFound": {
        "description": "Ressource non trouvée"
      },
      "BadRequest": {
        "description": "Données invalides"
      },
      "Unauthorized": {
        "description": "Clé API invalide"
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}