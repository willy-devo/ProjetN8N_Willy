{
  "openapi": "3.0.0",
  "info": {
    "title": "Bancassurance API",
    "version": "1.0.0",
    "x-api-id": "bancassurance-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Assurance",
    "x-domain": "Insurance",
    "description": "Produits bancassurance. Protection emprunts et assurances adossees credits."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/bancassurance/products": {
      "get": {
        "summary": "Produits bancassurance",
        "operationId": "listBancassuranceProducts",
        "tags": [
          "Products"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/bancassurance/{loanId}/coverage": {
      "parameters": [
        {
          "name": "loanId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Couverture pret",
        "operationId": "getLoanCoverage",
        "tags": [
          "Coverage"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Souscrire ADI",
        "operationId": "subscribeLoanProtection",
        "tags": [
          "Coverage"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}