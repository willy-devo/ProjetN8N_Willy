{
  "openapi": "3.0.0",
  "info": {
    "title": "Commodity Price API",
    "version": "1.0.0",
    "x-api-id": "commodity-price-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Agriculture",
    "x-domain": "Agriculture",
    "description": "Prix matières premières agricoles. Cours marchés et historiques."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/commodities": {
      "get": {
        "summary": "Matières premières",
        "operationId": "listCommodities",
        "tags": [
          "Commodities"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/commodities/{id}/price": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Historique cours",
        "operationId": "getPriceHistory",
        "tags": [
          "Price"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/commodities/alerts": {
      "get": {
        "summary": "Alertes prix",
        "operationId": "getPriceAlerts",
        "tags": [
          "Alerts"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Créer alerte",
        "operationId": "createPriceAlert",
        "tags": [
          "Alerts"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}