            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Parametres eau",
        "operationId": "getWaterQuality",
        "tags": [
          "Water"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Ajouter analyse",
        "operationId": "addWaterAnalysis",
        "tags": [
          "Water"
