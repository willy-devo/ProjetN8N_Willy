{
  "openapi": "3.0.0",
  "info": {
    "title": "Incoming Inspection API",
    "version": "1.0.0",
    "x-api-id": "incoming-inspection-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Industrie",
    "x-domain": "Industry",
    "description": "Reception et controle entrants. Controle a reception, echantillonnage et acceptation."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/incoming/{poId}": {
      "parameters": [
        {
          "name": "poId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Controle reception",
        "operationId": "getIncomingInspection",
        "tags": [
          "Incoming"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Enregistrer",
        "operationId": "recordInspection",
        "tags": [
          "Incoming"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/incoming/{poId}/sampling": {
      "parameters": [
        {
          "name": "poId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Plan echantillonnage",
        "operationId": "getSamplingPlan",
        "tags": [
          "Sampling"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Resultat",
        "operationId": "recordSamplingResult",
        "tags": [
          "Sampling"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}