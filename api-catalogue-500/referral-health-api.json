{
  "openapi": "3.0.0",
  "info": {
    "title": "Referral Health API",
    "version": "1.0.0",
    "x-api-id": "referral-health-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Santé",
    "x-domain": "Healthcare",
    "description": "Orientations entre professionnels de santé. Consultations spécialisées et lettres de liaison. DIFFÉRENCE vs referral-api (e-commerce) : Referral Health = orientation médicale, Referral = parrainage client.",
    "x-false-positive-warning": "Parrainage commercial → referral-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v1/referrals": {
      "get": {
        "summary": "Demandes orientation",
        "operationId": "listReferrals",
        "tags": [
          "Referrals"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Créer orientation",
        "operationId": "createReferral",
        "tags": [
          "Referrals"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/referrals/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Détail",
        "operationId": "getReferral",
        "tags": [
          "Referrals"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Statut",
        "operationId": "updateStatus",
        "tags": [
          "Referrals"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/referrals/{id}/letter": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Lettre de liaison",
        "operationId": "getLetter",
        "tags": [
          "Letters"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Générer",
        "operationId": "generateLetter",
        "tags": [
          "Letters"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "NotFound": {
        "description": "Ressource non trouvée"
      },
      "BadRequest": {
        "description": "Données invalides"
      },
      "Unauthorized": {
        "description": "Clé API invalide"
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}