{
  "openapi": "3.0.0",
  "info": {
    "title": "Property Management API",
    "version": "1.0.0",
    "x-api-id": "property-management-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Immobilier",
    "x-domain": "RealEstate",
    "description": "Gestion portefeuille immobilier. Vue consolidee, reporting et KPIs. DIFFERENCE vs property-api : Property Management = vue portefeuille multi-biens, Property = fiche d'un seul bien.",
