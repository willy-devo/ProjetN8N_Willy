{
  "openapi": "3.0.0",
  "info": {
    "title": "Room Booking API",
    "version": "3.0.0",
    "x-api-id": "room-booking-api-v3",
    "x-api-version": "v3",
    "x-status": "active",
    "x-team": "Equipe Tourisme",
    "x-domain": "Tourism",
    "description": "Réservation chambres avec garanties et politiques annulation. DIFFERENCE vs amenity-booking-api : Room Booking = chambre d'hôtel, Amenity Booking = équipements résidentiels partagés.",
