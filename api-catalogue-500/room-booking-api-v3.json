        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Modifier",
        "operationId": "modifyBooking",
        "tags": [
          "Bookings"
        ],
        "responses": {
          "200": {
            "description": "OK"
