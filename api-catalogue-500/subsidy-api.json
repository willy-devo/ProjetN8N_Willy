{
  "openapi": "3.0.0",
  "info": {
    "title": "Subsidy API",
    "version": "1.0.0",
    "x-api-id": "subsidy-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Agriculture",
    "x-domain": "Agriculture",
    "description": "Aides et subventions agricoles. PAC, MSA et dossiers."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/subsidies": {
      "get": {
        "summary": "Aides disponibles",
        "operationId": "listAvailableSubsidies",
        "tags": [
          "Subsidies"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/subsidies/{farmId}": {
      "parameters": [
        {
          "name": "farmId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Aides exploitation",
        "operationId": "getFarmSubsidies",
        "tags": [
          "Subsidies"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Demander aide",
        "operationId": "applySubsidy",
        "tags": [
          "Subsidies"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/subsidies/applications/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Statut dossier",
        "operationId": "getSubsidyApplication",
        "tags": [
          "Applications"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Mettre a jour",
        "operationId": "updateApplication",
        "tags": [
          "Applications"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}