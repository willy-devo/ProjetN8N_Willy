{
  "openapi": "3.0.0",
  "info": {
    "title": "Housekeeping API",
    "version": "1.0.0",
    "x-api-id": "housekeeping-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Tourisme",
    "x-domain": "Tourism",
    "description": "Gestion ménage hôtelier. Planning, priorités et statut chambres."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/housekeeping/{hotelId}": {
      "parameters": [
        {
          "name": "hotelId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Plan ménage",
        "operationId": "getHousekeepingPlan",
        "tags": [
          "Housekeeping"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Créer tâche",
        "operationId": "createHousekeepingTask",
        "tags": [
          "Housekeeping"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/housekeeping/rooms/{roomId}": {
      "parameters": [
        {
          "name": "roomId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Statut chambre",
        "operationId": "getRoomStatus",
        "tags": [
          "Rooms"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Changer statut",
        "operationId": "updateRoomStatus",
        "tags": [
          "Rooms"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/housekeeping/staff": {
      "get": {
        "summary": "Equipe ménage",
        "operationId": "getHousekeepingStaff",
        "tags": [
          "Staff"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}