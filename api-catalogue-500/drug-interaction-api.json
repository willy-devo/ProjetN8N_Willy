{
  "openapi": "3.0.0",
  "info": {
    "title": "Drug Interaction API",
    "version": "1.0.0",
    "x-api-id": "drug-interaction-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Santé",
    "x-domain": "Healthcare",
    "description": "Vérification interactions médicamenteuses et contre-indications. DIFFÉRENCE vs prescription-api : Drug Interaction = vérification sécurité avant prescription, Prescription = document légal de dispensation.",
    "x-false-positive-warning": "Ordonnance légale → prescription-api-v2."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v1/interactions/check": {
      "post": {
        "summary": "Vérifier interactions",
        "operationId": "checkInteractions",
        "tags": [
          "Interactions"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/interactions/{drugId}": {
      "parameters": [
        {
          "name": "drugId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Interactions d'un médicament",
        "operationId": "getDrugInteractions",
        "tags": [
          "Drugs"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/contraindications/check": {
      "post": {
        "summary": "Vérifier contre-indications",
        "operationId": "checkContraindications",
        "tags": [
          "Contraindications"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "NotFound": {
        "description": "Ressource non trouvée"
      },
      "BadRequest": {
        "description": "Données invalides"
      },
      "Unauthorized": {
        "description": "Clé API invalide"
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}