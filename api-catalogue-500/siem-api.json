{
  "openapi": "3.0.0",
  "info": {
    "title": "SIEM API",
    "version": "1.0.0",
    "x-api-id": "siem-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Cybersécurité",
    "x-domain": "Cybersecurity",
    "description": "Security Information and Event Management. Collecte logs, corrélation et alertes."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/siem/events": {
      "get": {
        "summary": "Événements sécurité",
        "operationId": "listSecurityEvents",
        "tags": [
          "Events"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Ingérer événement",
        "operationId": "ingestEvent",
        "tags": [
          "Events"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/siem/rules": {
      "get": {
        "summary": "Règles corrélation",
        "operationId": "listCorrelationRules",
        "tags": [
          "Rules"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Ajouter règle",
        "operationId": "addCorrelationRule",
        "tags": [
          "Rules"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/siem/alerts": {
      "get": {
        "summary": "Alertes SIEM",
        "operationId": "getSIEMAlerts",
        "tags": [
          "Alerts"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Résoudre alerte",
        "operationId": "resolveSIEMAlert",
        "tags": [
          "Alerts"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/siem/dashboards": {
      "get": {
        "summary": "Tableau de bord",
        "operationId": "getSecurityDashboard",
        "tags": [
          "Dashboards"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}