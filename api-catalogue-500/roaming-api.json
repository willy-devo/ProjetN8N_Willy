        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "delete": {
        "summary": "Desactiver",
        "operationId": "deactivateRoaming",
        "tags": [
          "Roaming"
