{
  "openapi": "3.0.0",
  "info": {
    "title": "Travel Package API",
    "version": "1.0.0",
    "x-api-id": "travel-package-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Tourisme",
    "x-domain": "Tourism",
    "description": "Forfaits voyage. Séjours tout inclus, circuits et personnalisation.",
    "x-false-positive-warning": "Réservation chambre seule -> room-booking-api-v3."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/packages": {
      "get": {
        "summary": "Forfaits disponibles",
        "operationId": "listTravelPackages",
        "tags": [
          "Packages"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Créer forfait",
        "operationId": "createPackage",
        "tags": [
          "Packages"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/packages/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Detail forfait",
        "operationId": "getPackage",
        "tags": [
          "Packages"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Modifier",
        "operationId": "updatePackage",
        "tags": [
          "Packages"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/packages/{id}/book": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "post": {
        "summary": "Réserver forfait",
        "operationId": "bookPackage",
        "tags": [
          "Book"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "get": {
        "summary": "Disponibilité",
        "operationId": "getPackageAvailability",
        "tags": [
          "Book"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}