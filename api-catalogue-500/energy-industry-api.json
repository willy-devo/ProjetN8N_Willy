{
  "openapi": "3.0.0",
  "info": {
    "title": "Energy Industry API",
    "version": "1.0.0",
    "x-api-id": "energy-industry-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Industrie",
    "x-domain": "Industry",
    "description": "Energie process industriels. Consommation par machine et optimisation. DIFFERENCE vs energy-consumption-api : Energy Industry = energie machines de production, Energy Consumption = batiments et installations.",
    "x-false-positive-warning": "Batiments -> energy-consumption-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/energy-industry/{machineId}": {
      "parameters": [
        {
          "name": "machineId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Energie par piece",
        "operationId": "getEnergyPerPart",
        "tags": [
          "Energy"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/energy-industry/site": {
      "get": {
        "summary": "Recommandations optimisation",
        "operationId": "getEnergyOptimization",
        "tags": [
          "Site"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}