{
  "openapi": "3.0.0",
  "info": {
    "title": "Accessibility API",
    "version": "1.0.0",
    "x-api-id": "accessibility-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Platform",
    "x-domain": "Infrastructure",
    "description": "Accessibilité numérique. Analyse WCAG, génération de descriptions alt-text et vérification de contrastes."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/accessibility/analyze": {
      "post": {
        "summary": "Analyser l'accessibilité d'une page web",
        "operationId": "analyzeAccessibility",
        "tags": [
          "Accessibility"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "url"
                ],
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri"
                  },
                  "standard": {
                    "type": "string",
                    "enum": [
                      "WCAG_2.0_AA",
                      "WCAG_2.1_AA",
                      "WCAG_2.2_AA"
                    ],
                    "default": "WCAG_2.1_AA"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Rapport d'accessibilité avec violations"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/accessibility/alt-text": {
      "post": {
        "summary": "Générer du texte alternatif pour une image (IA)",
        "operationId": "generateAltText",
        "tags": [
          "Accessibility"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "image_url"
                ],
                "properties": {
                  "image_url": {
                    "type": "string",
                    "format": "uri"
                  },
                  "language": {
                    "type": "string",
                    "default": "fr"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Alt-text généré"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/accessibility/contrast": {
      "post": {
        "summary": "Vérifier le ratio de contraste couleur (WCAG)",
        "operationId": "checkContrast",
        "tags": [
          "Accessibility"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "foreground",
                  "background"
                ],
                "properties": {
                  "foreground": {
                    "type": "string",
                    "example": "#FFFFFF"
                  },
                  "background": {
                    "type": "string",
                    "example": "#007AFF"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ratio de contraste et conformité WCAG"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Non autorisé",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Non trouvé",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}