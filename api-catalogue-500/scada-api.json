{
  "openapi": "3.0.0",
  "info": {
    "title": "SCADA API",
    "version": "1.0.0",
    "x-api-id": "scada-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Industrie",
    "x-domain": "Industry",
    "description": "SCADA supervision industrielle. Acquisition donnees terrain et telecommande."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/scada/tags": {
      "get": {
        "summary": "Tags SCADA",
        "operationId": "listSCADATags",
        "tags": [
          "Tags"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Ajouter tag",
        "operationId": "addTag",
        "tags": [
          "Tags"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/scada/tags/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Valeur temps reel",
        "operationId": "getTagValue",
        "tags": [
          "Tags"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Ecrire valeur",
        "operationId": "writeTagValue",
        "tags": [
          "Tags"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/scada/alarms": {
      "get": {
        "summary": "Alarmes actives",
        "operationId": "getActiveAlarms",
        "tags": [
          "Alarms"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Effacer",
        "operationId": "clearAlarm",
        "tags": [
          "Alarms"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/scada/historian": {
      "post": {
        "summary": "Interroger historique",
        "operationId": "queryHistorian",
        "tags": [
          "Historian"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}