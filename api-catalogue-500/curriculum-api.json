{
  "openapi": "3.0.0",
  "info": {
    "title": "Curriculum API",
    "version": "1.0.0",
    "x-api-id": "curriculum-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Education",
    "x-domain": "Education",
