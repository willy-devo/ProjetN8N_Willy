{
  "openapi": "3.0.0",
  "info": {
    "title": "MRP API",
    "version": "1.0.0",
    "x-api-id": "mrp-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Industrie",
    "x-domain": "Industry",
    "description": "Material Requirements Planning. Calcul besoins, suggestions et lancement. DIFFERENCE vs inventory-api : MRP = calcul besoins futurs selon planification, Inventory = stock physique actuel.",
    "x-false-positive-warning": "Stock physique -> inventory-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/mrp/calculate": {
      "post": {
        "summary": "Calculer besoins MRP",
        "operationId": "runMRP",
        "tags": [
          "MRP"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/mrp/suggestions": {
      "get": {
        "summary": "Suggestions approvisionnement",
        "operationId": "getMRPSuggestions",
        "tags": [
          "Suggestions"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Accepter suggestion",
        "operationId": "acceptSuggestion",
        "tags": [
          "Suggestions"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/mrp/plan/{productId}": {
      "parameters": [
        {
          "name": "productId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Plan de production",
        "operationId": "getProductionPlan",
        "tags": [
          "Plan"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}