{
  "openapi": "3.0.0",
  "info": {
    "title": "Billing API",
    "version": "2.0.0",
    "x-api-id": "billing-api-v2",
    "x-api-version": "v2",
    "x-status": "active",
    "x-team": "Equipe Finance",
    "x-domain": "Finance",
    "description": "Version 2 de l'API facturation. Métered billing (usage-based), taxes automatiques et portail self-service. DIFFÉRENCE vs v1 : ajout facturation à l'usage, taxes auto via tax-api et portail client.",
    "x-breaking-changes-from-previous": [
      "Métered billing (usage-based)",
      "Taxes automatiques via tax-api",
      "Portail self-service client",
      "Gestion des crédits/avoirs automatique"
    ]
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v2/billing/subscriptions": {
      "post": {
        "summary": "Créer abonnement avec billing au usage",
        "operationId": "createBillingSubV2",
        "tags": [
          "Subscriptions"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "customer_id",
                  "plan_id"
                ],
                "properties": {
                  "customer_id": {
                    "type": "string"
                  },
                  "plan_id": {
                    "type": "string"
                  },
                  "billing_mode": {
                    "type": "string",
                    "enum": [
                      "flat",
                      "metered",
                      "hybrid"
                    ],
                    "default": "flat"
                  },
                  "trial_days": {
                    "type": "integer",
                    "default": 0
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Créé"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v2/billing/usage": {
      "post": {
        "summary": "Reporter la consommation (métered billing)",
        "operationId": "reportUsage",
        "tags": [
          "Usage"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "subscription_id",
                  "quantity",
                  "metric"
                ],
                "properties": {
                  "subscription_id": {
                    "type": "string"
                  },
                  "quantity": {
                    "type": "number"
                  },
                  "metric": {
                    "type": "string",
                    "example": "api_calls"
                  },
                  "timestamp": {
                    "type": "string",
                    "format": "date-time"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Consommation enregistrée"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v2/billing/portal/{customerId}": {
      "parameters": [
        {
          "name": "customerId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "post": {
        "summary": "Générer un lien vers le portail self-service client",
        "operationId": "getBillingPortal",
        "tags": [
          "Portal"
        ],
        "responses": {
          "200": {
            "description": "URL du portail (valable 24h)"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Non autorisé",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Non trouvé",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}