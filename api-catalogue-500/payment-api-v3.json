{
  "openapi": "3.0.0",
  "info": {
    "title": "Payment API",
    "version": "3.0.0",
    "x-api-id": "payment-api-v3",
    "x-api-version": "v3",
    "x-status": "active",
    "x-team": "Equipe Finance",
    "x-domain": "Finance",
    "description": "Version 3 Payment. Paiements crypto, paiement en plusieurs fois (BNPL) et réconciliation bancaire automatique. DIFFÉRENCE vs v2 : ajout BNPL (Klarna/Alma), crypto (BTC/ETH), réconciliation.",
    "x-breaking-changes-from-previous": [
      "BNPL (paiement en 3x/4x)",
      "Cryptomonnaies: BTC, ETH, USDC",
      "Réconciliation bancaire automatique",
      "Dispute management (chargebacks)"
    ]
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v3/payments": {
      "post": {
        "summary": "Initier un paiement (card/paypal/sepa/bnpl/crypto)",
        "operationId": "createPaymentV3",
        "tags": [
          "Payments"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "amount",
                  "currency",
                  "method",
                  "order_id"
                ],
                "properties": {
                  "amount": {
                    "type": "number"
                  },
                  "currency": {
                    "type": "string"
                  },
                  "method": {
                    "type": "string",
                    "enum": [
                      "card",
                      "paypal",
                      "sepa",
                      "wallet",
                      "bnpl",
                      "bitcoin",
                      "ethereum",
                      "usdc"
                    ]
                  },
                  "installments": {
                    "type": "integer",
                    "description": "Pour BNPL: 3 ou 4",
                    "enum": [
                      3,
                      4
                    ]
                  },
                  "order_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Initié"
          },
          "402": {
            "description": "Refusé"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v3/payments/{id}/dispute": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "post": {
        "summary": "Contester un paiement (chargeback)",
        "operationId": "disputePayment",
        "tags": [
          "Disputes"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "reason"
                ],
                "properties": {
                  "reason": {
                    "type": "string",
                    "enum": [
                      "unauthorized",
                      "not_received",
                      "defective",
                      "duplicate"
                    ]
                  },
                  "evidence": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "uri"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Dispute ouverte"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v3/payments/reconciliation": {
      "post": {
        "summary": "Lancer la réconciliation bancaire",
        "operationId": "reconcilePayments",
        "tags": [
          "Reconciliation"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "period"
                ],
                "properties": {
                  "period": {
                    "type": "string",
                    "example": "2026-04"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Réconciliation lancée"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Non autorisé",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Non trouvé",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}