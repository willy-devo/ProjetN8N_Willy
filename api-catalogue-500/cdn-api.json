{
  "openapi": "3.0.0",
  "info": {
    "title": "CDN API",
    "version": "1.0.0",
    "x-api-id": "cdn-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Platform",
    "x-domain": "Infrastructure",
    "description": "Gestion du Content Delivery Network. Purge, règles de cache et statistiques."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v1/cdn/purge": {
      "post": {
        "summary": "Purger des URLs ou préfixes du CDN",
        "operationId": "purgeCDN",
        "tags": [
          "CDN"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "urls": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "uri"
                    }
                  },
                  "prefix": {
                    "type": "string",
                    "description": "Purge tout le contenu sous ce préfixe"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Purge planifiée"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/cdn/stats": {
      "get": {
        "summary": "Statistiques CDN (hit rate, bande passante)",
        "operationId": "getCDNStats",
        "tags": [
          "CDN"
        ],
        "parameters": [
          {
            "name": "period",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "24h"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Stats"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/cdn/rules": {
      "get": {
        "summary": "Règles de cache CDN",
        "operationId": "getCDNRules",
        "tags": [
          "CDN"
        ],
        "responses": {
          "200": {
            "description": "Règles"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Créer une règle de cache",
        "operationId": "createCDNRule",
        "tags": [
          "CDN"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "path_pattern",
                  "ttl"
                ],
                "properties": {
                  "path_pattern": {
                    "type": "string",
                    "example": "/images/*"
                  },
                  "ttl": {
                    "type": "integer",
                    "description": "TTL en secondes"
                  },
                  "browser_cache_ttl": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Règle créée"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Clé API invalide",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Ressource non trouvée",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit d'état",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Clé API Kong Gateway — contacter votre équipe platform"
      }
    }
  }
}