{
  "openapi": "3.0.0",
  "info": {
    "title": "Session API",
    "version": "1.0.0",
    "x-api-id": "session-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Identity",
    "x-domain": "Identity & Access",
    "description": "Gestion des sessions actives. Liste, révocation et détection de sessions suspectes. DIFFÉRENCE vs auth-api : Session API consulte et révoque les sessions existantes, Auth API les crée.",
    "x-false-positive-warning": "Création de session → auth-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/sessions/{userId}": {
      "parameters": [
        {
          "name": "userId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Sessions actives d'un utilisateur",
        "operationId": "getUserSessions",
        "tags": [
          "Sessions"
        ],
        "responses": {
          "200": {
            "description": "Sessions"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/sessions/{sessionId}": {
      "parameters": [
        {
          "name": "sessionId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "delete": {
        "summary": "Révoquer une session spécifique",
        "operationId": "revokeSession",
        "tags": [
          "Sessions"
        ],
        "responses": {
          "204": {
            "description": "Révoquée"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/sessions/{userId}/revoke-all": {
      "parameters": [
        {
          "name": "userId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "delete": {
        "summary": "Révoquer toutes les sessions (déconnexion totale)",
        "operationId": "revokeAllSessions",
        "tags": [
          "Sessions"
        ],
        "responses": {
          "204": {
            "description": "Toutes révoquées"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/sessions/suspicious": {
      "get": {
        "summary": "Sessions suspectes détectées (géoloc inhabituelle, IP blacklistée)",
        "operationId": "getSuspiciousSessions",
        "tags": [
          "Security"
        ],
        "responses": {
          "200": {
            "description": "Sessions suspectes"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Non autorisé",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Non trouvé",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}