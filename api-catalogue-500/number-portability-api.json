{
  "openapi": "3.0.0",
  "info": {
    "title": "Number Portability API",
    "version": "1.0.0",
    "x-api-id": "number-portability-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Telecom",
    "x-domain": "Telecom",
    "description": "Portabilite numeros entre operateurs. Demandes, statuts et delais."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/portability/requests": {
      "get": {
        "summary": "Demandes",
        "operationId": "listPortabilityRequests",
        "tags": [
          "Requests"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Soumettre",
        "operationId": "submitPortabilityRequest",
        "tags": [
          "Requests"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/portability/requests/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Statut",
        "operationId": "getPortabilityRequest",
        "tags": [
          "Requests"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "delete": {
        "summary": "Annuler",
        "operationId": "cancelPortabilityRequest",
        "tags": [
          "Requests"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}