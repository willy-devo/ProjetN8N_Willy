{
  "openapi": "3.0.0",
  "info": {
    "title": "Comment API",
    "version": "1.0.0",
    "x-api-id": "comment-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Platform",
    "x-domain": "Operations",
    "description": "Commentaires et annotations sur des ressources internes (tickets, tâches, documents, contrats). Fils de discussion, mentions et réactions. DIFFÉRENCE vs review-api : Comment = annotation interne collaborative sur une ressource (ticket, doc), Review = avis public client sur un produit. DIFFÉRENCE vs messaging-api : Comment est ancré à une ressource spécifique (discussion contextualisée), Messaging est une conversation libre entre utilisateurs.",
    "x-false-positive-warning": "Avis public client sur produit → review-api. Chat libre entre utilisateurs → messaging-api. Annotation sur tâche ou doc interne → comment-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v1/comments": {
      "post": {
        "summary": "Ajouter un commentaire sur une ressource",
        "operationId": "createComment",
        "tags": [
          "Comments"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CommentCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Commentaire ajouté"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/comments/{resourceType}/{resourceId}": {
      "parameters": [
        {
          "name": "resourceType",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "enum": [
              "ticket",
              "task",
              "document",
              "contract",
              "order"
            ]
          }
        },
        {
          "name": "resourceId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Commentaires d'une ressource",
        "operationId": "getResourceComments",
        "tags": [
          "Comments"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Commentaires"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/comments/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "put": {
        "summary": "Modifier un commentaire (auteur uniquement)",
        "operationId": "updateComment",
        "tags": [
          "Comments"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "content"
                ],
                "properties": {
                  "content": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Modifié"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "delete": {
        "summary": "Supprimer un commentaire",
        "operationId": "deleteComment",
        "tags": [
          "Comments"
        ],
        "responses": {
          "204": {
            "description": "Supprimé"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/comments/{id}/reactions": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "post": {
        "summary": "Ajouter une réaction (👍, ✅, 🚀...)",
        "operationId": "addReaction",
        "tags": [
          "Reactions"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "emoji"
                ],
                "properties": {
                  "emoji": {
                    "type": "string",
                    "example": "👍"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Réaction ajoutée"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "delete": {
        "summary": "Retirer sa réaction",
        "operationId": "removeReaction",
        "tags": [
          "Reactions"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "emoji"
                ],
                "properties": {
                  "emoji": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Retirée"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/comments/{id}/resolve": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "put": {
        "summary": "Résoudre un thread de commentaires",
        "operationId": "resolveComment",
        "tags": [
          "Comments"
        ],
        "responses": {
          "200": {
            "description": "Thread résolu"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "CommentCreate": {
        "type": "object",
        "required": [
          "resource_type",
          "resource_id",
          "content",
          "author_id"
        ],
        "properties": {
          "resource_type": {
            "type": "string",
            "enum": [
              "ticket",
              "task",
              "document",
              "contract",
              "order"
            ]
          },
          "resource_id": {
            "type": "string"
          },
          "content": {
            "type": "string",
            "maxLength": 5000
          },
          "author_id": {
            "type": "string"
          },
          "parent_id": {
            "type": "string",
            "description": "ID du commentaire parent pour répondre en fil"
          },
          "mentions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "IDs des utilisateurs mentionnés (@mention)"
          },
          "internal": {
            "type": "boolean",
            "default": false,
            "description": "Si true: visible agents/équipes uniquement"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "NOT_FOUND"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Clé API invalide",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Ressource non trouvée",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit d'état",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Clé API Kong Gateway — Devoteam nexDigital"
      }
    }
  }
}