{
  "openapi": "3.0.0",
  "info": {
    "title": "Contact Form API",
    "version": "1.0.0",
    "x-api-id": "contact-form-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Support",
    "x-domain": "Customer Support",
    "description": "Formulaires de contact web et mobile. Réception, routing et conversion en tickets. DIFFÉRENCE vs ticket-api : Contact Form = point d'entrée côté client (formulaire), Ticket API = gestion interne des demandes (backoffice).",
    "x-false-positive-warning": "Gestion interne des tickets → ticket-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v1/contact/submit": {
      "post": {
        "summary": "Soumettre un formulaire de contact",
        "operationId": "submitContactForm",
        "tags": [
          "Contact"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ContactFormSubmit"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Reçu — ticket créé automatiquement"
          }
        },
        "security": []
      }
    },
    "/v1/contact/forms": {
      "get": {
        "summary": "Lister les formulaires configurés",
        "operationId": "listForms",
        "tags": [
          "Forms"
        ],
        "responses": {
          "200": {
            "description": "Formulaires"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Créer un formulaire de contact",
        "operationId": "createForm",
        "tags": [
          "Forms"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "fields"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "fields": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    }
                  },
                  "auto_create_ticket": {
                    "type": "boolean",
                    "default": true
                  },
                  "routing_rules": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Formulaire créé"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "ContactFormSubmit": {
        "type": "object",
        "required": [
          "name",
          "email",
          "message"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "subject": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "attachments": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uri"
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Clé API invalide",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Ressource non trouvée",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit d'état",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Clé API Kong Gateway — contacter votre équipe platform"
      }
    }
  }
}