{
  "openapi": "3.0.0",
  "info": {
    "title": "Stock Reservation API",
    "version": "1.0.0",
    "x-api-id": "stock-reservation-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Logistique",
    "x-domain": "Supply Chain",
    "description": "Réservation temporaire de stock lors du checkout. DIFFÉRENCE vs inventory-api : Stock Reservation = verrouillage temporaire (pendant la session panier), Inventory = stocks globaux et historique mouvements. Évite les surventes.",
    "x-false-positive-warning": "Stocks globaux → inventory-api. Gestion entrepôts → warehouse-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v1/stock/reserve": {
      "post": {
        "summary": "Réserver du stock temporairement (TTL 15 min)",
        "operationId": "reserveStock",
        "tags": [
          "Reservations"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StockReservationCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Stock réservé"
          },
          "409": {
            "description": "Stock insuffisant"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/stock/reservations/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Statut d'une réservation",
        "operationId": "getReservation",
        "tags": [
          "Reservations"
        ],
        "responses": {
          "200": {
            "description": "Réservation"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "delete": {
        "summary": "Libérer la réservation",
        "operationId": "releaseReservation",
        "tags": [
          "Reservations"
        ],
        "responses": {
          "204": {
            "description": "Libérée"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/stock/confirm/{reservationId}": {
      "parameters": [
        {
          "name": "reservationId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "post": {
        "summary": "Confirmer la réservation (stock déduit définitivement)",
        "operationId": "confirmReservation",
        "tags": [
          "Reservations"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "order_id"
                ],
                "properties": {
                  "order_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Confirmée — stock déduit"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "StockReservationCreate": {
        "type": "object",
        "required": [
          "items",
          "session_id"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "product_id",
                "quantity"
              ],
              "properties": {
                "product_id": {
                  "type": "string"
                },
                "quantity": {
                  "type": "integer",
                  "minimum": 1
                }
              }
            }
          },
          "session_id": {
            "type": "string"
          },
          "ttl_minutes": {
            "type": "integer",
            "default": 15,
            "description": "Durée de réservation avant libération automatique"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Clé API invalide",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Ressource non trouvée",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit d'état",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Clé API Kong Gateway — contacter votre équipe platform"
      }
    }
  }
}