{
  "openapi": "3.0.0",
  "info": {
    "title": "Amenity Booking API",
    "version": "1.0.0",
    "x-api-id": "amenity-booking-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Immobilier",
    "x-domain": "RealEstate",
    "description": "Réservation équipements partagés. Salles de réunion, parking, buanderie. DIFFERENCE vs meeting-room-api : Amenity Booking = équipements résidentiels, Meeting Room = salles de réunion professionnelles.",
    "x-false-positive-warning": "Salles de réunion pro -> meeting-room-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/amenities": {
      "get": {
        "summary": "Equipements disponibles",
        "operationId": "listAmenities",
        "tags": [
          "Amenities"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/amenities/{id}/bookings": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Réservations",
        "operationId": "getBookings",
        "tags": [
          "Bookings"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Réserver",
        "operationId": "bookAmenity",
        "tags": [
          "Bookings"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/amenities/{id}/bookings/{bookingId}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        },
        {
          "name": "bookingId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "delete": {
        "summary": "Annuler",
        "operationId": "cancelBooking",
        "tags": [
          "Bookings"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}