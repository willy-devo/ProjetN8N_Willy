{
  "openapi": "3.0.0",
  "info": {
    "title": "Reinsurance API",
    "version": "1.0.0",
    "x-api-id": "reinsurance-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Assurance",
    "x-domain": "Insurance",
    "description": "Réassurance et cession de risques. Traités, facultatives et sinistres réassureurs."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway"
    }
  ],
  "paths": {
    "/v1/reinsurance/treaties": {
      "get": {
        "summary": "Traités de réassurance",
        "operationId": "listTreaties",
        "tags": [
          "Treaties"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Créer traité",
        "operationId": "createTreaty",
        "tags": [
          "Treaties"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/reinsurance/treaties/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Detail traité",
        "operationId": "getTreaty",
        "tags": [
          "Treaties"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "put": {
        "summary": "Modifier",
        "operationId": "updateTreaty",
        "tags": [
          "Treaties"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/reinsurance/claims": {
      "get": {
        "summary": "Sinistres cédés",
        "operationId": "listReinsuranceClaims",
        "tags": [
          "Claims"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "summary": "Céder sinistre",
        "operationId": "cessionClaim",
        "tags": [
          "Claims"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}