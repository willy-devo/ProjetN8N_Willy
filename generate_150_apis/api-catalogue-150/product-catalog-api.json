{
  "id": "product-catalog-api",
  "name": "Product Catalog API",
  "version": "v2",
  "description": "Gestion du catalogue produits. CRUD complet sur les produits, catégories et attributs. Faux positif avec Search API — Catalog gère les données, Search les interroge.",
  "team": "Equipe Catalog",
  "authentication": "Bearer Token JWT",
  "base_url": "/v2/product-catalog",
  "endpoints": [
    {
      "method": "GET",
      "path": "/v2/products"
    },
    {
      "method": "POST",
      "path": "/v2/products"
    },
    {
      "method": "GET",
      "path": "/v2/products/{id}"
    },
    {
      "method": "PUT",
      "path": "/v2/products/{id}"
    },
    {
      "method": "DELETE",
      "path": "/v2/products/{id}"
    },
    {
      "method": "GET",
      "path": "/v2/categories"
    }
  ],
  "tags": [
    "catalog",
    "v2"
  ]
}