{
  "id": "reporting-api",
  "name": "Reporting API",
  "version": "v1",
  "description": "Génération de rapports personnalisés et exports. PDF, Excel et tableaux de bord planifiés. Faux positif avec Analytics API — Reporting génère des documents, Analytics agrège des métriques.",
  "team": "Equipe Data",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/reporting",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/reports/generate"
    },
    {
      "method": "GET",
      "path": "/v1/reports/{id}"
    },
    {
      "method": "GET",
      "path": "/v1/reports/{id}/download"
    },
    {
      "method": "POST",
      "path": "/v1/reports/schedule"
    },
    {
      "method": "GET",
      "path": "/v1/reports/templates"
    }
  ],
  "tags": [
    "data",
    "v1"
  ]
}