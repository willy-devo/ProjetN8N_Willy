{
  "id": "billing-api",
  "name": "Billing API",
  "version": "v1",
  "description": "Gestion de la facturation et des abonnements récurrents. Cycles de facturation, relances et impayés. Faux positif avec Payment API — Billing gère les cycles, Payment les transactions.",
  "team": "Equipe Finance",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/billing",
  "endpoints": [
    {
      "method": "GET",
      "path": "/v1/billing/subscriptions/{customerId}"
    },
    {
      "method": "POST",
      "path": "/v1/billing/subscriptions"
    },
    {
      "method": "PUT",
      "path": "/v1/billing/subscriptions/{id}/cancel"
    },
    {
      "method": "GET",
      "path": "/v1/billing/invoices/{customerId}"
    },
    {
      "method": "POST",
      "path": "/v1/billing/retry/{invoiceId}"
    }
  ],
  "tags": [
    "finance",
    "v1"
  ]
}