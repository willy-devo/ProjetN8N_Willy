{
  "id": "sms-api",
  "name": "SMS API",
  "version": "v1",
  "description": "Envoi de SMS transactionnels et OTP. Gestion des numéros courts et tracking des livraisons. Faux positif avec Notification API — SMS API se spécialise sur la messagerie SMS.",
  "team": "Equipe Platform",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/sms",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/sms/send"
    },
    {
      "method": "POST",
      "path": "/v1/sms/otp/send"
    },
    {
      "method": "POST",
      "path": "/v1/sms/otp/verify"
    },
    {
      "method": "GET",
      "path": "/v1/sms/{id}/status"
    }
  ],
  "tags": [
    "platform",
    "v1"
  ]
}