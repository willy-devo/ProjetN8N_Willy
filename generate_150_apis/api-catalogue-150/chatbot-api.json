{
  "id": "chatbot-api",
  "name": "Chatbot API",
  "version": "v1",
  "description": "Chatbot de support automatisé. Réponses FAQ, escalade vers humain et historique des conversations.",
  "team": "Equipe Support",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/chatbot",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/chatbot/message"
    },
    {
      "method": "GET",
      "path": "/v1/chatbot/sessions/{sessionId}"
    },
    {
      "method": "POST",
      "path": "/v1/chatbot/escalate"
    },
    {
      "method": "GET",
      "path": "/v1/chatbot/intents"
    }
  ],
  "tags": [
    "support",
    "v1"
  ]
}