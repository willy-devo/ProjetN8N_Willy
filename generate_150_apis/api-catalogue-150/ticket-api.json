{
  "id": "ticket-api",
  "name": "Ticket API",
  "version": "v1",
  "description": "Gestion des tickets de support client. Création, assignation, escalade et résolution des incidents.",
  "team": "Equipe Support",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/ticket",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/tickets"
    },
    {
      "method": "GET",
      "path": "/v1/tickets/{id}"
    },
    {
      "method": "PUT",
      "path": "/v1/tickets/{id}/assign"
    },
    {
      "method": "PUT",
      "path": "/v1/tickets/{id}/escalate"
    },
    {
      "method": "PUT",
      "path": "/v1/tickets/{id}/close"
    },
    {
      "method": "POST",
      "path": "/v1/tickets/{id}/comments"
    }
  ],
  "tags": [
    "support",
    "v1"
  ]
}