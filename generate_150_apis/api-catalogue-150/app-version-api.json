{
  "id": "app-version-api",
  "name": "App Version API",
  "version": "v1",
  "description": "Gestion des versions de l'application mobile. Vérification des mises à jour et notes de version.",
  "team": "Equipe Mobile",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/app-version",
  "endpoints": [
    {
      "method": "GET",
      "path": "/v1/app/version/latest"
    },
    {
      "method": "POST",
      "path": "/v1/app/version/check"
    },
    {
      "method": "GET",
      "path": "/v1/app/version/{version}/changelog"
    },
    {
      "method": "GET",
      "path": "/v1/app/version/force-update"
    }
  ],
  "tags": [
    "mobile",
    "v1"
  ]
}