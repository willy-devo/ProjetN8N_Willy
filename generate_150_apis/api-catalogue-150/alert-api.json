{
  "id": "alert-api",
  "name": "Alert API",
  "version": "v1",
  "description": "Alertes système et monitoring. Notifications d'incidents, pannes et seuils dépassés. Faux positif avec Notification API — Alert cible les équipes techniques, Notification les clients.",
  "team": "Equipe Platform",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/alert",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/alerts"
    },
    {
      "method": "GET",
      "path": "/v1/alerts?status=active"
    },
    {
      "method": "PUT",
      "path": "/v1/alerts/{id}/acknowledge"
    },
    {
      "method": "PUT",
      "path": "/v1/alerts/{id}/resolve"
    },
    {
      "method": "GET",
      "path": "/v1/alerts/rules"
    }
  ],
  "tags": [
    "platform",
    "v1"
  ]
}