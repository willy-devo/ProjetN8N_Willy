{
  "id": "integration-api",
  "name": "Integration API",
  "version": "v1",
  "description": "Connecteurs vers systèmes tiers. ERP, CRM externes, marketplaces et plateformes partenaires.",
  "team": "Equipe Platform",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/integration",
  "endpoints": [
    {
      "method": "GET",
      "path": "/v1/integrations"
    },
    {
      "method": "POST",
      "path": "/v1/integrations/{name}/connect"
    },
    {
      "method": "DELETE",
      "path": "/v1/integrations/{name}/disconnect"
    },
    {
      "method": "GET",
      "path": "/v1/integrations/{name}/sync"
    },
    {
      "method": "GET",
      "path": "/v1/integrations/{name}/status"
    }
  ],
  "tags": [
    "platform",
    "v1"
  ]
}