{
  "id": "cart-api",
  "name": "Cart API",
  "version": "v1",
  "description": "Gestion du panier d'achat. Ajout, suppression et mise à jour des articles avant commande. Gère les sessions anonymes.",
  "team": "Equipe Commerce",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/cart",
  "endpoints": [
    {
      "method": "GET",
      "path": "/v1/cart/{userId}"
    },
    {
      "method": "POST",
      "path": "/v1/cart/{userId}/items"
    },
    {
      "method": "PUT",
      "path": "/v1/cart/{userId}/items/{itemId}"
    },
    {
      "method": "DELETE",
      "path": "/v1/cart/{userId}/items/{itemId}"
    },
    {
      "method": "POST",
      "path": "/v1/cart/{userId}/checkout"
    }
  ],
  "tags": [
    "commerce",
    "v1"
  ]
}