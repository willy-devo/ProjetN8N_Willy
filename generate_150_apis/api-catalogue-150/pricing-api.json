{
  "id": "pricing-api",
  "name": "Pricing API",
  "version": "v1",
  "description": "Gestion des prix et promotions. Calcul des remises, codes promo et règles tarifaires dynamiques.",
  "team": "Equipe Commerce",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/pricing",
  "endpoints": [
    {
      "method": "GET",
      "path": "/v1/pricing/product/{productId}"
    },
    {
      "method": "POST",
      "path": "/v1/pricing/calculate"
    },
    {
      "method": "POST",
      "path": "/v1/pricing/promo/validate"
    },
    {
      "method": "GET",
      "path": "/v1/pricing/rules"
    },
    {
      "method": "PUT",
      "path": "/v1/pricing/rules/{id}"
    }
  ],
  "tags": [
    "commerce",
    "v1"
  ]
}