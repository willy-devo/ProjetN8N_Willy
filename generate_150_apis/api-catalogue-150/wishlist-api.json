{
  "id": "wishlist-api",
  "name": "Wishlist API",
  "version": "v1",
  "description": "Gestion des listes de souhaits clients. Ajouter, supprimer des produits désirés. Similaire au panier mais sans intention d'achat immédiate.",
  "team": "Equipe Commerce",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/wishlist",
  "endpoints": [
    {
      "method": "GET",
      "path": "/v1/wishlists/{userId}"
    },
    {
      "method": "POST",
      "path": "/v1/wishlists/{userId}/items"
    },
    {
      "method": "DELETE",
      "path": "/v1/wishlists/{userId}/items/{itemId}"
    },
    {
      "method": "POST",
      "path": "/v1/wishlists/{userId}/share"
    }
  ],
  "tags": [
    "commerce",
    "v1"
  ]
}