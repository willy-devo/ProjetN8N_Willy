{
  "id": "recommendation-api",
  "name": "Recommendation API",
  "version": "v1",
  "description": "Recommandations personnalisées de produits. Algorithmes collaboratifs et basés sur le contenu.",
  "team": "Equipe Data",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/recommendation",
  "endpoints": [
    {
      "method": "GET",
      "path": "/v1/recommendations/{userId}"
    },
    {
      "method": "GET",
      "path": "/v1/recommendations/similar/{productId}"
    },
    {
      "method": "GET",
      "path": "/v1/recommendations/trending"
    },
    {
      "method": "POST",
      "path": "/v1/recommendations/feedback"
    }
  ],
  "tags": [
    "data",
    "v1"
  ]
}