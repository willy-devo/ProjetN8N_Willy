{
  "id": "media-api",
  "name": "Media API",
  "version": "v1",
  "description": "Gestion des médias images et vidéos. Upload, redimensionnement, optimisation et CDN. Faux positif avec File Storage — Media traite les fichiers multimédias, Storage tous les types.",
  "team": "Equipe Platform",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/media",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/media/upload"
    },
    {
      "method": "GET",
      "path": "/v1/media/{id}"
    },
    {
      "method": "POST",
      "path": "/v1/media/{id}/resize"
    },
    {
      "method": "GET",
      "path": "/v1/media/{id}/cdn-url"
    },
    {
      "method": "DELETE",
      "path": "/v1/media/{id}"
    }
  ],
  "tags": [
    "platform",
    "v1"
  ]
}