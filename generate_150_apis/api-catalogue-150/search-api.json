{
  "id": "search-api",
  "name": "Search API",
  "version": "v1",
  "description": "Recherche full-text sur le catalogue produits et commandes. Supporte les filtres, facettes et tri par pertinence.",
  "team": "Equipe Platform",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/search",
  "endpoints": [
    {
      "method": "GET",
      "path": "/v1/search?q={query}"
    },
    {
      "method": "GET",
      "path": "/v1/search/products?category={cat}"
    },
    {
      "method": "GET",
      "path": "/v1/search/orders?status={status}"
    },
    {
      "method": "POST",
      "path": "/v1/search/advanced"
    }
  ],
  "tags": [
    "platform",
    "v1"
  ]
}