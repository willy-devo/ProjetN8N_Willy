{
  "id": "recruitment-api",
  "name": "Recruitment API",
  "version": "v1",
  "description": "Gestion du recrutement et des candidatures. Offres d'emploi, candidats et processus de sélection.",
  "team": "Equipe RH",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/recruitment",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/jobs"
    },
    {
      "method": "GET",
      "path": "/v1/jobs"
    },
    {
      "method": "POST",
      "path": "/v1/jobs/{id}/apply"
    },
    {
      "method": "GET",
      "path": "/v1/jobs/{id}/candidates"
    },
    {
      "method": "PUT",
      "path": "/v1/candidates/{id}/status"
    }
  ],
  "tags": [
    "rh",
    "v1"
  ]
}