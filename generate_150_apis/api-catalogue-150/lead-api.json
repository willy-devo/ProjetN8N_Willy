{
  "id": "lead-api",
  "name": "Lead API",
  "version": "v1",
  "description": "Gestion des prospects et leads commerciaux. Scoring, qualification et assignation aux commerciaux. Faux positif avec CRM Contact — Lead gère les prospects non-clients, Contact gère tous les contacts.",
  "team": "Equipe CRM",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/lead",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/leads"
    },
    {
      "method": "GET",
      "path": "/v1/leads/{id}"
    },
    {
      "method": "PUT",
      "path": "/v1/leads/{id}/qualify"
    },
    {
      "method": "PUT",
      "path": "/v1/leads/{id}/assign"
    },
    {
      "method": "GET",
      "path": "/v1/leads/score/{id}"
    }
  ],
  "tags": [
    "crm",
    "v1"
  ]
}