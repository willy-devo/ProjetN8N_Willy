{
  "id": "crm-contact-api",
  "name": "CRM Contact API",
  "version": "v1",
  "description": "Gestion des contacts CRM. Création, enrichissement et segmentation des contacts clients et prospects.",
  "team": "Equipe CRM",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/crm-contact",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/crm/contacts"
    },
    {
      "method": "GET",
      "path": "/v1/crm/contacts/{id}"
    },
    {
      "method": "PUT",
      "path": "/v1/crm/contacts/{id}"
    },
    {
      "method": "DELETE",
      "path": "/v1/crm/contacts/{id}"
    },
    {
      "method": "POST",
      "path": "/v1/crm/contacts/search"
    }
  ],
  "tags": [
    "crm",
    "v1"
  ]
}