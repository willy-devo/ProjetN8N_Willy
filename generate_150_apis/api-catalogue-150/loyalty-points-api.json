{
  "id": "loyalty-points-api",
  "name": "Loyalty Points API",
  "version": "v1",
  "description": "Gestion des points de fidélité clients. Accumulation, consultation et utilisation des points de récompense.",
  "team": "Equipe CRM",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/loyalty-points",
  "endpoints": [
    {
      "method": "GET",
      "path": "/v1/loyalty/{customerId}"
    },
    {
      "method": "POST",
      "path": "/v1/loyalty/earn"
    },
    {
      "method": "POST",
      "path": "/v1/loyalty/redeem"
    },
    {
      "method": "GET",
      "path": "/v1/loyalty/{customerId}/history"
    }
  ],
  "tags": [
    "crm",
    "v1"
  ]
}