{
  "id": "tax-api",
  "name": "Tax API",
  "version": "v1",
  "description": "Calcul des taxes et TVA selon les régions. Conformité fiscale internationale et déclarations.",
  "team": "Equipe Finance",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/tax",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/tax/calculate"
    },
    {
      "method": "GET",
      "path": "/v1/tax/rates?country={code}"
    },
    {
      "method": "POST",
      "path": "/v1/tax/validate-vat"
    },
    {
      "method": "GET",
      "path": "/v1/tax/reports?period={period}"
    }
  ],
  "tags": [
    "finance",
    "v1"
  ]
}