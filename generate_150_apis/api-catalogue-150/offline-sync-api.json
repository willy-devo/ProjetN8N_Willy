{
  "id": "offline-sync-api",
  "name": "Offline Sync API",
  "version": "v1",
  "description": "Synchronisation des données en mode hors-ligne. Gestion des conflits et réconciliation des données.",
  "team": "Equipe Mobile",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/offline-sync",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/sync/push"
    },
    {
      "method": "GET",
      "path": "/v1/sync/pull?since={timestamp}"
    },
    {
      "method": "POST",
      "path": "/v1/sync/resolve-conflict"
    },
    {
      "method": "GET",
      "path": "/v1/sync/status/{deviceId}"
    }
  ],
  "tags": [
    "mobile",
    "v1"
  ]
}