{
  "id": "messaging-api",
  "name": "Messaging API",
  "version": "v1",
  "description": "Messagerie interne entre utilisateurs. Chat en temps réel, historique et modération. Faux positif avec Notification API — Messaging est bidirectionnel, Notification est unidirectionnel.",
  "team": "Equipe Platform",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/messaging",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/messages"
    },
    {
      "method": "GET",
      "path": "/v1/messages/conversations/{userId}"
    },
    {
      "method": "GET",
      "path": "/v1/messages/{conversationId}"
    },
    {
      "method": "DELETE",
      "path": "/v1/messages/{id}"
    }
  ],
  "tags": [
    "platform",
    "v1"
  ]
}