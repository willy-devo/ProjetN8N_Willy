{
  "id": "api-key-api",
  "name": "API Key API",
  "version": "v1",
  "description": "Gestion des clés API et tokens d'accès. Création, révocation et rotation des clés.",
  "team": "Equipe Security",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/api-key",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/api-keys"
    },
    {
      "method": "GET",
      "path": "/v1/api-keys"
    },
    {
      "method": "DELETE",
      "path": "/v1/api-keys/{id}"
    },
    {
      "method": "POST",
      "path": "/v1/api-keys/{id}/rotate"
    }
  ],
  "tags": [
    "security",
    "v1"
  ]
}