{
  "id": "auth-api",
  "name": "Auth API",
  "version": "v2",
  "description": "Authentification et autorisation. Gestion des tokens JWT, OAuth2 et refresh tokens.",
  "team": "Equipe Identity",
  "authentication": "Bearer Token JWT",
  "base_url": "/v2/auth",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v2/auth/login"
    },
    {
      "method": "POST",
      "path": "/v2/auth/logout"
    },
    {
      "method": "POST",
      "path": "/v2/auth/refresh"
    },
    {
      "method": "GET",
      "path": "/v2/auth/me"
    },
    {
      "method": "POST",
      "path": "/v2/auth/forgot-password"
    },
    {
      "method": "POST",
      "path": "/v2/auth/reset-password"
    }
  ],
  "tags": [
    "identity",
    "v2"
  ]
}