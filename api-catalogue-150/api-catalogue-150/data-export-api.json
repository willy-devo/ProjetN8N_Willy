{
  "id": "data-export-api",
  "name": "Data Export API",
  "version": "v1",
  "description": "Export massif de données en CSV, JSON ou Parquet. Jobs asynchrones et liens de téléchargement sécurisés.",
  "team": "Equipe Data",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/data-export",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/exports"
    },
    {
      "method": "GET",
      "path": "/v1/exports/{jobId}/status"
    },
    {
      "method": "GET",
      "path": "/v1/exports/{jobId}/download"
    },
    {
      "method": "DELETE",
      "path": "/v1/exports/{jobId}"
    }
  ],
  "tags": [
    "data",
    "v1"
  ]
}