{
  "id": "compliance-api",
  "name": "Compliance API",
  "version": "v1",
  "description": "Vérifications de conformité réglementaire. KYC, AML et validations légales. Faux positif avec GDPR API — Compliance couvre toutes les réglementations, GDPR uniquement la protection des données.",
  "team": "Equipe Security",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/compliance",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/compliance/kyc/verify"
    },
    {
      "method": "GET",
      "path": "/v1/compliance/kyc/{userId}/status"
    },
    {
      "method": "POST",
      "path": "/v1/compliance/aml/check"
    },
    {
      "method": "GET",
      "path": "/v1/compliance/reports"
    }
  ],
  "tags": [
    "security",
    "v1"
  ]
}