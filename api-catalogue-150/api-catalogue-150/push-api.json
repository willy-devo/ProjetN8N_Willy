{
  "id": "push-api",
  "name": "Push Notification API",
  "version": "v1",
  "description": "Notifications push mobiles iOS et Android. Gestion des tokens, segments et campagnes push. Faux positif avec Notification API — Push API se spécialise sur les appareils mobiles.",
  "team": "Equipe Platform",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/push",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/push/send"
    },
    {
      "method": "POST",
      "path": "/v1/push/register-device"
    },
    {
      "method": "DELETE",
      "path": "/v1/push/unregister-device"
    },
    {
      "method": "POST",
      "path": "/v1/push/campaigns"
    },
    {
      "method": "GET",
      "path": "/v1/push/campaigns/{id}/stats"
    }
  ],
  "tags": [
    "platform",
    "v1"
  ]
}