{
  "id": "session-api",
  "name": "Session API",
  "version": "v1",
  "description": "Gestion des sessions utilisateurs actives. Révocation, durée de vie et appareils connectés.",
  "team": "Equipe Identity",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/session",
  "endpoints": [
    {
      "method": "GET",
      "path": "/v1/sessions/user/{userId}"
    },
    {
      "method": "DELETE",
      "path": "/v1/sessions/{sessionId}"
    },
    {
      "method": "DELETE",
      "path": "/v1/sessions/user/{userId}/all"
    },
    {
      "method": "GET",
      "path": "/v1/sessions/devices/{userId}"
    }
  ],
  "tags": [
    "identity",
    "v1"
  ]
}