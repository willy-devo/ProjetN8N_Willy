{
  "id": "analytics-api",
  "name": "Analytics API",
  "version": "v1",
  "description": "Agrégation et reporting des données métier. Rapports ventes, trafic et comportement utilisateur en temps réel.",
  "team": "Equipe Data",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/analytics",
  "endpoints": [
    {
      "method": "GET",
      "path": "/v1/analytics/sales"
    },
    {
      "method": "GET",
      "path": "/v1/analytics/traffic"
    },
    {
      "method": "GET",
      "path": "/v1/analytics/conversion"
    },
    {
      "method": "POST",
      "path": "/v1/analytics/reports"
    },
    {
      "method": "GET",
      "path": "/v1/analytics/dashboard"
    }
  ],
  "tags": [
    "data",
    "v1"
  ]
}