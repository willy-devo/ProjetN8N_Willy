{
  "id": "invoice-api",
  "name": "Invoice API",
  "version": "v1",
  "description": "Génération et gestion des factures. Création, envoi et archivage des factures clients. Faux positif avec Billing API — Invoice gère les documents, Billing les cycles.",
  "team": "Equipe Finance",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/invoice",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/invoices"
    },
    {
      "method": "GET",
      "path": "/v1/invoices/{id}"
    },
    {
      "method": "GET",
      "path": "/v1/invoices/{id}/pdf"
    },
    {
      "method": "POST",
      "path": "/v1/invoices/{id}/send"
    },
    {
      "method": "PUT",
      "path": "/v1/invoices/{id}/void"
    }
  ],
  "tags": [
    "finance",
    "v1"
  ]
}