{
  "id": "sso-api",
  "name": "SSO API",
  "version": "v1",
  "description": "Single Sign-On pour les applications internes. Authentification centralisée SAML/OIDC. Faux positif avec Auth API — SSO gère la fédération d'identité, Auth les tokens applicatifs.",
  "team": "Equipe Identity",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/sso",
  "endpoints": [
    {
      "method": "GET",
      "path": "/v1/sso/login?provider={provider}"
    },
    {
      "method": "GET",
      "path": "/v1/sso/callback"
    },
    {
      "method": "POST",
      "path": "/v1/sso/logout"
    },
    {
      "method": "GET",
      "path": "/v1/sso/providers"
    }
  ],
  "tags": [
    "identity",
    "v1"
  ]
}