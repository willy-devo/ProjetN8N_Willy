{
  "id": "store-locator-api",
  "name": "Store Locator API",
  "version": "v1",
  "description": "Localisation des points de vente et magasins. Recherche par proximité, horaires et disponibilités.",
  "team": "Equipe Commerce",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/store-locator",
  "endpoints": [
    {
      "method": "GET",
      "path": "/v1/stores/nearby?lat={lat}&lng={lng}"
    },
    {
      "method": "GET",
      "path": "/v1/stores/{id}"
    },
    {
      "method": "GET",
      "path": "/v1/stores/{id}/hours"
    },
    {
      "method": "GET",
      "path": "/v1/stores/{id}/stock/{productId}"
    }
  ],
  "tags": [
    "commerce",
    "v1"
  ]
}