{
  "id": "shipping-api",
  "name": "Shipping API",
  "version": "v1",
  "description": "Gestion des expéditions et livraisons. Calcul des frais de port, suivi colis et gestion des retours.",
  "team": "Equipe Logistique",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/shipping",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/shipping/estimate"
    },
    {
      "method": "POST",
      "path": "/v1/shipping/create"
    },
    {
      "method": "GET",
      "path": "/v1/shipping/{trackingId}"
    },
    {
      "method": "PUT",
      "path": "/v1/shipping/{trackingId}/cancel"
    },
    {
      "method": "POST",
      "path": "/v1/shipping/return"
    }
  ],
  "tags": [
    "logistique",
    "v1"
  ]
}