{
  "id": "contract-api",
  "name": "Contract API",
  "version": "v1",
  "description": "Gestion des contrats B2B et partenariats. Création, signature électronique et suivi des échéances.",
  "team": "Equipe Supply",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/contract",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/contracts"
    },
    {
      "method": "GET",
      "path": "/v1/contracts/{id}"
    },
    {
      "method": "POST",
      "path": "/v1/contracts/{id}/sign"
    },
    {
      "method": "GET",
      "path": "/v1/contracts/expiring"
    }
  ],
  "tags": [
    "supply",
    "v1"
  ]
}