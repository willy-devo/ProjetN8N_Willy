{
  "id": "segmentation-api",
  "name": "Segmentation API",
  "version": "v1",
  "description": "Segmentation automatique des clients. Création de segments basés sur le comportement et les attributs.",
  "team": "Equipe CRM",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/segmentation",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/segments"
    },
    {
      "method": "GET",
      "path": "/v1/segments/{id}/members"
    },
    {
      "method": "PUT",
      "path": "/v1/segments/{id}/rules"
    },
    {
      "method": "POST",
      "path": "/v1/segments/preview"
    }
  ],
  "tags": [
    "crm",
    "v1"
  ]
}