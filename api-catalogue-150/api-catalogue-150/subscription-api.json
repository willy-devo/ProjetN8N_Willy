{
  "id": "subscription-api",
  "name": "Subscription API",
  "version": "v2",
  "description": "Gestion des abonnements produits et services. Plans tarifaires, upgrades et résiliations. Faux positif avec Billing API — Subscription gère les plans, Billing les paiements.",
  "team": "Equipe Commerce",
  "authentication": "Bearer Token JWT",
  "base_url": "/v2/subscription",
  "endpoints": [
    {
      "method": "GET",
      "path": "/v2/subscriptions/{customerId}"
    },
    {
      "method": "POST",
      "path": "/v2/subscriptions"
    },
    {
      "method": "PUT",
      "path": "/v2/subscriptions/{id}/upgrade"
    },
    {
      "method": "PUT",
      "path": "/v2/subscriptions/{id}/downgrade"
    },
    {
      "method": "DELETE",
      "path": "/v2/subscriptions/{id}"
    }
  ],
  "tags": [
    "commerce",
    "v2"
  ]
}