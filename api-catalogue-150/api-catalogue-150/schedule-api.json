{
  "id": "schedule-api",
  "name": "Schedule API",
  "version": "v1",
  "description": "Planification de tâches récurrentes. Cron jobs, déclencheurs temporels et gestion des fuseaux horaires. Faux positif avec Task API — Schedule planifie, Task exécute.",
  "team": "Equipe Platform",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/schedule",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/schedules"
    },
    {
      "method": "GET",
      "path": "/v1/schedules/{id}"
    },
    {
      "method": "PUT",
      "path": "/v1/schedules/{id}/pause"
    },
    {
      "method": "PUT",
      "path": "/v1/schedules/{id}/resume"
    },
    {
      "method": "DELETE",
      "path": "/v1/schedules/{id}"
    }
  ],
  "tags": [
    "platform",
    "v1"
  ]
}