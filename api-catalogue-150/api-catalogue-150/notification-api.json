{
  "id": "notification-api",
  "name": "Notification API",
  "version": "v1",
  "description": "Envoi de notifications multicanal (email, SMS, push) pour les utilisateurs de la plateforme.",
  "team": "Equipe Platform",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/notification",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/notifications/send"
    },
    {
      "method": "POST",
      "path": "/v1/notifications/schedule"
    },
    {
      "method": "GET",
      "path": "/v1/notifications/{id}"
    },
    {
      "method": "GET",
      "path": "/v1/notifications"
    },
    {
      "method": "DELETE",
      "path": "/v1/notifications/{id}"
    },
    {
      "method": "GET",
      "path": "/v1/notifications/stats"
    }
  ],
  "tags": [
    "platform",
    "v1"
  ]
}