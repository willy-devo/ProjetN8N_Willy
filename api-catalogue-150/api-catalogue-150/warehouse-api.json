{
  "id": "warehouse-api",
  "name": "Warehouse API",
  "version": "v1",
  "description": "Gestion des entrepôts et emplacements physiques. Suivi des mouvements de stock entre entrepôts. Faux positif avec Inventory — Warehouse gère les lieux physiques, Inventory les quantités.",
  "team": "Equipe Logistique",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/warehouse",
  "endpoints": [
    {
      "method": "GET",
      "path": "/v1/warehouses"
    },
    {
      "method": "GET",
      "path": "/v1/warehouses/{id}/stock"
    },
    {
      "method": "POST",
      "path": "/v1/warehouses/transfer"
    },
    {
      "method": "GET",
      "path": "/v1/warehouses/{id}/locations"
    }
  ],
  "tags": [
    "logistique",
    "v1"
  ]
}