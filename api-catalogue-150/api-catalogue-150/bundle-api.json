{
  "id": "bundle-api",
  "name": "Bundle API",
  "version": "v1",
  "description": "Gestion des offres groupées et kits produits. Création, tarification et disponibilité des bundles.",
  "team": "Equipe Catalog",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/bundle",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/bundles"
    },
    {
      "method": "GET",
      "path": "/v1/bundles/{id}"
    },
    {
      "method": "GET",
      "path": "/v1/bundles/{id}/price"
    },
    {
      "method": "GET",
      "path": "/v1/bundles/{id}/availability"
    }
  ],
  "tags": [
    "catalog",
    "v1"
  ]
}