{
  "id": "fraud-detection-api",
  "name": "Fraud Detection API",
  "version": "v1",
  "description": "Détection des transactions frauduleuses en temps réel. Scoring de risque et blocage automatique.",
  "team": "Equipe Finance",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/fraud-detection",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/fraud/score"
    },
    {
      "method": "POST",
      "path": "/v1/fraud/report"
    },
    {
      "method": "GET",
      "path": "/v1/fraud/rules"
    },
    {
      "method": "PUT",
      "path": "/v1/fraud/rules/{id}"
    }
  ],
  "tags": [
    "finance",
    "v1"
  ]
}