{
  "id": "ab-testing-api",
  "name": "A/B Testing API",
  "version": "v1",
  "description": "Gestion des expérimentations et tests A/B. Création de variantes, assignation et analyse des résultats.",
  "team": "Equipe Data",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/ab-testing",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/experiments"
    },
    {
      "method": "GET",
      "path": "/v1/experiments/{id}"
    },
    {
      "method": "POST",
      "path": "/v1/experiments/{id}/assign"
    },
    {
      "method": "POST",
      "path": "/v1/experiments/{id}/convert"
    },
    {
      "method": "GET",
      "path": "/v1/experiments/{id}/results"
    }
  ],
  "tags": [
    "data",
    "v1"
  ]
}