{
  "id": "training-api",
  "name": "Training API",
  "version": "v1",
  "description": "Gestion de la formation professionnelle. Catalogue de formations, inscriptions et suivi des compétences.",
  "team": "Equipe RH",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/training",
  "endpoints": [
    {
      "method": "GET",
      "path": "/v1/trainings"
    },
    {
      "method": "POST",
      "path": "/v1/trainings/{id}/enroll"
    },
    {
      "method": "GET",
      "path": "/v1/trainings/{employeeId}/completed"
    },
    {
      "method": "GET",
      "path": "/v1/skills/{employeeId}"
    }
  ],
  "tags": [
    "rh",
    "v1"
  ]
}