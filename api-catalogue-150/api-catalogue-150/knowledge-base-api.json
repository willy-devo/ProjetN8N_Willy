{
  "id": "knowledge-base-api",
  "name": "Knowledge Base API",
  "version": "v1",
  "description": "Base de connaissances et FAQ. Gestion des articles, recherche et suggestions automatiques.",
  "team": "Equipe Support",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/knowledge-base",
  "endpoints": [
    {
      "method": "GET",
      "path": "/v1/kb/articles"
    },
    {
      "method": "POST",
      "path": "/v1/kb/articles"
    },
    {
      "method": "GET",
      "path": "/v1/kb/articles/{id}"
    },
    {
      "method": "GET",
      "path": "/v1/kb/search?q={query}"
    },
    {
      "method": "GET",
      "path": "/v1/kb/suggest?ticketId={id}"
    }
  ],
  "tags": [
    "support",
    "v1"
  ]
}