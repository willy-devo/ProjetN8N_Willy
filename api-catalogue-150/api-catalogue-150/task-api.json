{
  "id": "task-api",
  "name": "Task API",
  "version": "v1",
  "description": "Gestion des tâches et files d'attente asynchrones. Création, priorité et monitoring des jobs.",
  "team": "Equipe Platform",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/task",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/tasks"
    },
    {
      "method": "GET",
      "path": "/v1/tasks/{id}"
    },
    {
      "method": "PUT",
      "path": "/v1/tasks/{id}/cancel"
    },
    {
      "method": "GET",
      "path": "/v1/tasks/queue/stats"
    }
  ],
  "tags": [
    "platform",
    "v1"
  ]
}