{
  "id": "inventory-api",
  "name": "Inventory API",
  "version": "v3",
  "description": "Gestion des stocks et inventaires produits. Suivi en temps réel, alertes de rupture et réapprovisionnement automatique.",
  "team": "Equipe Logistique",
  "authentication": "Bearer Token JWT",
  "base_url": "/v3/inventory",
  "endpoints": [
    {
      "method": "GET",
      "path": "/v3/inventory"
    },
    {
      "method": "GET",
      "path": "/v3/inventory/{productId}"
    },
    {
      "method": "PUT",
      "path": "/v3/inventory/{productId}/stock"
    },
    {
      "method": "POST",
      "path": "/v3/inventory/alerts"
    },
    {
      "method": "POST",
      "path": "/v3/inventory/restock"
    }
  ],
  "tags": [
    "logistique",
    "v3"
  ]
}