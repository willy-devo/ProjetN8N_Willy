{
  "id": "config-api",
  "name": "Config API",
  "version": "v1",
  "description": "Gestion de la configuration applicative. Feature flags, paramètres et variables d'environnement.",
  "team": "Equipe Platform",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/config",
  "endpoints": [
    {
      "method": "GET",
      "path": "/v1/config/{key}"
    },
    {
      "method": "PUT",
      "path": "/v1/config/{key}"
    },
    {
      "method": "GET",
      "path": "/v1/config/features"
    },
    {
      "method": "PUT",
      "path": "/v1/config/features/{flag}/toggle"
    }
  ],
  "tags": [
    "platform",
    "v1"
  ]
}