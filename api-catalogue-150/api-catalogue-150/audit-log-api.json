{
  "id": "audit-log-api",
  "name": "Audit Log API",
  "version": "v1",
  "description": "Journal d'audit et traçabilité des actions. Enregistrement de toutes les opérations sensibles.",
  "team": "Equipe Security",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/audit-log",
  "endpoints": [
    {
      "method": "GET",
      "path": "/v1/audit/logs"
    },
    {
      "method": "GET",
      "path": "/v1/audit/logs?userId={id}"
    },
    {
      "method": "GET",
      "path": "/v1/audit/logs?resource={type}"
    },
    {
      "method": "POST",
      "path": "/v1/audit/export"
    }
  ],
  "tags": [
    "security",
    "v1"
  ]
}