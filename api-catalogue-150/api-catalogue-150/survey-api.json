{
  "id": "survey-api",
  "name": "Survey API",
  "version": "v1",
  "description": "Gestion des enquêtes de satisfaction. Création, envoi et analyse des résultats NPS et CSAT.",
  "team": "Equipe Support",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/survey",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/surveys"
    },
    {
      "method": "POST",
      "path": "/v1/surveys/{id}/send"
    },
    {
      "method": "POST",
      "path": "/v1/surveys/{id}/respond"
    },
    {
      "method": "GET",
      "path": "/v1/surveys/{id}/results"
    },
    {
      "method": "GET",
      "path": "/v1/surveys/nps"
    }
  ],
  "tags": [
    "support",
    "v1"
  ]
}