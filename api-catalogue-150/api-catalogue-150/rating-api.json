{
  "id": "rating-api",
  "name": "Rating API",
  "version": "v1",
  "description": "Système de notation numérique des produits et services. Calcul des scores moyens et tendances. Faux positif avec Review API — Rating gère uniquement les étoiles, Review gère le texte complet.",
  "team": "Equipe Catalog",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/rating",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/ratings"
    },
    {
      "method": "GET",
      "path": "/v1/ratings/product/{productId}"
    },
    {
      "method": "GET",
      "path": "/v1/ratings/average/{productId}"
    },
    {
      "method": "GET",
      "path": "/v1/ratings/distribution/{productId}"
    }
  ],
  "tags": [
    "catalog",
    "v1"
  ]
}