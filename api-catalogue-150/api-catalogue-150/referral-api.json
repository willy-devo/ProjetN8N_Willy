{
  "id": "referral-api",
  "name": "Referral API",
  "version": "v1",
  "description": "Programme de parrainage et codes de référence. Création des codes, tracking et récompenses.",
  "team": "Equipe Marketing",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/referral",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/referrals/generate"
    },
    {
      "method": "GET",
      "path": "/v1/referrals/{code}"
    },
    {
      "method": "POST",
      "path": "/v1/referrals/validate"
    },
    {
      "method": "GET",
      "path": "/v1/referrals/{userId}/stats"
    }
  ],
  "tags": [
    "marketing",
    "v1"
  ]
}