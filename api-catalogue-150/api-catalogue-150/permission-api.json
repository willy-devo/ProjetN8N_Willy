{
  "id": "permission-api",
  "name": "Permission API",
  "version": "v1",
  "description": "Gestion fine des permissions et rôles RBAC. Attribution des droits par ressource et action. Faux positif avec Auth API — Permission gère les droits, Auth l'authentification.",
  "team": "Equipe Identity",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/permission",
  "endpoints": [
    {
      "method": "GET",
      "path": "/v1/permissions/user/{userId}"
    },
    {
      "method": "POST",
      "path": "/v1/permissions/assign"
    },
    {
      "method": "DELETE",
      "path": "/v1/permissions/revoke"
    },
    {
      "method": "GET",
      "path": "/v1/roles"
    },
    {
      "method": "POST",
      "path": "/v1/roles"
    }
  ],
  "tags": [
    "identity",
    "v1"
  ]
}