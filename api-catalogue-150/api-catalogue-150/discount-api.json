{
  "id": "discount-api",
  "name": "Discount API",
  "version": "v1",
  "description": "Gestion des remises et codes de réduction. Création et validation des promotions. Faux positif avec Pricing API — Discount gère les campagnes, Pricing calcule les prix finaux.",
  "team": "Equipe Marketing",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/discount",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/discounts"
    },
    {
      "method": "GET",
      "path": "/v1/discounts/{code}"
    },
    {
      "method": "PUT",
      "path": "/v1/discounts/{id}/activate"
    },
    {
      "method": "PUT",
      "path": "/v1/discounts/{id}/deactivate"
    },
    {
      "method": "GET",
      "path": "/v1/discounts/campaigns"
    }
  ],
  "tags": [
    "marketing",
    "v1"
  ]
}