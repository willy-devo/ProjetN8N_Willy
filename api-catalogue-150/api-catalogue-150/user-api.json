{
  "id": "user-api",
  "name": "User API",
  "version": "v2",
  "description": "Gestion des utilisateurs et profils. Inscription, mise à jour et suppression des comptes utilisateurs de la plateforme.",
  "team": "Equipe Identity",
  "authentication": "Bearer Token JWT",
  "base_url": "/v2/user",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v2/users/register"
    },
    {
      "method": "POST",
      "path": "/v2/users/login"
    },
    {
      "method": "GET",
      "path": "/v2/users/{id}"
    },
    {
      "method": "PUT",
      "path": "/v2/users/{id}"
    },
    {
      "method": "DELETE",
      "path": "/v2/users/{id}"
    }
  ],
  "tags": [
    "identity",
    "v2"
  ]
}