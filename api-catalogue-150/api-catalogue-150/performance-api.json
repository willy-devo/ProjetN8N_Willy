{
  "id": "performance-api",
  "name": "Performance API",
  "version": "v1",
  "description": "Évaluations de performance et objectifs. OKRs, feedback 360° et plans de développement.",
  "team": "Equipe RH",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/performance",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/performance/reviews"
    },
    {
      "method": "GET",
      "path": "/v1/performance/{employeeId}"
    },
    {
      "method": "POST",
      "path": "/v1/performance/objectives"
    },
    {
      "method": "PUT",
      "path": "/v1/performance/objectives/{id}/progress"
    }
  ],
  "tags": [
    "rh",
    "v1"
  ]
}