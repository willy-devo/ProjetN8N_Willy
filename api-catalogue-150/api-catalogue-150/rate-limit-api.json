{
  "id": "rate-limit-api",
  "name": "Rate Limit API",
  "version": "v1",
  "description": "Gestion des limites de débit par client et endpoint. Configuration des quotas et blacklists.",
  "team": "Equipe Platform",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/rate-limit",
  "endpoints": [
    {
      "method": "GET",
      "path": "/v1/rate-limits/{clientId}"
    },
    {
      "method": "PUT",
      "path": "/v1/rate-limits/{clientId}"
    },
    {
      "method": "DELETE",
      "path": "/v1/rate-limits/{clientId}/reset"
    },
    {
      "method": "POST",
      "path": "/v1/rate-limits/blacklist"
    }
  ],
  "tags": [
    "platform",
    "v1"
  ]
}