{
  "id": "event-tracking-api",
  "name": "Event Tracking API",
  "version": "v1",
  "description": "Collecte des événements utilisateurs pour l'analyse comportementale. Clics, pages vues, funnels.",
  "team": "Equipe Data",
  "authentication": "Bearer Token JWT",
  "base_url": "/v1/event-tracking",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/events/track"
    },
    {
      "method": "POST",
      "path": "/v1/events/batch"
    },
    {
      "method": "GET",
      "path": "/v1/events/funnels/{funnelId}"
    },
    {
      "method": "GET",
      "path": "/v1/events/sessions/{userId}"
    }
  ],
  "tags": [
    "data",
    "v1"
  ]
}