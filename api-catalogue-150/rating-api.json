{
  "openapi": "3.0.0",
  "info": {
    "title": "Rating API",
    "version": "1.0.0",
    "x-api-id": "rating-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe Catalog",
    "x-domain": "E-Commerce",
    "description": "Notations numériques produits (1-5 étoiles). Scores moyens et distributions. DIFFÉRENCE vs review-api : Rating = note numérique seule, Review = texte complet + note. Cas d'usage : vote rapide sans rédiger un avis.",
    "x-false-positive-warning": "Avis textuels → review-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v1/ratings": {
      "post": {
        "summary": "Soumettre une note",
        "operationId": "createRating",
        "tags": [
          "Ratings"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "product_id",
                  "score",
                  "user_id"
                ],
                "properties": {
                  "product_id": {
                    "type": "string"
                  },
                  "score": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 5
                  },
                  "user_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Note enregistrée"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/ratings/product/{productId}": {
      "parameters": [
        {
          "name": "productId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Toutes les notes d'un produit",
        "operationId": "getProductRatings",
        "tags": [
          "Ratings"
        ],
        "responses": {
          "200": {
            "description": "Notes"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/ratings/average/{productId}": {
      "parameters": [
        {
          "name": "productId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Moyenne des notes",
        "operationId": "getAverageRating",
        "tags": [
          "Ratings"
        ],
        "responses": {
          "200": {
            "description": "Moyenne"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/ratings/distribution/{productId}": {
      "parameters": [
        {
          "name": "productId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Distribution des notes (1 à 5 étoiles)",
        "operationId": "getRatingDistribution",
        "tags": [
          "Ratings"
        ],
        "responses": {
          "200": {
            "description": "Distribution"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "NOT_FOUND"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Clé API manquante ou invalide",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Ressource non trouvée",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit — ressource déjà existante ou état incompatible",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Clé API Kong Gateway"
      }
    }
  }
}