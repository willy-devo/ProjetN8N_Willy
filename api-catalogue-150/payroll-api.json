{
  "openapi": "3.0.0",
  "info": {
    "title": "Payroll API",
    "version": "1.0.0",
    "x-api-id": "payroll-api",
    "x-api-version": "v1",
    "x-status": "active",
    "x-team": "Equipe RH",
    "x-domain": "Human Resources",
    "description": "Paie et bulletins de salaire. Calcul des rémunérations, charges sociales et virements. DIFFÉRENCE vs billing-api : Payroll concerne les salaires des employés, Billing concerne la facturation clients.",
    "x-false-positive-warning": "Facturation clients → billing-api."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Kong API Gateway — Devoteam nexDigital"
    }
  ],
  "paths": {
    "/v1/payroll/run": {
      "post": {
        "summary": "Lancer le calcul de la paie du mois",
        "operationId": "runPayroll",
        "tags": [
          "Payroll"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "month",
                  "year"
                ],
                "properties": {
                  "month": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 12
                  },
                  "year": {
                    "type": "integer"
                  },
                  "department": {
                    "type": "string",
                    "description": "Si absent, toute l'entreprise"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Calcul lancé"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/payroll/{employeeId}/slips": {
      "parameters": [
        {
          "name": "employeeId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Liste des bulletins de salaire",
        "operationId": "getPaySlips",
        "tags": [
          "Payroll"
        ],
        "responses": {
          "200": {
            "description": "Bulletins"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/payroll/{employeeId}/slips/{month}": {
      "parameters": [
        {
          "name": "employeeId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        },
        {
          "name": "month",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "example": "2026-04"
          }
        }
      ],
      "get": {
        "summary": "Bulletin d'un mois spécifique",
        "operationId": "getPaySlip",
        "tags": [
          "Payroll"
        ],
        "responses": {
          "200": {
            "description": "Bulletin"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/payroll/simulate": {
      "post": {
        "summary": "Simuler la paie d'un employé",
        "operationId": "simulatePayroll",
        "tags": [
          "Payroll"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "employee_id": {
                    "type": "string"
                  },
                  "gross_salary": {
                    "type": "number"
                  },
                  "bonuses": {
                    "type": "number"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Simulation"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "NOT_FOUND"
          },
          "message": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Données invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Clé API manquante ou invalide",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Ressource non trouvée",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflit — ressource déjà existante ou état incompatible",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Clé API Kong Gateway"
      }
    }
  }
}